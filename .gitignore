# === omostation root .gitignore ===
# 根仓库只追踪元配置、基础设施和文档。
# 项目代码在各子仓库中独立管理。

# ---- 项目目录（独立 git 仓库） ----
projects/kairon/
projects/agentmesh/
projects/gbrain/
projects/_archived/

# ---- 运行时数据持久层 ----
data/sharedbrain/data/
data/kos/

# ---- 运行时日志（Hermes Agent 持续写入） ----
agent-runtime/

# ---- 构建产物 ----
.env
__pycache__/
*.pyc
node_modules/

# ---- graphify产物 ----
graphify-out/

dist/
*.egg-info/
*.so

# ---- macOS ----
.DS_Store

# ---- 缓存 ----
.pytest_cache/
.ruff_cache/
.coverage
.runtime/
runtime/*
!runtime/README.md
!runtime/run-continuation/
runtime/run-continuation/*
!runtime/run-continuation/README.md

# ---- 运行时数据 ----
data/backups/
data/**/*.db
data/**/*.db-shm
data/**/*.db-wal
data/**/*.sqlite
data/**/*.sqlite3

# ---- 工具运行时状态 ----
.omc/state/
.omc/project-memory.json
.omc/state/agent-replay-*.jsonl
.omc/state/last-tool-error.json
.omc/state/subagent-tracking.json
.omc/state/sessions/
.omc/state/checkpoints/
.omc/sessions/
.omo/plans/
.omo/run-continuation/
