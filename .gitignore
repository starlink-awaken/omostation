# === omostation root .gitignore ===
# 根仓库只追踪元配置、基础设施和文档。
# 项目代码在各子仓库中独立管理。

# ---- OMO / OMC 运行时与治理产物 ----
.omo/.omo/
.omo/_archive/
.omo/_delivery/
.omo/_log/
.omo/_knowledge/*.jsonl
.omo/_control/evolution/drift-history/*.json.lock
.omo/capabilities/
.omo/debt/
.omo/evidence
.omo/plans/
.omo/run-continuation/
.omo/tests/
.omo/workers/

.omc/autopilot/
.omc/handoffs/
.omc/logs/
.omc/notepads/
.omc/plans/
.omc/project-memory.json
.omc/prd.json
.omc/progress.txt
.omc/sessions/
.omc/state/

projects/.omc/
projects/cockpit-ui/
projects/ecos/src/ecos/ssot/mof/m0/snapshot.yaml

# ---- 运行时数据与日志 ----
agent-runtime/
runtime/agent-runtime/
runtime/**/*.log
runtime/data/kei_audit.jsonl
runtime/sandbox/decayed/
runtime/sandbox/pitches/

data/backups/
data/kos/
data/sharedbrain/data/
data/驾驶舱/
data/**/*.db
data/**/*.db-shm
data/**/*.db-wal
data/**/*.sqlite
data/**/*.sqlite3

kos/
graphify-out/
spaces/*.db
_derivation_logs/

# ---- 构建产物与缓存 ----
.env
__pycache__/
*.egg-info/
*.pyc
*.so
dist/
node_modules/

.coverage
.mypy_cache/
.pytest_cache/
.ruff_cache/
.runtime/

.grok/
.reasonix/
.antigravitycli/
.hermes/
.mimocode/
.deepeval/
.codebuddy/
.crush/
.husky/
.idea/
.serena/
.claude/


# ---- 本地工具与敏感配置 ----
.metaos/
.qoder/
config/
*.local.json

# ---- 本地开发沙箱与一次性脚本 ----
/scratch/
**/_tmp_*
**/temp_*

/fix_indent.py
/patch.py
/patch_all.py
/patch_scenario.py
/patch_scenario2.py
/patch_scenario3.py
