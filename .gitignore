# === omostation root .gitignore ===
# 根仓库只追踪元配置、基础设施和文档。
# 项目代码在各子仓库中独立管理。

# ---- 项目目录（独立 git 仓库） ----

# ---- 运行时数据 ----
data/sharedbrain/data/
data/kos/
data/驾驶舱/

# ---- 运行时日志 ----
runtime/agent-runtime/
agent-runtime/

# ---- Daemon 日志 ----
.omo/_delivery/

# ---- 治理审计日志 ----
.omo/_knowledge/governance-history.jsonl

# ---- 债务仪表板（自动生成） ----
.omo/debt/

# ---- MOF 快照（自动生成） ----
projects/ecos/src/ecos/ssot/mof/m0/snapshot.yaml

# ---- 构建产物 ----
.env
__pycache__/
*.pyc
node_modules/
dist/
*.egg-info/
*.so

# ---- macOS ----
.DS_Store

# ---- 缓存 ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.runtime/

# ---- KOS 运行时索引 ----
kos/

# ---- 外部工具数据 ----
spaces/
_derivation_logs/

# ---- 运行时数据 ----
data/backups/
data/**/*.db
data/**/*.db-shm
data/**/*.db-wal
data/**/*.sqlite
data/**/*.sqlite3

# ---- 工具运行时状态 ----
.omc/state/
.omc/project-memory.json
.omc/state/agent-replay-*.jsonl
.omc/state/last-tool-error.json
.omc/state/subagent-tracking.json
.omc/state/sessions/
.omc/state/checkpoints/
.omc/sessions/
.omo/plans/
.omo/run-continuation/

# ---- 第三方工具缓存 ----
.grok/
.reasonix/

# ---- Token 存储 ----
.metaos/

# PAI 框架运行时测试数据(.omo/capabilities/ 全部)
.omo/capabilities/

# Agent 运行时工作态（自动生成，gitignore）
.omo/workers/

# 治理审计日志（运行时 JSONL）
.omo/_knowledge/*.jsonl
