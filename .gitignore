# === omostation root .gitignore ===
# 根仓库只追踪元配置、基础设施和文档。
# 项目代码在各子仓库中独立管理。

# ---- 项目目录（独立 git 仓库） ----

# ---- 运行时数据 ----
data/sharedbrain/data/
data/kos/
data/驾驶舱/

# ---- 运行时日志 ----
runtime/agent-runtime/
agent-runtime/

# ---- OMO C2G Sandbox 工作区（OMO 治理引擎 auto-loop 产物，勿 commit） ----
runtime/sandbox/pitches/
runtime/sandbox/decayed/

# ---- OMO 嵌套目录（OMO_ROOT 解析错导致 daemon log 落到 .omo/.omo/） ----
.omo/.omo/

# ---- Daemon 日志 ----
.omo/_delivery/

# ---- 治理审计日志 ----
.omo/_knowledge/governance-history.jsonl

# ---- 旧归档（2026-02 遗留数据） ----
.omo/_archive/

# ---- 债务仪表板（自动生成） ----
.omo/debt/

# ---- MOF 快照（自动生成） ----
projects/ecos/src/ecos/ssot/mof/m0/snapshot.yaml

# ---- 构建产物 ----
.env
__pycache__/
*.pyc
node_modules/
dist/
*.egg-info/
*.so

# ---- macOS ----
.DS_Store

# ---- 缓存 ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.runtime/

# ---- KOS 运行时索引 ----
kos/

# ---- 外部工具数据 ----
spaces/
_derivation_logs/

# ---- 运行时数据 ----
data/backups/
data/**/*.db
data/**/*.db-shm
data/**/*.db-wal
data/**/*.sqlite
data/**/*.sqlite3

# ---- 工具运行时状态 ----
.omc/state/
.omc/project-memory.json
.omc/state/agent-replay-*.jsonl
.omc/state/last-tool-error.json
.omc/state/subagent-tracking.json
.omc/state/sessions/
.omc/state/checkpoints/
.omc/sessions/
.omo/plans/
.omo/run-continuation/

# ---- 第三方工具缓存 ----
.grok/
.reasonix/

# ---- Token 存储 ----
.metaos/

# PAI 框架运行时测试数据(.omo/capabilities/ 全部)
.omo/capabilities/

# Agent 运行时工作态（自动生成，gitignore）
.omo/workers/

# 治理审计日志（运行时 JSONL）
.omo/_knowledge/*.jsonl

# 运行时备份（自动创建，不入仓）
data/backups/

# 防 pytest 误把 .omo/ 当 test root 产生 dummy 文件
.omo/tests/

# ---- 一次性本地补丁脚本 ----
/fix_indent.py
/patch.py
/patch_all.py
/patch_scenario.py
/patch_scenario2.py
/patch_scenario3.py
/patch_scenario4.py
/patch_test.py
/patch_test2.py
