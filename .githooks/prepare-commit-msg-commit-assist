#!/bin/bash
# prepare-commit-msg-commit-assist — LLM-assisted commit message advisory hook
#
# 设计原则 (P76-7-1):
#   - LLM 永远不能 auto-apply (advisory only)
#   - 写侧车 .commit-suggestion (gitignored), 不直接注入 commit message
#   - developer 必须显式 `git commit -F .commit-suggestion` 接受
#   - git commit -m "..." / git commit --message 跳过 (developer knows what they want)
#
# 安装: 见 .githooks/README.md
#
# 退出码:
#   0 = success (write .commit-suggestion, NOT commit message)
#
# 设计抗-fail-safe: hook 永远不阻断 commit. 网络/parser 失败 → 沉默不写.
#   P76-7-2: tier-graceful-fallback (aetherforge → ollama → heuristic)

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

# Trigger condition: 只在 developer 用 editor / -F 模式时跑 (有 `git commit` 但没传 -m)
# 实际 Git 行为:
#   git commit -m "..."           → 跳过 (已 -m)
#   git commit -F <file>          → 跳过 (指定 source)
#   git commit                   → 调 editor, prepare hook 可注入
#   git commit --no-verify       → 不影响 hook 调用, developer 显式要求
# 我们通过 COMMIT_MSG_FILE 检测 (git 把临时文件传 hook)

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"  # message (用 -m 时) / template (用 .git/message 时)

# 跳过 -m 模式 (developer 已知意图)
if [ "$COMMIT_SOURCE" = "message" ]; then
  exit 0
fi

# 跳过模板模式 (merge / squash 自带消息)
if [ "$COMMIT_SOURCE" = "template" ]; then
  exit 0
fi

# 跳过 amend (developer 在编辑历史)
if [ "$COMMIT_SOURCE" = "commit" ]; then
  exit 0
fi

# 跳过非 staged 改动 (空 commit 也允许, 但不写 suggestion)
if git diff --cached --quiet 2>/dev/null; then
  exit 0  # 没有 staged 改动, 不做什么
fi

# 跳过 --no-verify / 跳过 commit-assist 自身 (避免无限循环)
COMMIT_ASSIST="$ROOT/bin/commit-assist.py"
if [ ! -f "$COMMIT_ASSIST" ]; then
  exit 0
fi

# 短超时, hook 不能卡 commit
SUGGESTION_FILE="$ROOT/.commit-suggestion"

# 调 commit-assist (Python 自带 subprocess timeout → 我们手动包过)
# 兜底: 用 python -u + signal.alarm 不可靠; 改为 fall-through to heuristic on timeout
# 取 .commit-suggestion 是否新写出来判定 ok
if uv run --no-project python "$COMMIT_ASSIST" --no-llm > "$COMMIT_MSG_FILE.tmp" 2>/dev/null \
   && [ -f "$ROOT/.commit-suggestion" ]; then
  # success — append hint to commit msg (但 NEVER overwrite developer msg)
  if [ -s "$COMMIT_MSG_FILE" ] && [ "$(tail -c 1 "$COMMIT_MSG_FILE" 2>/dev/null)" != "" ]; then
    echo "" >> "$COMMIT_MSG_FILE"
  fi
  cat >> "$COMMIT_MSG_FILE" <<'HINT'

# ── LLM-assisted suggestion available (P76 Phase 9A) ──────────────────────
# Generated by: bin/commit-assist.py (aetherforge|ollama|heuristic tier)
# To use: git commit -F .commit-suggestion
# Suggestion file: .commit-suggestion
HINT
  rm -f "$COMMIT_MSG_FILE.tmp"
fi

# 不管成败都 exit 0 (失败 silent, 修真修真反模式)
exit 0
