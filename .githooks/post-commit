#!/bin/bash
# post-commit — 异步写时更新 (Write-on-Commit)
#
# 每次本地提交成功后，异步执行治理数据生成，
# 确保仪表板数据绝对新鲜，彻底消灭滞后。

set -e

ROOT="$(git rev-parse --show-toplevel)"

if [ -f "$ROOT/scripts/generate-governance-data.py" ]; then
  # 异步非阻塞运行，不卡顿 Git Commit 交付体验
  nohup python3 "$ROOT/scripts/generate-governance-data.py" >/dev/null 2>&1 &
fi

exit 0
