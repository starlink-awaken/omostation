#!/bin/bash
# post-commit — 状态失效事件 (State-Stale Event)
#
# 每次本地提交成功后只 emit state_stale，真实投影刷新由
# `omo state sync` 单写者负责，避免多 agent commit 触发写风暴。

set -e

ROOT="$(git rev-parse --show-toplevel)"

if [ -f "$ROOT/bin/state-stale-emit.py" ]; then
  python3 "$ROOT/bin/state-stale-emit.py" \
    --source "git-post-commit" \
    --trigger "post-commit" \
    --surface ".omo/state" \
    --quiet >/dev/null 2>&1 || true
fi

exit 0
