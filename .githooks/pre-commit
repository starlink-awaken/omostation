#!/bin/bash
# pre-commit — GaC + SSOT 本地硬门
#
# commit 前:
#   1. hygiene advisory: 0 字节/大小写冲突提示
#   2. GaC local gate: validate + drift + doc SSOT + snapshot + doc links
#   3. SSOT guardian: task count/current wave/submodule/direct-io 等漂移
#   4. audit-engine: Python AST 静态非原子写审计与拦截
#
# 安装: make install-hooks (从 .githooks/ 复制到 .git/hooks/)
# 新 clone 必跑: make install-hooks

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

if [ -x "$ROOT/bin/gac-hygiene-check.py" ]; then
  # advisory: 输出到 stderr, 不阻断 commit (|| true)
  python3 "$ROOT/bin/gac-hygiene-check.py" 2>&1 | sed 's/^/[hygiene] /' >&2 || true
fi

run_py_with_yaml() {
  local script="$1"
  shift
  if command -v uv >/dev/null 2>&1; then
    uv run --with pyyaml python "$script" "$@"
  else
    python3 "$script" "$@"
  fi
}

if [ -f "$ROOT/bin/gac-local-gate.py" ]; then
  run_py_with_yaml "$ROOT/bin/gac-local-gate.py" 2>&1 | sed 's/^/[gac] /' >&2
fi

if [ -f "$ROOT/bin/ssot-guardian.py" ]; then
  run_py_with_yaml "$ROOT/bin/ssot-guardian.py" 2>&1 | sed 's/^/[ssot] /' >&2
fi

if [ -f "$ROOT/bin/gac-audit-engine.py" ]; then
  # 调用中央 audit-engine 进行 atomic_write (debt) 的静态 AST 审计拦截
  python3 "$ROOT/bin/gac-audit-engine.py" --staged 2>&1 | sed 's/^/[audit] /' >&2
fi

# ── Debt directory deletion guard ──
# 禁止 unstaged 删除 .omo/debt/ 下的文件
if git status --short -- ".omo/debt/" | grep -q "^.D"; then
  echo "[debt-guard] ❌ .omo/debt/ 下有关联删除文件:" >&2
  git status --short -- ".omo/debt/" | grep "^.D" | sed 's/^/[debt-guard]   /' >&2
  echo "[debt-guard] ⛔ 拒绝提交 — 债务文件只能通过 omo debt CLI 管理" >&2
  exit 1
fi

exit 0
