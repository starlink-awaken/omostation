#!/bin/bash
# 治本 D: 主仓 push 前同步未推子模块, 防 CI 悬空.
#
# 病根: 自动化 agent (OMC/autopilot) commit 子模块 + bump 主仓指针却不 push
#   → 主仓 gitlink 指向子模块远程没有的 commit → CI `submodules: recursive`
#   拉不到 → "not our ref" → 整条 CI 红. (2026-06-17 实测 14/18 子模块悬空)
#
# 此钩子: 主仓 push(触发 CI)前, 把本地领先远程的子模块 push 上去, 让 gitlink 可达.
# 子模块 push 失败会阻断主仓 push,避免把不可达 gitlink 推到远端.
#
# Phase 2a (2026-06-30): direct-push-to-main advisory 守卫.
# Phase 2c (2026-07-01): 升级 blocking — push 目标含 refs/heads/main 且当前分支
#   非 work/* → exit 1 拒绝. 逼走 PR 流程 (worktree 隔离). 紧急绕过:
#     DIRECT_PUSH_MAIN_OK=1 git push ...   (跳 blocking, sync/reachability 仍跑)
#     git push --no-verify                  (git 原生, 绕整个 hook, 自担 gitlink 悬空风险)
#   详见 docs/AGENT-ISOLATION-ROLLOUT.md §4 Phase 2 (ISC-3b).
#
# 安装: make install-hooks  (从本文件复制到 .git/hooks/pre-push)
# 新 clone 必跑: make install-hooks

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

# ── 读 pre-push stdin (push ref 列表), 供 advisory 守卫 ──────────
# stdin 格式每行: <local-ref> <local-sha> <remote-ref> <remote-sha>
PUSH_REFS=""
while read -r _lref _lsha _rref _rsha; do
  PUSH_REFS="${PUSH_REFS}${_rref}
"
done

# ── Phase 2c: direct-push-to-main blocking 守卫 ─────────────────
# push 目标含 refs/heads/main 且当前分支非 work/* → exit 1 拒绝.
# 逼走 PR 流程. 紧急绕过: DIRECT_PUSH_MAIN_OK=1 (跳 blocking, sync/reachability 仍跑).
# { ... } || true 兜底: 守卫内部非 exit 的命令出错不阻断 (只让显式 exit 1 生效).
{
  CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
  if printf '%s\n' "$PUSH_REFS" | grep -qE 'refs/heads/main'; then
    if [ -z "$CURRENT_BRANCH" ] || ! printf '%s' "$CURRENT_BRANCH" | grep -qE '^work/'; then
      if [ "${DIRECT_PUSH_MAIN_OK:-}" = "1" ]; then
        cat >&2 <<EOF
[2c-block] ⚠️ DIRECT_PUSH_MAIN_OK=1 放行 direct push to main (分支: ${CURRENT_BRANCH:-detached})
   仅紧急热补丁用. 日常变更走 PR:
     bash bin/gac-worktree.sh claim <session> && ... && bash bin/gac-worktree.sh submit <session>
EOF
      else
        cat >&2 <<EOF
[2c-block] ❌ 拒绝 direct push to main (分支: ${CURRENT_BRANCH:-detached})
   Phase 2c: main 变更必须走 PR 流程 (worktree 隔离). 改用:
     bash bin/gac-worktree.sh claim <session>   # 起隔离 worktree
     # ... 改文件, commit ...
     bash bin/gac-worktree.sh submit <session>   # push 分支 + 开 PR
     bash bin/gac-worktree.sh merge <session>    # squash 合并 + release
   紧急热补丁: DIRECT_PUSH_MAIN_OK=1 git push ...
EOF
        exit 1
      fi
    fi
  fi
} || true

# ── 治本 D: sync 子模块, 防 gitlink 悬空 ─────────────────────────
# sync 子模块, 结果显示到 stderr; 失败即阻断 push.
"$ROOT/bin/sync-submodules-push.sh" 2>&1 | sed 's/^/[pre-push] /' >&2
python3 "$ROOT/bin/submodule-reachability-gate.py" --source head --fetch 2>&1 | sed 's/^/[reachability] /' >&2
exit 0
