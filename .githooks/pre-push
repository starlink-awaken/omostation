#!/bin/bash
# 治本 D: 主仓 push 前同步未推子模块, 防 CI 悬空.
#
# 病根: 自动化 agent (OMC/autopilot) commit 子模块 + bump 主仓指针却不 push
#   → 主仓 gitlink 指向子模块远程没有的 commit → CI `submodules: recursive`
#   拉不到 → "not our ref" → 整条 CI 红. (2026-06-17 实测 14/18 子模块悬空)
#
# 此钩子: 主仓 push(触发 CI)前, 把本地领先远程的子模块 push 上去, 让 gitlink 可达.
# 子模块 push 失败会阻断主仓 push,避免把不可达 gitlink 推到远端.
#
# direct-push-to-main 守卫历程:
#   2a (2026-06-30): advisory (警告不阻断)
#   2c (2026-07-01, commit 893f2332): 升级 blocking (exit 1)
#   路径A第1步 (2026-07-01): 回退 advisory — 2c 意外生效但 auto-PR 通道未建,
#     escape hatch 滥用废 blocking (半吊子). 第4步 (auto-PR通+并发agent切PR) 恢复 blocking.
# 当前: blocking (实测 2026-07-04: git push --dry-run origin main → [blocking] exit 1; work/* 放行).
#   注: 此行曾滞后写成 advisory (路径A第1步回退叙事), 但实际代码 (第34-54行 Phase 2c blocking) 一直是 active,
#   以 `git push --dry-run origin main` 实测为准, 勿信旧注释.
# 详见 docs/AGENT-ISOLATION-ROLLOUT.md §4 Phase 2 (ISC-3b) + docs/AUTO-PR-REVIEW-ISA.md.
#
# 安装: make install-hooks  (从本文件复制到 .git/hooks/pre-push)
# 新 clone 必跑: make install-hooks

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

# ── 读 pre-push stdin (push ref 列表), 供 advisory 守卫 ──────────
# stdin 格式每行: <local-ref> <local-sha> <remote-ref> <remote-sha>
PUSH_REFS=""
while read -r _lref _lsha _rref _rsha; do
  PUSH_REFS="${PUSH_REFS}${_rref}
"
done

# ── direct-push-to-main 守卫 (Phase 2c: blocking) ───────────────────────────
# push 目标含 refs/heads/main 且当前分支非 work/* 或 pr/* → 物理阻断 (exit 1)
# 强制所有 Agent 并行开发必须走 per-session worktree + PR 合流。
# 绕过拦截: 紧急情况下可使用 git push --no-verify 自担风险。
{
  CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
  if printf '%s\n' "$PUSH_REFS" | grep -qE 'refs/heads/main'; then
    if [ -z "$CURRENT_BRANCH" ] || ! printf '%s' "$CURRENT_BRANCH" | grep -qE '^work/|^pr/'; then
      cat >&2 <<EOF
[blocking] ❌ 拒绝直接 Push 至 main 分支 (当前分支: ${CURRENT_BRANCH:-detached})
   原因: 大仓已全面落地 SGF-v1 隔离工作区策略 (Phase 2c)。
   建议: 请使用隔离分支或 pr 分支开发，并开 PR 合流。
   步骤:
     1. 起 worktree:  bash bin/gac-worktree.sh claim <session>
     2. 提交分支:     bash bin/gac-worktree.sh submit <session>
     3. 强制合流:     bash bin/gac-worktree.sh merge <session>
EOF
      exit 1
    fi
  fi
}

# ── 治本 D: sync 子模块, 防 gitlink 悬空 ─────────────────────────
# SSOT paths live under bin/ssot/ (bin rationalization). Prefer ssot/,
# fall back to bin/ wrappers for older checkouts.
# sync 子模块, 结果显示到 stderr; 失败即阻断 push.
SYNC_SCRIPT="$ROOT/bin/ssot/sync-submodules-push.sh"
if [ ! -f "$SYNC_SCRIPT" ]; then
  SYNC_SCRIPT="$ROOT/bin/sync-submodules-push.sh"
fi
REACH_SCRIPT="$ROOT/bin/ssot/submodule-reachability-gate.py"
if [ ! -f "$REACH_SCRIPT" ]; then
  REACH_SCRIPT="$ROOT/bin/submodule-reachability-gate.py"
fi
if [ ! -f "$SYNC_SCRIPT" ]; then
  echo "[pre-push] ❌ missing sync-submodules-push.sh (expected bin/ssot/ or bin/)" >&2
  exit 1
fi
"$SYNC_SCRIPT" 2>&1 | sed 's/^/[pre-push] /' >&2
python3 "$REACH_SCRIPT" --source head --fetch 2>&1 | sed 's/^/[reachability] /' >&2

# ── G-CONV.7 / ADR-0220 D4: escape-hatch allowlist for CI_LOCAL_SKIP ─
# CI_LOCAL_SKIP=1 requires SWARM_ESCAPE_ID matching registry allowlist.
if [ "${CI_LOCAL_SKIP:-}" = "1" ]; then
  if [ -f "$ROOT/bin/gac/swarm-discipline-cli.py" ]; then
    _esc_out="$(python3 "$ROOT/bin/gac/swarm-discipline-cli.py" escape-check --flag ci_local_skip 2>&1)" || _esc_rc=$?
    _esc_rc="${_esc_rc:-0}"
    printf '%s\n' "$_esc_out" | sed 's/^/[swarm-d4] /' >&2
    if [ "$_esc_rc" -ne 0 ]; then
      cat >&2 <<EOF
[swarm-d4] ❌ CI_LOCAL_SKIP=1 blocked (G-CONV.7 / ADR-0220 D4)
   需要: SWARM_ESCAPE_ID=<id> 且 id 在 .omo/_truth/registry/swarm-coordination.yaml
   例:   SWARM_ESCAPE_ID=submodule-reachability-partial-worktree CI_LOCAL_SKIP=1 git push ...
   注: git push --no-verify 会跳过本 hook 整体; 滥用会被观测窗计为 escape_hatch_abuse
       (用 bin/gac/swarm-discipline-cli.py escape-check --flag no_verify_push 自检/登记).
EOF
      exit 1
    fi
  fi
fi

# ── ci-local-fast: 本地 CI 预检 (~5s) ────────────────────────────
# GaC gate + ruff + YAML 语法. 拦 90% CI 失败, 省等 CI 时间.
# 绕过: git push --no-verify (跳整个 hook, 自担风险 — D4 观测)
#       CI_LOCAL_SKIP=1 + SWARM_ESCAPE_ID=...  (登记豁免后跳预检)
if [ "${CI_LOCAL_SKIP:-}" != "1" ]; then
  if [ -f "$ROOT/Makefile" ]; then
    make -C "$ROOT" ci-local-fast 2>&1 | sed 's/^/[ci-local] /' >&2 || {
      cat >&2 <<EOF
[ci-local] ❌ 本地 CI 预检未通过. 修复后重试, 或:
  SWARM_ESCAPE_ID=<allowlisted-id> CI_LOCAL_SKIP=1 git push ...
  git push --no-verify           (跳整个 hook, 不推荐; 计入 G-CONV.7 观测)
EOF
      exit 1
    }
  fi
fi

exit 0
