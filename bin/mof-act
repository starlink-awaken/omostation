#!/usr/bin/env python3
"""MOF 自主行动引擎 — Phase 4: 规划→验证→执行→验证→记录"""

import subprocess
import sys
from datetime import datetime
from pathlib import Path

import yaml

M1_DIR = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m1"
PROJECTS_DIR = Path(__file__).parent.parent / "projects"
VERSION_FILE = Path(__file__).parent.parent / ".omo/_truth/mof-version.yaml"


def load_all_m1() -> list[dict]:
    nodes = []
    for yaml_file in M1_DIR.rglob("*.yaml"):
        if yaml_file.name.startswith("_"):
            continue
        try:
            data = yaml.safe_load(yaml_file.read_text())
            if isinstance(data, dict) and "id" in data:
                nodes.append(data)
        except Exception:
            pass
    return nodes


def plan_action(action_type: str, target: str) -> dict:
    """规划行动"""
    actions = {
        "fix_test": {
            "description": f"修复 {target} 测试失败",
            "steps": ["运行测试", "分析失败原因", "修复代码", "重新测试"],
            "validation": "mof-enforce post-check",
        },
        "reduce_drift": {
            "description": f"减少 {target} 架构漂移",
            "steps": ["识别漂移类型", "规划修复方案", "执行修复", "验证结果"],
            "validation": "mof-drift",
        },
        "improve_coverage": {
            "description": f"提升 {target} 测试覆盖率",
            "steps": ["分析低覆盖率区域", "编写测试", "运行测试", "验证覆盖率"],
            "validation": "mof-analyze testing",
        },
        "reduce_debt": {
            "description": f"减少 {target} 技术债务",
            "steps": ["分析债务类型", "规划清理方案", "执行清理", "验证结果"],
            "validation": "mof-scan",
        },
    }
    
    action = actions.get(action_type, {
        "description": f"执行 {action_type} on {target}",
        "steps": ["分析", "规划", "执行", "验证"],
        "validation": "mof-enforce post-check",
    })
    
    return {
        "action_type": action_type,
        "target": target,
        "plan": action,
        "timestamp": datetime.now().isoformat(),
    }


def validate_action(action_plan: dict) -> dict:
    """验证行动合法性"""
    # Check if target exists in MOF model
    nodes = load_all_m1()
    target = action_plan.get("target", "")
    
    target_exists = False
    for n in nodes:
        if n.get("id") == target or n.get("project") == target:
            target_exists = True
            break
    
    if not target_exists:
        return {
            "valid": False,
            "reason": f"Target {target} not found in MOF model",
        }
    
    return {
        "valid": True,
        "reason": "Action validated against MOF model",
    }


def execute_action(action_plan: dict) -> dict:
    """执行行动"""
    action_type = action_plan.get("action_type", "")
    target = action_plan.get("target", "")
    
    # For now, simulate execution
    # In real implementation, this would call actual tools
    return {
        "executed": True,
        "action_type": action_type,
        "target": target,
        "timestamp": datetime.now().isoformat(),
        "result": "Action executed (simulated)",
    }


def verify_result(action_plan: dict, execution_result: dict) -> dict:
    """验证行动结果"""
    # Run post-check
    try:
        result = subprocess.run(
            ["bin/mof-enforce", "post-check"],
            capture_output=True, text=True, timeout=120
        )
        validation_passed = result.returncode == 0
    except Exception:
        validation_passed = False
    
    return {
        "verified": validation_passed,
        "validation_output": result.stdout if validation_passed else result.stderr,
    }


def record_change(action_plan: dict, verification_result: dict) -> dict:
    """记录变更"""
    version_data = {"version": "0.0.0", "history": []}
    if VERSION_FILE.exists():
        version_data = yaml.safe_load(VERSION_FILE.read_text())
    
    parts = version_data["version"].split(".")
    parts[2] = str(int(parts[2]) + 1)
    new_version = ".".join(parts)
    
    version_data["history"].append({
        "version": new_version,
        "timestamp": datetime.now().isoformat(),
        "description": f"Action: {action_plan.get('plan', {}).get('description', '')}",
        "verified": verification_result.get("verified", False),
    })
    version_data["version"] = new_version
    
    VERSION_FILE.parent.mkdir(parents=True, exist_ok=True)
    VERSION_FILE.write_text(yaml.dump(version_data, allow_unicode=True, default_flow_style=False))
    
    return {
        "version": new_version,
        "recorded": True,
    }


def main():
    if len(sys.argv) < 3:
        print("Usage: mof-act <action_type> <target>")
        print("Actions: fix_test, reduce_drift, improve_coverage, reduce_debt")
        sys.exit(1)
    
    action_type = sys.argv[1]
    target = sys.argv[2]
    
    print(f"=== MOF Autonomous Action: {action_type} on {target} ===\n")
    
    # Step 1: Plan
    print("Step 1: Planning...")
    action_plan = plan_action(action_type, target)
    print(f"  Plan: {action_plan['plan']['description']}")
    print(f"  Steps: {', '.join(action_plan['plan']['steps'])}")
    print()
    
    # Step 2: Validate
    print("Step 2: Validating...")
    validation = validate_action(action_plan)
    print(f"  Valid: {validation['valid']}")
    print(f"  Reason: {validation['reason']}")
    print()
    
    if not validation["valid"]:
        print("❌ Action validation failed. Aborting.")
        sys.exit(1)
    
    # Step 3: Execute
    print("Step 3: Executing...")
    execution = execute_action(action_plan)
    print(f"  Result: {execution['result']}")
    print()
    
    # Step 4: Verify
    print("Step 4: Verifying...")
    verification = verify_result(action_plan, execution)
    print(f"  Verified: {verification['verified']}")
    print()
    
    # Step 5: Record
    print("Step 5: Recording...")
    record = record_change(action_plan, verification)
    print(f"  Version: v{record['version']}")
    print()
    
    print("=== Action Complete ===")


if __name__ == "__main__":
    main()
