#!/usr/bin/env python3
# Status: implemented (P47 R1: MOF 决策支持 — 多视角推理)
"""MOF 智能决策支持 — 回答"要不要做 X" """

import sys
from pathlib import Path

import yaml

M1_DIR = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m1"


def load_all_m1() -> list[dict]:
    nodes = []
    for yaml_file in M1_DIR.rglob("*.yaml"):
        if yaml_file.name.startswith("_"):
            continue
        try:
            data = yaml.safe_load(yaml_file.read_text())
            if isinstance(data, dict) and "id" in data:
                nodes.append(data)
        except Exception:
            pass
    return nodes


def decide_impact(node_id: str) -> dict:
    """推导变更影响"""
    nodes = load_all_m1()
    
    # Find the node
    target = None
    for n in nodes:
        if n.get("id") == node_id or n.get("project") == node_id:
            target = n
            break
    
    if not target:
        return {"error": f"Node {node_id} not found"}
    
    # Find dependents
    dependents = []
    for n in nodes:
        relations = n.get("relations", {})
        depends_on = relations.get("depends_on", []) if isinstance(relations, dict) else []
        if node_id in depends_on or target.get("project") in depends_on:
            dependents.append(n.get("name", n.get("id", "")))
    
    # Find services
    services = []
    for n in nodes:
        if n.get("project") == target.get("project") and n.get("type") == "Service":
            services.append(n.get("name", n.get("id", "")))
    
    return {
        "affected_components": dependents,
        "affected_services": services,
        "risk_level": "high" if len(dependents) > 3 else "medium" if len(dependents) > 1 else "low",
    }


def decide_cost(node_id: str) -> dict:
    """推导成本"""
    nodes = load_all_m1()
    
    for n in nodes:
        if n.get("id") == node_id or n.get("project") == node_id:
            value = n.get("value_metrics", {})
            cost = n.get("cost_model", {})
            return {
                "business_value": value.get("business_value", "unknown"),
                "strategic_importance": value.get("strategic_importance", "unknown"),
                "maintenance_cost": value.get("maintenance_cost", "unknown"),
                "operational_cost": cost.get("operational", "unknown"),
            }
    
    return {"error": "Node not found"}


def decide_benefit(node_id: str) -> dict:
    """推导收益"""
    nodes = load_all_m1()
    
    for n in nodes:
        if n.get("id") == node_id or n.get("project") == node_id:
            value = n.get("value_metrics", {})
            return {
                "business_value": value.get("business_value", "unknown"),
                "technical_debt": value.get("technical_debt", "unknown"),
                "strategic_importance": value.get("strategic_importance", "unknown"),
            }
    
    return {"error": "Node not found"}


def decide(node_id: str) -> dict:
    """综合决策"""
    impact = decide_impact(node_id)
    cost = decide_cost(node_id)
    benefit = decide_benefit(node_id)
    
    # 综合评估
    risk = impact.get("risk_level", "unknown")
    value = benefit.get("strategic_importance", "unknown")
    
    if risk == "high" and value == "critical":
        recommendation = "谨慎执行 — 高风险高价值，需要详细计划"
    elif risk == "high":
        recommendation = "不建议 — 高风险低价值"
    elif value == "critical":
        recommendation = "建议执行 — 低风险高价值"
    elif value == "high":
        recommendation = "可选执行 — 评估 ROI 后决定"
    else:
        recommendation = "低优先级 — 可延后"
    
    return {
        "node": node_id,
        "impact": impact,
        "cost": cost,
        "benefit": benefit,
        "recommendation": recommendation,
    }


def main():
    if len(sys.argv) < 2:
        print("Usage: mof-decide <node_id>")
        print("Example: mof-decide COMP-WS-agora")
        sys.exit(1)
    
    node_id = sys.argv[1]
    
    result = decide(node_id)
    
    if "error" in result:
        print(f"Error: {result['error']}")
        sys.exit(1)
    
    print(f"=== MOF Decision Support: {node_id} ===\n")
    
    print("Impact:")
    for c in result["impact"].get("affected_components", []):
        print(f"  → {c}")
    for s in result["impact"].get("affected_services", []):
        print(f"  → Service: {s}")
    print(f"  Risk level: {result['impact'].get('risk_level', 'unknown')}")
    print()
    
    print("Cost:")
    for k, v in result["cost"].items():
        print(f"  {k}: {v}")
    print()
    
    print("Benefit:")
    for k, v in result["benefit"].items():
        print(f"  {k}: {v}")
    print()
    
    print(f"Recommendation: {result['recommendation']}")


if __name__ == "__main__":
    main()
