#!/usr/bin/env python3
# Status: planned (P45 审计: 0 引用, 等 P46+ 实现)
"""MOF 自主决策引擎 — Phase 3: 异常检测→推理→建议"""

import subprocess
import sys
from pathlib import Path

import yaml

M1_DIR = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m1"
PROJECTS_DIR = Path(__file__).parent.parent / "projects"


def load_all_m1() -> list[dict]:
    nodes = []
    for yaml_file in M1_DIR.rglob("*.yaml"):
        if yaml_file.name.startswith("_"):
            continue
        try:
            data = yaml.safe_load(yaml_file.read_text())
            if isinstance(data, dict) and "id" in data:
                nodes.append(data)
        except Exception:
            pass
    return nodes


def detect_anomalies() -> list[dict]:
    """检测系统异常"""
    anomalies = []
    
    # 1. 检测测试失败
    for proj in ["agora", "cockpit", "runtime", "omo", "metaos", "ecos", "l4-kernel", "kairon"]:
        project_dir = PROJECTS_DIR / proj
        if not project_dir.exists():
            continue
        try:
            result = subprocess.run(
                ["uv", "run", "pytest", "tests/", "-x", "-q", "--tb=no"],
                capture_output=True, text=True, timeout=60,
                cwd=str(project_dir)
            )
            if result.returncode != 0:
                anomalies.append({
                    "type": "test_failure",
                    "project": proj,
                    "severity": "high",
                    "message": f"Tests failing in {proj}",
                    "details": result.stdout[-200:] if result.stdout else "",
                })
        except subprocess.TimeoutExpired:
            pass
        except Exception:
            pass
    
    # 2. 检测架构漂移
    for proj in ["agora", "cockpit", "runtime", "omo"]:
        project_dir = PROJECTS_DIR / proj / "src"
        if not project_dir.exists():
            continue
        try:
            result = subprocess.run(
                ["grep", "-r", "sys.path.insert", str(project_dir), "--include=*.py"],
                capture_output=True, text=True, timeout=30
            )
            if result.stdout.strip():
                count = len(result.stdout.strip().split("\n"))
                if count > 0:
                    anomalies.append({
                        "type": "architecture_drift",
                        "project": proj,
                        "severity": "medium",
                        "message": f"{count} sys.path.insert found in {proj}",
                    })
        except Exception:
            pass
    
    # 3. 检测 debt 积累
    nodes = load_all_m1()
    for n in nodes:
        if n.get("type") == "Component":
            value = n.get("value_metrics", {})
            if value.get("technical_debt") == "high":
                anomalies.append({
                    "type": "debt_accumulation",
                    "project": n.get("project", ""),
                    "severity": "medium",
                    "message": f"High technical debt in {n.get('name', '')}",
                })
    
    return anomalies


def reason_impact(anomaly: dict) -> dict:
    """推理异常影响"""
    nodes = load_all_m1()
    project = anomaly.get("project", "")
    
    # Find project node
    project_node = None
    for n in nodes:
        if n.get("id") == f"COMP-WS-{project}" or n.get("project") == project:
            project_node = n
            break
    
    if not project_node:
        return {"impact": "unknown"}
    
    # Find dependents
    dependents = []
    for n in nodes:
        relations = n.get("relations", {})
        depends_on = relations.get("depends_on", []) if isinstance(relations, dict) else []
        if project in depends_on:
            dependents.append(n.get("name", n.get("id", "")))
    
    return {
        "affected_components": dependents,
        "affected_services": [n.get("name", "") for n in nodes 
                             if n.get("type") == "Service" and n.get("project") == project],
        "risk_level": "high" if len(dependents) > 3 else "medium" if len(dependents) > 1 else "low",
    }


def evaluate_decision(anomaly: dict, impact: dict) -> dict:
    """评估决策"""
    severity = anomaly.get("severity", "medium")
    risk = impact.get("risk_level", "low")
    
    if severity == "high" and risk == "high":
        recommendation = "立即修复 — 高风险高影响"
        priority = "P0"
    elif severity == "high":
        recommendation = "尽快修复 — 高风险"
        priority = "P1"
    elif risk == "high":
        recommendation = "评估后修复 — 高影响"
        priority = "P2"
    else:
        recommendation = "可延后修复"
        priority = "P3"
    
    return {
        "recommendation": recommendation,
        "priority": priority,
        "anomaly": anomaly,
        "impact": impact,
    }


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "detect":
        anomalies = detect_anomalies()
        if not anomalies:
            print("✅ No anomalies detected.")
        else:
            print(f"=== Detected {len(anomalies)} anomalies ===\n")
            for a in anomalies:
                print(f"[{a['severity'].upper()}] {a['project']}: {a['message']}")
    
    elif len(sys.argv) > 1 and sys.argv[1] == "decide":
        anomalies = detect_anomalies()
        if not anomalies:
            print("✅ No anomalies to decide on.")
            return
        
        print(f"=== Autonomous Decision: {len(anomalies)} anomalies ===\n")
        for a in anomalies:
            impact = reason_impact(a)
            decision = evaluate_decision(a, impact)
            
            print(f"[{decision['priority']}] {a['project']}: {a['message']}")
            print(f"  Impact: {len(impact.get('affected_components', []))} components affected")
            print(f"  Risk: {impact.get('risk_level', 'unknown')}")
            print(f"  Recommendation: {decision['recommendation']}")
            print()
    
    else:
        print("Usage: mof-autonomous <command>")
        print("Commands: detect, decide")
        sys.exit(1)


if __name__ == "__main__":
    main()
