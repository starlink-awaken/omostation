#!/usr/bin/env python3
"""MOF 团队任务分配 — 基于模型数据做团队任务分配"""

import sys
from pathlib import Path

import yaml

M1_DIR = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m1"


def load_all_m1() -> list[dict]:
    """加载所有 M1 节点"""
    nodes = []
    for yaml_file in M1_DIR.rglob("*.yaml"):
        if yaml_file.name.startswith("_"):
            continue
        try:
            data = yaml.safe_load(yaml_file.read_text())
            if isinstance(data, dict) and "id" in data:
                nodes.append(data)
        except Exception:
            pass
    return nodes


def analyze_domain(domain_name: str) -> dict:
    """分析某个域的任务分配"""
    nodes = load_all_m1()
    
    # Find all nodes for this domain
    domain_nodes = []
    for n in nodes:
        project = n.get("project", "")
        if project == domain_name:
            domain_nodes.append(n)
    
    # Categorize
    components = [n for n in domain_nodes if n.get("type") == "Component"]
    services = [n for n in domain_nodes if n.get("type") == "Service"]
    mcptools = [n for n in domain_nodes if n.get("type") == "MCPTool"]
    processes = [n for n in domain_nodes if n.get("type") == "Process"]
    
    # Calculate value
    total_value = {"high": 0, "medium": 0, "low": 0}
    for n in domain_nodes:
        value = n.get("value_metrics", {}).get("strategic_importance", "unknown")
        if value in total_value:
            total_value[value] += 1
    
    # Calculate cost
    total_cost = {"low": 0, "medium": 0, "high": 0}
    for n in domain_nodes:
        cost = n.get("cost_model", {}).get("operational", "unknown")
        if cost in total_cost:
            total_cost[cost] += 1
    
    return {
        "domain": domain_name,
        "components": len(components),
        "services": len(services),
        "mcptools": len(mcptools),
        "processes": len(processes),
        "total_nodes": len(domain_nodes),
        "value_distribution": total_value,
        "cost_distribution": total_cost,
    }


def suggest_priority(analysis: dict) -> list[str]:
    """基于分析结果建议优先级"""
    suggestions = []
    
    if analysis["services"] > 0:
        suggestions.append(f"优先维护 {analysis['services']} 个服务的健康状态")
    
    if analysis["mcptools"] > 0:
        suggestions.append(f"确保 {analysis['mcptools']} 个 MCP 工具的测试覆盖")
    
    if analysis["value_distribution"].get("high", 0) > 0:
        suggestions.append(f"高价值组件 ({analysis['value_distribution']['high']} 个) 需要重点保护")
    
    if analysis["cost_distribution"].get("high", 0) > 0:
        suggestions.append(f"高成本组件 ({analysis['cost_distribution']['high']} 个) 需要优化")
    
    return suggestions


def main():
    if len(sys.argv) < 2:
        print("Usage: mof-assign <domain>")
        print("Example: mof-assign cockpit")
        sys.exit(1)
    
    domain = sys.argv[1]
    
    print(f"=== MOF Team Assignment: {domain} ===\n")
    
    analysis = analyze_domain(domain)
    
    print(f"Domain: {analysis['domain']}")
    print(f"Total nodes: {analysis['total_nodes']}")
    print(f"Components: {analysis['components']}")
    print(f"Services: {analysis['services']}")
    print(f"MCP Tools: {analysis['mcptools']}")
    print(f"Processes: {analysis['processes']}")
    print()
    
    print("Value Distribution:")
    for k, v in analysis["value_distribution"].items():
        if v > 0:
            print(f"  {k}: {v}")
    print()
    
    print("Cost Distribution:")
    for k, v in analysis["cost_distribution"].items():
        if v > 0:
            print(f"  {k}: {v}")
    print()
    
    suggestions = suggest_priority(analysis)
    if suggestions:
        print("Priority Suggestions:")
        for s in suggestions:
            print(f"  → {s}")
    print()


if __name__ == "__main__":
    main()
