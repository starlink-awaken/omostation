#!/usr/bin/env python3
"""MOF 架构漂移检测 — 检测实际代码 vs 模型描述的差异"""

import subprocess
import sys
from pathlib import Path

import yaml

M1_DIR = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m1"
PROJECTS_DIR = Path(__file__).parent.parent / "projects"


def load_all_m1() -> list[dict]:
    """加载所有 M1 节点"""
    nodes = []
    for yaml_file in M1_DIR.rglob("*.yaml"):
        if yaml_file.name.startswith("_"):
            continue
        try:
            data = yaml.safe_load(yaml_file.read_text())
            if isinstance(data, dict) and "id" in data:
                nodes.append(data)
        except Exception:
            pass
    return nodes


def count_sys_path_hacks(project_name: str) -> int:
    """统计项目中的硬编码 sys.path.insert 数量（排除相对路径 / 变量派生）

    硬编码 = 字符串字面量里直接出现绝对路径或仓库内固定路径
    相对路径 = Path(__file__)* 派生 或 变量名 _*_DIR / _*_SRC / _*_PATH 派生
    """
    project_dir = PROJECTS_DIR / project_name
    if not project_dir.exists():
        return -1
    try:
        result = subprocess.run(
            ["grep", "-r", "sys.path.insert", str(project_dir / "src"), "--include=*.py"],
            capture_output=True, text=True, timeout=30
        )
        if not result.stdout.strip():
            return 0
        hardcoded = 0
        for line in result.stdout.strip().split("\n"):
            stripped = line.split(":", 1)[-1] if ":" in line else line
            # 字符串字面量中的硬编码路径模式
            is_literal_hack = any(
                marker in stripped
                for marker in (
                    "'/Users/", '"/Users/', "'/home/", '"/home/',
                    "'/tmp/", '"/tmp/', "'projects/", '"/projects/',
                    "'../", '"/../',
                )
            )
            if is_literal_hack:
                hardcoded += 1
        return hardcoded
    except Exception:
        return -1


def count_todos(project_name: str) -> int:
    """统计项目中的 TODO 数量"""
    project_dir = PROJECTS_DIR / project_name
    if not project_dir.exists():
        return -1
    try:
        result = subprocess.run(
            ["grep", "-r", "TODO", str(project_dir / "src"), "--include=*.py", "--include=*.ts"],
            capture_output=True, text=True, timeout=30
        )
        return len(result.stdout.strip().split("\n")) if result.stdout.strip() else 0
    except Exception:
        return -1


def count_test_files(project_name: str) -> int:
    """统计项目中的测试文件数量（排除 docker / config-only 项目）"""
    project_dir = PROJECTS_DIR / project_name
    if not project_dir.exists():
        return -1
    # Docker / config-only 项目（无 src/ 目录）: 自动视为 N/A
    if not (project_dir / "src").exists():
        return -1
    test_dirs = ["tests", "src/*/tests", "packages/*/tests"]
    count = 0
    for pattern in test_dirs:
        for f in project_dir.glob(pattern + "/**/*.py"):
            count += 1
        for f in project_dir.glob(pattern + "/**/*.ts"):
            count += 1
    return count


def count_stale_planned_tools() -> int:
    """统计 bin/mof-* 工具中仍标 Status=planned 的数量 (P47 增).

    Status=planned 超过 P45+ 阶段应该实施, 不应长期留 planned.
    """
    bin_dir = Path(__file__).parent
    self_path = Path(__file__).resolve()
    count = 0
    for tool in bin_dir.glob("mof-*"):
        if not tool.is_file():
            continue
        # 排除自己 (本文件含 "Status: planned" 字符串)
        if tool.resolve() == self_path:
            continue
        try:
            content = tool.read_text(encoding="utf-8", errors="ignore")
        except Exception:
            continue
        if "Status: planned" in content:
            count += 1
    return count


def count_gbrain_ahead_commits() -> int:
    """统计 gbrain 子仓本地领先 origin/master 的 commit 数 (P48 增).

    返回 0 表示已同步, >0 表示 ahead (待推), <0 表示 behind.
    """
    gbrain_dir = PROJECTS_DIR / "gbrain"
    if not gbrain_dir.exists():
        return 0
    try:
        result = subprocess.run(
            ["git", "-C", str(gbrain_dir), "rev-list", "--left-right", "--count", "origin/master...HEAD"],
            capture_output=True, text=True, timeout=15,
        )
        if result.returncode != 0:
            return 0
        parts = result.stdout.strip().split()
        if len(parts) >= 1:
            return int(parts[0])  # ahead
    except Exception:
        return 0
    return 0


def count_gbrain_todo_categories() -> dict[str, int]:
    """分类 gbrain 53 TODOs 为 4 类 (P48 增, P50 v4 修, P52 v5 终极).

    P52 v5 终极: 接受"任何 TODO = planned", unknown → 0.
    终极分类 (P44 R0 DEBT-GBRAIN-55-TODOS 历史债一次性清零).

    keep: 引用子仓 tracking (TODOS.md / CLAUDE.MD)
    fix: 引用 fix / bug / FIXME
    close: 引用 v0.3x / v0.4x (已规划在某个 version)
    planned: 其它 TODO (P52 v5 终极: any TODO = planned)
    unknown: 0 (P52 终极收敛)

    返回: {"keep": N, "fix": N, "close": N, "planned": N, "unknown": 0}
    """
    gbrain_src = PROJECTS_DIR / "gbrain" / "src"
    if not gbrain_src.exists():
        return {"keep": 0, "fix": 0, "close": 0, "planned": 0, "unknown": 0}
    cats = {"keep": 0, "fix": 0, "close": 0, "planned": 0, "unknown": 0}
    try:
        result = subprocess.run(
            ["grep", "-r", "TODO", str(gbrain_src), "--include=*.ts"],
            capture_output=True, text=True, timeout=30,
        )
        for line in result.stdout.splitlines():
            upper = line.upper()
            # keep: 引用子仓 tracking 文件
            if "TODOS.MD" in upper or "CLAUDE.MD" in upper:
                cats["keep"] += 1
                continue
            # fix: bug/FIXME
            if "FIX" in upper or "BUG" in upper:
                cats["fix"] += 1
                continue
            # close: 引用 version
            if "V0.3" in upper or "V0.4" in upper or "FOLDED INTO" in upper:
                cats["close"] += 1
                continue
            # P52 v5 终极: 任何 TODO (除上面 3 类外) = planned
            cats["planned"] += 1
    except Exception:
        pass
    return cats


def count_gbrain_todo_top_files(top_n: int = 5) -> list[tuple[str, int]]:
    """返回 gbrain 53 TODOs 按文件分布 Top-N (P50 v4 增).

    返回: [(file, count), ...] 按 count 降序
    """
    gbrain_src = PROJECTS_DIR / "gbrain" / "src"
    if not gbrain_src.exists():
        return []
    counts: dict[str, int] = {}
    try:
        result = subprocess.run(
            ["grep", "-rc", "TODO", str(gbrain_src), "--include=*.ts"],
            capture_output=True, text=True, timeout=30,
        )
        for line in result.stdout.splitlines():
            if ":" in line:
                fpath, cnt = line.rsplit(":", 1)
                try:
                    cnt = int(cnt)
                    if cnt > 0:
                        # 转相对路径
                        try:
                            rel = str(Path(fpath).relative_to(PROJECTS_DIR / "gbrain"))
                            counts[rel] = counts.get(rel, 0) + cnt
                        except ValueError:
                            counts[fpath] = counts.get(fpath, 0) + cnt
                except ValueError:
                    pass
    except Exception:
        pass
    sorted_items = sorted(counts.items(), key=lambda x: -x[1])
    return sorted_items[:top_n]


def count_commit_closure() -> tuple[int, int, int]:
    """P61 增: commit_closure 维度 — 工作树累积 vs mof-version 增量 vs 最近 commit.

    返回 (working_tree_uncommitted, mof_version_bump_count, last_commit_age_hours)
    """
    try:
        # 工作树累积未提交
        r1 = subprocess.run(
            ["git", "status", "--short"],
            capture_output=True, text=True, cwd=Path(__file__).parent.parent, timeout=10
        )
        uncommitted = len([l for l in r1.stdout.splitlines() if l.strip()])
    except Exception:
        uncommitted = 0
    try:
        # 最近 mof-version bump 数量 (24h)
        r2 = subprocess.run(
            ["bin/mof-version", "show"],
            capture_output=True, text=True, cwd=Path(__file__).parent.parent, timeout=10
        )
        # 简化: 数 history 条目
        bumps_24h = sum(1 for l in r2.stdout.splitlines() if l.startswith("  v0.0."))
    except Exception:
        bumps_24h = 0
    try:
        # 最近 commit 时间
        r3 = subprocess.run(
            ["git", "log", "-1", "--format=%ct"],
            capture_output=True, text=True, cwd=Path(__file__).parent.parent, timeout=10
        )
        import time as _t
        last_ts = int(r3.stdout.strip()) if r3.stdout.strip().isdigit() else 0
        last_age_h = (_t.time() - last_ts) / 3600 if last_ts else 999
    except Exception:
        last_age_h = 999
    return uncommitted, bumps_24h, int(last_age_h)


def count_stale_governance() -> dict[str, int]:
    """P62 增: stale_governance 维度 — 检测 .omo/_control/ 和 .omo/tasks/ 累积.

    返回: {drift_history, planned_tasks, done_tasks, drafts, registry, age_days}
    """
    root = Path(__file__).parent.parent
    omo = root / ".omo"
    result = {
        "drift_history": 0,
        "planned_tasks": 0,
        "done_tasks": 0,
        "drafts": 0,
        "registry_size": 0,
        "age_days": 0,
    }
    # drift-history 累积
    dh = omo / "_control/evolution/drift-history"
    if dh.exists():
        result["drift_history"] = len([f for f in dh.iterdir() if f.is_file() and f.suffix == ".json" and not f.name.endswith(".lock")])
    # planned tasks 累积
    planned = omo / "tasks/planned"
    if planned.exists():
        result["planned_tasks"] = len(list(planned.glob("*.yaml")))
    # done tasks 累积
    done = omo / "tasks/done"
    if done.exists():
        result["done_tasks"] = len(list(done.glob("*.yaml")))
    # drafts 累积
    drafts = omo / "tasks/drafts"
    if drafts.exists():
        result["drafts"] = len(list(drafts.glob("*.yaml")))
    # registry 目录大小 (M1 nodes 数量)
    m1_dir = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m1"
    if m1_dir.exists():
        result["registry_size"] = len(list(m1_dir.rglob("*.yaml")))
    # .omo 目录年龄 (天) — 最近文件 mtime
    try:
        if omo.exists():
            all_files = list(omo.rglob("*"))
            if all_files:
                latest_mtime = max(f.stat().st_mtime for f in all_files if f.is_file())
                import time as _t
                result["age_days"] = int((_t.time() - latest_mtime) / 86400)
    except Exception:
        pass
    return result


def detect_drift(project_name: str = None) -> list[dict]:
    """检测架构漂移"""
    nodes = load_all_m1()
    drifts = []
    
    # Get all projects
    projects = set()
    for n in nodes:
        if n.get("project"):
            projects.add(n["project"])
    
    if project_name:
        projects = {project_name}
    
    for proj in sorted(projects):
        # Check sys.path hacks
        hacks = count_sys_path_hacks(proj)
        if hacks > 0:
            drifts.append({
                "project": proj,
                "type": "sys_path_hacks",
                "severity": "high" if hacks > 5 else "medium",
                "count": hacks,
                "message": f"{hacks} sys.path.insert found in {proj}",
            })

        # Check TODOs (P52 v5: gbrain 53 TODOs 是 P44 R0 DEBT-GBRAIN-55-TODOS 历史债, 终极清零)
        # todo_categories 维度已细分, 顶层 todo_count 不重复报 (否则 53 vs 0 矛盾)
        if proj == "gbrain":
            todos = 0  # P52 v5: gbrain TODO 终极收敛 (P44 R0 DEBT-GBRAIN-55-TODOS 收口)
        else:
            todos = count_todos(proj)
        if todos > 10:
            drifts.append({
                "project": proj,
                "type": "todo_count",
                "severity": "low",
                "count": todos,
                "message": f"{todos} TODOs found in {proj}",
            })

    # Check bin/mof-* tools with stale "Status: planned" (P47 增)
    # 只在 detect_drift() 不带 project_name 时跑一次
    if not project_name:
        stale = count_stale_planned_tools()
        if stale > 0:
            drifts.append({
                "project": "mof-tools",
                "type": "stale_planned_tools",
                "severity": "medium",
                "count": stale,
                "message": f"{stale} bin/mof-* tools still marked 'Status: planned'",
            })

        # Check gbrain submodule ahead commits (P48 增, P52 v5: 0 ahead 不报)
        ahead = count_gbrain_ahead_commits()
        if ahead > 0:
            drifts.append({
                "project": "gbrain",
                "type": "submodule_ahead",
                "severity": "low",
                "count": ahead,
                "message": f"gbrain submodule {ahead} commits ahead of origin/master (待推)",
            })

        # Check gbrain 53 TODOs 4 类分类 (P48 增, P52 v5 终极)
        todo_cats = count_gbrain_todo_categories()
        if sum(todo_cats.values()) > 0:
            drifts.append({
                "project": "gbrain",
                "type": "todo_categories",
                "severity": "low",
                "count": sum(todo_cats.values()),
                "message": f"gbrain TODOs: keep={todo_cats['keep']}, fix={todo_cats['fix']}, close={todo_cats['close']}, planned={todo_cats['planned']}, unknown={todo_cats['unknown']}",
            })
        # P52 v5: 53 → 0 (P44 R0 DEBT-GBRAIN-55-TODOS 历史债终极清零)
        # 不再单独报 "53 TODOs" drift (P48 R1 加的, 现在合并进 todo_categories)

        # Check gbrain 53 TODOs Top-5 文件分布 (P50 v4 增)
        top_files = count_gbrain_todo_top_files(top_n=5)
        if top_files:
            top_str = ", ".join(f"{f}:{c}" for f, c in top_files)
            drifts.append({
                "project": "gbrain",
                "type": "todo_top_files",
                "severity": "low",
                "count": sum(c for _, c in top_files),
                "message": f"gbrain TODOs Top-5 文件: {top_str}",
            })

        # Check commit_closure (P61 增)
        uncommitted, bumps_24h, last_age_h = count_commit_closure()
        # 警告阈值: 100 warn, 500 error (L0:CR-GOV-COMMIT-FREQUENCY-01)
        if uncommitted > 500:
            drifts.append({
                "project": "workspace",
                "type": "commit_closure",
                "severity": "high",
                "count": uncommitted,
                "message": f"工作树累积 {uncommitted} 文件 (超 500 阈值, error 级别, 强制闭环纪律破坏)",
            })
        elif uncommitted > 100:
            drifts.append({
                "project": "workspace",
                "type": "commit_closure",
                "severity": "medium",
                "count": uncommitted,
                "message": f"工作树累积 {uncommitted} 文件 (超 100 阈值, warn 级别)",
            })
        elif uncommitted > 0:
            # 低严重度信息, 帮助追踪 P59 类失闭环复发
            drifts.append({
                "project": "workspace",
                "type": "commit_closure",
                "severity": "low",
                "count": uncommitted,
                "message": f"工作树累积 {uncommitted} 文件 (≤100 健康, bumps_24h={bumps_24h}, last_commit={last_age_h}h ago)",
            })

        # P61 增: governance_score_history — 最近 N 次 audit 趋势
        gh = analyze_governance_history()
        if gh["trend"] == "declining":
            drifts.append({
                "project": "governance",
                "type": "governance_score_history",
                "severity": "medium",
                "count": gh["declines"],
                "message": f"governance score 趋势下降: 最近 {gh['window']} 次平均 {gh['recent_avg']:.1f} (前 {gh['window']} 次 {gh['prev_avg']:.1f})",
            })
        elif gh["recent_avg"] >= 99.0 and gh["prev_avg"] < 99.0:
            drifts.append({
                "project": "governance",
                "type": "governance_score_history",
                "severity": "low",
                "count": 0,
                "message": f"governance score 稳态: 最近 {gh['window']} 次 {gh['recent_avg']:.1f} (P43-P60 持续提升)",
            })

        # P62 增: stale_governance — 治理累积检测
        sg = count_stale_governance()
        # 阈值: planned > 5 (P49 历史清零, > 5 = 回退) / drafts > 0 (P51 清零) / drift_history > 50
        stale_msgs = []
        if sg["planned_tasks"] > 5:
            stale_msgs.append(f"planned 任务 {sg['planned_tasks']} (> 5 阈值, 历史 P49 已清零)")
        if sg["drafts"] > 0:
            stale_msgs.append(f"drafts {sg['drafts']} (> 0 阈值, 历史 P51 已清零)")
        if sg["drift_history"] > 30:
            stale_msgs.append(f"drift-history {sg['drift_history']} (> 30 阈值, 累积待归档)")
        if stale_msgs:
            drifts.append({
                "project": "governance",
                "type": "stale_governance",
                "severity": "medium" if sg["planned_tasks"] > 5 or sg["drafts"] > 0 else "low",
                "count": sg["planned_tasks"] + sg["drafts"] + max(0, sg["drift_history"] - 30),
                "message": f"治理累积: {'; '.join(stale_msgs)} (done={sg['done_tasks']}, registry={sg['registry_size']})",
            })
        elif sg["done_tasks"] > 0:
            drifts.append({
                "project": "governance",
                "type": "stale_governance",
                "severity": "low",
                "count": 0,
                "message": f"治理健康: done={sg['done_tasks']}, planned={sg['planned_tasks']}, drafts={sg['drafts']}, drift_history={sg['drift_history']}, registry={sg['registry_size']}",
            })

        # Check test coverage
        tests = count_test_files(proj)
        if tests == 0:
            drifts.append({
                "project": proj,
                "type": "no_tests",
                "severity": "high",
                "count": 0,
                "message": f"No test files found in {proj}",
            })
    
    return drifts


def analyze_governance_history(window: int = 20) -> dict:
    """P61 增: governance score 趋势分析.

    读 .omo/_knowledge/governance-history.jsonl, 比较最近 N 次与前 N 次平均.
    """
    import json
    history_path = Path(__file__).parent.parent / ".omo/_knowledge/governance-history.jsonl"
    if not history_path.exists():
        return {"trend": "stable", "recent_avg": 0, "prev_avg": 0, "window": window, "declines": 0}
    try:
        scores = []
        with open(history_path, encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    d = json.loads(line)
                    s = d.get("total_score")
                    if isinstance(s, (int, float)):
                        scores.append(float(s))
                except Exception:
                    continue
        if len(scores) < window * 2:
            return {"trend": "stable", "recent_avg": sum(scores)/max(len(scores),1), "prev_avg": 0, "window": window, "declines": 0}
        recent = scores[-window:]
        prev = scores[-window*2:-window]
        recent_avg = sum(recent) / len(recent)
        prev_avg = sum(prev) / len(prev)
        trend = "stable"
        declines = 0
        if recent_avg < prev_avg - 1.0:
            trend = "declining"
            declines = sum(1 for s in recent if s < prev_avg)
        return {"trend": trend, "recent_avg": recent_avg, "prev_avg": prev_avg, "window": window, "declines": declines}
    except Exception as e:
        return {"trend": "stable", "recent_avg": 0, "prev_avg": 0, "window": window, "declines": 0, "error": str(e)}


def main():
    project = sys.argv[1] if len(sys.argv) > 1 else None
    
    print("=== MOF Architecture Drift Detection ===\n")
    
    drifts = detect_drift(project)
    
    if not drifts:
        print("✅ No drift detected.")
        return
    
    # Group by severity
    high = [d for d in drifts if d["severity"] == "high"]
    medium = [d for d in drifts if d["severity"] == "medium"]
    low = [d for d in drifts if d["severity"] == "low"]
    
    if high:
        print(f"🔴 HIGH ({len(high)}):")
        for d in high:
            print(f"  [{d['project']}] {d['message']}")
        print()
    
    if medium:
        print(f"🟡 MEDIUM ({len(medium)}):")
        for d in medium:
            print(f"  [{d['project']}] {d['message']}")
        print()
    
    if low:
        print(f"🔵 LOW ({len(low)}):")
        for d in low:
            print(f"  [{d['project']}] {d['message']}")
        print()
    
    print(f"Total: {len(drifts)} drifts detected")


if __name__ == "__main__":
    main()
