#!/usr/bin/env python3
"""mypy-baseline-gate — workspace-level mypy regression gate.

任务: TASK-26348641 (P0 自反馈闭环: governance停摆/mypy假绿无报警)
      + L0:CR-ENG-MYPY-TRUTH-01 (mypy 验证必须 MYPYPATH=src, 禁裸 mypy 假绿).

委托 projects/kairon 的 mypy_report.py 作为真相计算器 (该工具已经按包
跑 MYPYPATH=src mypy src 收集 errors). 本 shim 只做两件事:

  1. 强制 MYPYPATH=src 注入到子进程环境 (防假绿)
  2. 提供 --check 模式: 检查 baseline 不超, 越界 exit 1 + omo event emit

用法:
  mypy-baseline-gate                   # 默认 gate 模式 (KPI only, 不 emit)
  mypy-baseline-gate --check          # 检查 + 越界时 emit
  mypy-baseline-gate --report         # 报表模式 (每包错误数 + top 5)
  mypy-baseline-gate --json           # JSON 输出 (CI 集成)

退出码:
  0 — baseline 内 (无回归)
  1 — 越界 (新增 errors vs baseline)
  2 — 工具错误 (mypy_report.py 不可达 / mypy 未装)
"""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path

WORKSPACE_ROOT = Path(__file__).resolve().parent.parent
KAIRON_SCRIPTS = WORKSPACE_ROOT / "projects" / "kairon" / "scripts"
MYPY_REPORT = KAIRON_SCRIPTS / "mypy_report.py"
BASELINE = WORKSPACE_ROOT / "projects" / "kairon" / "mypy-baseline.yaml"
OMO_VENV_PY = WORKSPACE_ROOT / "projects" / "omo" / ".venv" / "bin" / "python"


def _resolve_python() -> str | None:
    """优先用 kairon venv python (已装 mypy); 否则 omo venv; 都没有回退 PATH."""
    for cand in (
        WORKSPACE_ROOT / "projects" / "kairon" / ".venv" / "bin" / "python",
        OMO_VENV_PY,
    ):
        if cand.exists():
            return str(cand)
    found = shutil.which("python3")
    return found


def _run_mypy_report(args: list[str], env: dict) -> subprocess.CompletedProcess[str]:
    py = _resolve_python()
    if py is None or not MYPY_REPORT.exists():
        return subprocess.CompletedProcess(
            args=[], returncode=2, stdout="", stderr=f"FATAL: python or {MYPY_REPORT} not found"
        )
    cmd = [py, str(MYPY_REPORT), *args]
    return subprocess.run(cmd, cwd=WORKSPACE_ROOT / "projects" / "kairon",
                          env=env, capture_output=True, text=True, timeout=600, check=False)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="mypy baseline gate (workspace-level)")
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--check", action="store_true", help="gate + emit on breach (default)")
    mode.add_argument("--report", action="store_true", help="per-package report (no gate)")
    mode.add_argument("--json", action="store_true", help="JSON output")
    parser.add_argument("--top", type=int, default=10, help="top N errors in report")
    parser.add_argument("--dry-run", action="store_true", help="do not emit")
    args = parser.parse_args(argv)

    if not MYPY_REPORT.exists():
        print(f"FATAL: {MYPY_REPORT} not found", file=sys.stderr)
        return 2

    # 强制 MYPYPATH=src (CR-ENG-MYPY-TRUTH-01)
    env = os.environ.copy()
    env["MYPYPATH"] = "src"

    if args.report:
        result = _run_mypy_report(["--top", str(args.top)], env)
        sys.stdout.write(result.stdout)
        if result.stderr:
            sys.stderr.write(result.stderr)
        return result.returncode if result.returncode in (0, 1) else 2

    # 默认 + --check 都是 gate 模式
    baseline_arg = ["--baseline", str(BASELINE)] if BASELINE.exists() else []
    result = _run_mypy_report(baseline_arg, env)
    if args.json:
        print(result.stdout)
    else:
        sys.stdout.write(result.stdout)
        if result.stderr:
            sys.stderr.write(result.stderr)

    if result.returncode not in (0, 1):
        return 2  # 工具错误 (mypy 未装之类)
    if result.returncode == 0:
        return 0
    # 越界 → emit (除非 --dry-run)
    if args.dry_run:
        return 1
    if OMO_VENV_PY.exists():
        emit_cmd = [
            str(OMO_VENV_PY), "-m", "omo.omo_event", "emit",
            "--type", "mypy_regression_detected",
            "--source", "mypy-baseline-gate",
            "--payload", f'{{"baseline": "{BASELINE.relative_to(WORKSPACE_ROOT)}", '
                          f'"returncode": {result.returncode}}}',
        ]
        try:
            subprocess.run(emit_cmd, cwd=WORKSPACE_ROOT, check=False,
                           capture_output=True, text=True, timeout=20)
        except (subprocess.TimeoutExpired, FileNotFoundError):
            pass
    return 1


if __name__ == "__main__":
    raise SystemExit(main())