#!/usr/bin/env python3
"""MOF 模型导入/导出 — JSON 格式"""

import json
import sys
from pathlib import Path

import yaml

M1_DIR = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m1"
M2_DIR = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m2"


def load_all_m1() -> list[dict]:
    nodes = []
    for yaml_file in M1_DIR.rglob("*.yaml"):
        if yaml_file.name.startswith("_"):
            continue
        try:
            data = yaml.safe_load(yaml_file.read_text())
            if isinstance(data, dict) and "id" in data:
                nodes.append(data)
        except Exception:
            pass
    return nodes


def load_all_m2() -> list[dict]:
    schemas = []
    for yaml_file in M2_DIR.glob("*.yaml"):
        try:
            data = yaml.safe_load(yaml_file.read_text())
            if isinstance(data, dict):
                schemas.append(data)
        except Exception:
            pass
    return schemas


def export_json(output_file: str = None):
    """导出为 JSON"""
    m1_nodes = load_all_m1()
    m2_schemas = load_all_m2()
    
    data = {
        "version": "1.0",
        "exported_at": "2026-06-20",
        "m1_nodes": m1_nodes,
        "m2_schemas": m2_schemas,
        "stats": {
            "total_m1": len(m1_nodes),
            "total_m2": len(m2_schemas),
        }
    }
    
    if output_file:
        Path(output_file).write_text(json.dumps(data, indent=2, ensure_ascii=False))
        print(f"✅ Exported to {output_file}")
        print(f"   M1 nodes: {len(m1_nodes)}")
        print(f"   M2 schemas: {len(m2_schemas)}")
    else:
        print(json.dumps(data, indent=2, ensure_ascii=False))


def import_json(input_file: str):
    """从 JSON 导入"""
    if not Path(input_file).exists():
        print(f"Error: File {input_file} not found")
        sys.exit(1)
    
    data = json.loads(Path(input_file).read_text())
    
    print(f"✅ Imported from {input_file}")
    print(f"   M1 nodes: {len(data.get('m1_nodes', []))}")
    print(f"   M2 schemas: {len(data.get('m2_schemas', []))}")
    
    return data


def main():
    if len(sys.argv) < 2:
        print("Usage: mof-io <command> [args]")
        print("Commands: export [file], import <file>")
        sys.exit(1)
    
    command = sys.argv[1]
    
    if command == "export":
        output_file = sys.argv[2] if len(sys.argv) > 2 else None
        export_json(output_file)
    
    elif command == "import":
        if len(sys.argv) < 3:
            print("Usage: mof-io import <file>")
            sys.exit(1)
        import_json(sys.argv[2])
    
    else:
        print(f"Unknown command: {command}")
        sys.exit(1)


if __name__ == "__main__":
    main()
