#!/usr/bin/env python3
"""MOF 依赖安全扫描 — 扫描跨层依赖风险"""

import subprocess
import sys
from pathlib import Path

import yaml

M1_DIR = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m1"
PROJECTS_DIR = Path(__file__).parent.parent / "projects"

# 安全约束：禁止的跨层依赖模式
FORBIDDEN_DEPENDENCIES = {
    "L4": ["L0", "L1"],  # L4 不应直接依赖 L0/L1
    "L3": ["L0"],        # L3 不应直接依赖 L0 (应通过 L1/L2)
}

# 安全约束：禁止的代码模式
FORBIDDEN_PATTERNS = {
    "eval(": "代码注入风险",
    "exec(": "代码注入风险",
    "__import__": "动态导入风险",
    "pickle.loads": "反序列化风险",
    "yaml.load": "YAML 反序列化风险 (应使用 yaml.safe_load)",
}


def load_all_m1() -> list[dict]:
    """加载所有 M1 节点"""
    nodes = []
    for yaml_file in M1_DIR.rglob("*.yaml"):
        if yaml_file.name.startswith("_"):
            continue
        try:
            data = yaml.safe_load(yaml_file.read_text())
            if isinstance(data, dict) and "id" in data:
                nodes.append(data)
        except Exception:
            pass
    return nodes


def check_cross_layer_risks() -> list[dict]:
    """检查跨层依赖风险"""
    nodes = load_all_m1()
    risks = []
    
    for node in nodes:
        if node.get("type") != "Component":
            continue
        
        layer = node.get("layer", "")
        relations = node.get("relations", {})
        depends_on = relations.get("depends_on", [])
        
        for dep_id in depends_on:
            # Find dep node
            dep_node = None
            for n in nodes:
                if n.get("id") == dep_id or n.get("project") == dep_id:
                    dep_node = n
                    break
            
            if dep_node:
                dep_layer = dep_node.get("layer", "")
                # Check forbidden cross-layer dependencies
                if layer in FORBIDDEN_DEPENDENCIES:
                    if dep_layer in FORBIDDEN_DEPENDENCIES[layer]:
                        risks.append({
                            "type": "cross_layer",
                            "severity": "high",
                            "source": node.get("id", ""),
                            "target": dep_id,
                            "message": f"{layer} → {dep_layer}: 违反分层约束",
                        })
    
    return risks


def check_code_patterns(project_name: str = None) -> list[dict]:
    """检查代码中的危险模式"""
    risks = []
    
    projects = [project_name] if project_name else ["agora", "cockpit", "runtime", "omo", "metaos", "ecos", "l4-kernel"]
    
    for proj in projects:
        project_dir = PROJECTS_DIR / proj / "src"
        if not project_dir.exists():
            continue
        
        for pattern, desc in FORBIDDEN_PATTERNS.items():
            try:
                result = subprocess.run(
                    ["grep", "-r", "--include=*.py", pattern, str(project_dir)],
                    capture_output=True, text=True, timeout=30
                )
                if result.stdout.strip():
                    count = len(result.stdout.strip().split("\n"))
                    risks.append({
                        "type": "code_pattern",
                        "severity": "medium",
                        "project": proj,
                        "pattern": pattern,
                        "count": count,
                        "message": f"{proj}: {count} 处 {desc}",
                    })
            except Exception:
                pass
    
    return risks


def check_hardcoded_secrets() -> list[dict]:
    """检查硬编码密钥"""
    risks = []
    
    for proj in ["agora", "cockpit", "runtime", "omo", "metaos", "ecos"]:
        project_dir = PROJECTS_DIR / proj / "src"
        if not project_dir.exists():
            continue
        
        try:
            result = subprocess.run(
                ["grep", "-r", "--include=*.py", "--include=*.ts",
                 "password.*=.*['\"]", "secret.*=.*['\"]", "token.*=.*['\"]"],
                str(project_dir),
                capture_output=True, text=True, timeout=30
            )
            if result.stdout.strip():
                count = len(result.stdout.strip().split("\n"))
                risks.append({
                    "type": "hardcoded_secret",
                    "severity": "high",
                    "project": proj,
                    "count": count,
                    "message": f"{proj}: {count} 处疑似硬编码密钥",
                })
        except Exception:
            pass
    
    return risks


def main():
    project = sys.argv[1] if len(sys.argv) > 1 else None
    
    print("=== MOF Security Scan ===\n")
    
    risks = []
    risks.extend(check_cross_layer_risks())
    risks.extend(check_code_patterns(project))
    risks.extend(check_hardcoded_secrets())
    
    if not risks:
        print("✅ No security risks detected.")
        return
    
    # Group by severity
    high = [r for r in risks if r["severity"] == "high"]
    medium = [r for r in risks if r["severity"] == "medium"]
    
    if high:
        print(f"🔴 HIGH ({len(high)}):")
        for r in high:
            print(f"  [{r.get('project', r.get('source', ''))}] {r['message']}")
        print()
    
    if medium:
        print(f"🟡 MEDIUM ({len(medium)}):")
        for r in medium:
            print(f"  [{r.get('project', '')}] {r['message']}")
        print()
    
    print(f"Total: {len(risks)} security risks detected")


if __name__ == "__main__":
    main()
