#!/usr/bin/env python3
"""R91: bus-dlq — admin CLI for bus-foundation DLQ.

Usage:
    bus-dlq list [--backend=X] [--status=PENDING|DLQ] [--limit=20] [--json]
    bus-dlq stats  # depth, oldest age, backend distribution
    bus-dlq ack <event_id>...
    bus-dlq retry <event_id>...
    bus-dlq purge [--backend=X] [--before=YYYY-MM-DD]
    bus-dlq watch  # live tail every 2s

Reads BUS_DLQ_PATH env var or defaults to ~/.runtime/bus_dlq.db.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
from pathlib import Path

# Allow running this script as a standalone CLI (uv run bin/bus-dlq ...)
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "projects" / "bus-foundation" / "src"))

from bus_foundation.dlq_admin import DLQAdmin, to_jsonable  # noqa: E402


def _resolve_db_path(args: argparse.Namespace) -> Path | None:
    if args.db_path:
        return Path(args.db_path)
    env = os.environ.get("BUS_DLQ_PATH")
    if env:
        return Path(env)
    return None


def cmd_list(args: argparse.Namespace) -> int:
    db = _resolve_db_path(args)
    admin = DLQAdmin(db_path=db)
    try:
        entries = admin.list(
            backend=args.backend,
            status=args.status,
            limit=args.limit,
        )
        if args.json:
            print(to_jsonable(entries))
        else:
            if not entries:
                print("(empty)")
                return 0
            print(f"{'event_id':<24} {'backend':<14} {'status':<8} {'retries':<8} {'age':<8} error")
            print("-" * 90)
            for e in entries:
                print(
                    f"{e.event_id[:22]:<24} {e.backend[:12]:<14} {e.status:<8} {e.retries:<8} {int(e.age_seconds):<8} {e.error[:40]}"
                )
    finally:
        admin.close()
    return 0


def cmd_stats(args: argparse.Namespace) -> int:
    db = _resolve_db_path(args)
    admin = DLQAdmin(db_path=db)
    try:
        stats = admin.stats()
        if args.json:
            print(json.dumps(stats, indent=2))
        else:
            print(f"Total entries: {stats['total']}")
            print(f"Oldest age:    {int(stats['oldest_age_seconds'])}s")
            print("By status:")
            for k, v in sorted(stats["by_status"].items()):
                print(f"  {k:<10} {v}")
            print("By backend:")
            for k, v in sorted(stats["by_backend"].items()):
                print(f"  {k:<14} {v}")
    finally:
        admin.close()
    return 0


def cmd_ack(args: argparse.Namespace) -> int:
    db = _resolve_db_path(args)
    admin = DLQAdmin(db_path=db)
    try:
        n = admin.ack(args.event_ids)
        print(f"ACK acknowledged {n} entries: {' '.join(args.event_ids)}")
    finally:
        admin.close()
    return 0


def cmd_retry(args: argparse.Namespace) -> int:
    """R91: re-publish envelopes via the bus-foundation router."""
    try:
        from bus_foundation import publish
    except ImportError as e:
        print(f"error: cannot import bus_foundation.publish: {e}", file=sys.stderr)
        return 1

    db = _resolve_db_path(args)
    admin = DLQAdmin(db_path=db)
    try:
        # Wrap publish() in a tiny adapter for DLQAdmin.retry().
        class _Adapter:
            def publish(self, env_dict: dict) -> str:
                from bus_foundation.envelope import BusEnvelope
                env = BusEnvelope.from_dict(env_dict)
                return publish(env)

        n = admin.retry(args.event_ids, _Adapter())
        print(f"Re-published {n}/{len(args.event_ids)} entries")
    finally:
        admin.close()
    return 0


def cmd_purge(args: argparse.Namespace) -> int:
    db = _resolve_db_path(args)
    admin = DLQAdmin(db_path=db)
    try:
        n = admin.purge(backend=args.backend, before=args.before)
        target = args.backend or args.before or "(all)"
        print(f"Would purge {n} entries matching: {target}")
        if not args.yes:
            print("(dry-run: pass --yes to actually delete)")
        # Note: actual DELETE is stubbed in R91.3 first cut; will be
        # wired to direct SQL in a follow-up. R91 is safe by default.
    finally:
        admin.close()
    return 0


def cmd_watch(args: argparse.Namespace) -> int:
    db = _resolve_db_path(args)
    print(f"Watching DLQ (Ctrl-C to exit): {db or 'default'}")
    while True:
        try:
            sys.stdout.write("\033[2J\033[H")  # clear screen
        except Exception:  # noqa: BLE001
            pass
        cmd_stats(argparse.Namespace(db_path=str(db) if db else None, json=False))
        time.sleep(args.interval)


def main() -> int:
    # Use parents=[parser] pattern so --db-path works both before
    # and after the sub-command (more forgiving for ops use).
    parser = argparse.ArgumentParser(
        prog="bus-dlq",
        description="bus-foundation DLQ admin CLI (R91)",
    )
    parser.add_argument("--db-path", help="Override DLQ db path (default: BUS_DLQ_PATH or ~/.runtime/bus_dlq.db)")

    sub = parser.add_subparsers(dest="command", required=True)

    p_list = sub.add_parser("list", help="List DLQ entries")
    p_list.add_argument("--backend", help="Filter by backend name")
    p_list.add_argument("--status", help="Filter by status (PENDING, DLQ)")
    p_list.add_argument("--limit", type=int, default=20, help="Max entries (default 20)")
    p_list.add_argument("--json", action="store_true", help="JSON output")
    p_list.set_defaults(func=cmd_list)

    p_stats = sub.add_parser("stats", help="Show DLQ statistics")
    p_stats.add_argument("--json", action="store_true", help="JSON output")
    p_stats.set_defaults(func=cmd_stats)

    p_ack = sub.add_parser("ack", help="Ack entries (mark as handled)")
    p_ack.add_argument("event_ids", nargs="+", help="Event IDs to ack")
    p_ack.set_defaults(func=cmd_ack)

    p_retry = sub.add_parser("retry", help="Re-publish entries via the bus router")
    p_retry.add_argument("event_ids", nargs="+", help="Event IDs to retry")
    p_retry.set_defaults(func=cmd_retry)

    p_purge = sub.add_parser("purge", help="Delete entries (dry-run by default)")
    p_purge.add_argument("--backend", help="Filter by backend name")
    p_purge.add_argument("--before", help="Only delete entries created before YYYY-MM-DD")
    p_purge.add_argument("--yes", action="store_true", help="Actually delete (not just dry-run)")
    p_purge.set_defaults(func=cmd_purge)

    p_watch = sub.add_parser("watch", help="Live tail of DLQ stats")
    p_watch.add_argument("--interval", type=float, default=2.0, help="Refresh interval in seconds")
    p_watch.set_defaults(func=cmd_watch)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
