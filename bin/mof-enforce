#!/usr/bin/env bash
# MOF Agent 约束强制工具
# 用法: mof-enforce <command> <node_id> [args]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ECOS_DIR="$SCRIPT_DIR/../projects/ecos"
MOF_REASON="$ECOS_DIR/src/ecos/ssot/tools/mof-reason.py"
MOF_VALIDATE="$ECOS_DIR/src/ecos/ssot/tools/mof-schema-validate.py"

usage() {
    echo "Usage: mof-enforce <command> <node_id> [args]"
    echo ""
    echo "Commands:"
    echo "  impact <node_id>     - 推导变更影响链"
    echo "  state <node_id> [target] - 推导状态转换"
    echo "  value <node_id>      - 推导价值指标"
    echo "  validate             - 校验所有 M1 节点"
    echo "  pre-check <node_id>  - 修改前完整检查"
    echo "  post-check           - 修改后完整检查"
}

pre_check() {
    local node_id=$1
    echo "=== MOF Pre-check: $node_id ==="
    echo ""
    
    # 1. 影响分析
    echo "1. Impact Analysis:"
    python3 "$MOF_REASON" impact "$node_id" 2>&1 | grep -E "→|Direct|Services|Sub|Indirect"
    echo ""
    
    # 2. 状态分析
    echo "2. State Analysis:"
    python3 "$MOF_REASON" state "$node_id" 2>&1 | grep -E "Current|Legal|Is"
    echo ""
    
    # 3. 价值分析
    echo "3. Value Analysis:"
    python3 "$MOF_REASON" value "$node_id" 2>&1 | grep -E "business|technical|strategic|cost"
    echo ""
    
    echo "=== Pre-check complete ==="
}

post_check() {
    echo "=== MOF Post-check ==="
    echo ""
    
    # Schema 校验
    echo "1. Schema Validation:"
    python3 "$MOF_VALIDATE" --strict 2>&1 | grep -E "=== |ERROR|Total"
    echo ""
    
    echo "=== Post-check complete ==="
}

case "$1" in
    impact)
        python3 "$MOF_REASON" impact "$2"
        ;;
    state)
        python3 "$MOF_REASON" state "$2" "$3"
        ;;
    value)
        python3 "$MOF_REASON" value "$2"
        ;;
    validate)
        python3 "$MOF_VALIDATE" --strict
        ;;
    pre-check)
        pre_check "$2"
        ;;
    post-check)
        post_check
        ;;
    *)
        usage
        exit 1
        ;;
esac
