#!/usr/bin/env bash
# =============================================================================
# ecos-link — eCOS v5 工具一键安装 / 同步脚本
# =============================================================================
# macOS 兼容 (bash 3.2+)，使用函数替代关联数组
#
# 用法:
#   bash ~/Workspace/bin/ecos-link install   # 首次安装
#   bash ~/Workspace/bin/ecos-link sync      # 增量同步
#   bash ~/Workspace/bin/ecos-link list      # 列出工具
#   bash ~/Workspace/bin/ecos-link check     # 检查 + 过时报告
#   bash ~/Workspace/bin/ecos-link clean     # 清理失效链接
# =============================================================================

set -euo pipefail

BIN_DIR="${HOME}/.local/bin"
WS="${HOME}/Workspace"

# ── 工具注册: 格式 "name:project_dir" ────────────────────────────────
TOOL_LIST=(
  "agora:agora"           "agora-mcp:agora"        "agora-mcp-gateway:agora"
  "agora-watchdog:agora"  "cockpit:cockpit"        "cockpit-mcp:cockpit"
  "cockpit-dashboard:cockpit" "workspace:cockpit"   "agent-runtime:cockpit"
  "runtime:runtime"       "ecos-matrix-scheduler:runtime"
  "ecos-bus-consumer:runtime"
  "ecos-ssb:ecos"         "ecos-dashboard:ecos"    "ecos-scheduler:ecos"
  "mof:ecos"              "mof-validate:ecos"      "mof-audit:ecos"
  "omo:omo"               "omo-debt:omo"           "omo-mcp:omo"
  "omo-sse-daemon:omo"    "cards:omo"
  "metaos:metaos"
  "kos:kairon"            "eidos:kairon"            "minerva:kairon"
  "ontoderive:kairon"     "kronos:kairon"           "forge:kairon"
  "iris:kairon"           "codeanalyze:kairon"      "sophia:kairon"
  "kairon-cli:kairon"     "cloakbrowser:kairon"
)

KNOWN_STALE=(
  "ag" "agent" "agent-cli" "ai-tools" "astrbot" "grok"
  "kimi-cli" "kimi-legacy" "ccproxy" "m2claude" "mclaude" "zai-claude"
  "pylsp" "python3.12" "codexbar" "mkdocs" "nano-pdf" "eu-pricing"
  "deepagents" "deepagents-cli" "graphify" "markitdown"
  "serena" "serena-agent" "serena-hooks" "wpsnote-cli" "cua-driver"
  "forge-bridge" "forge-mcp" "hermes" "switch-node.sh"
  "agy" "cagent" "droid" "chair" "exec" "scribe"
)

# ── 颜色 ────────────────────────────────────────────────────────────
G='\033[32m'; R='\033[31m'; Y='\033[33m'; C='\033[36m'
B='\033[1m'; D='\033[2m'; Z='\033[0m'
ok()  { echo -e "  ${G}✓${Z} $1"; }
err() { echo -e "  ${R}✗${Z} $1"; }
warn(){ echo -e "  ${Y}⚠${Z} $1"; }
info(){ echo -e "  ${C}ℹ${Z} $1"; }

# ── tool_count ──────────────────────────────────────────────────────
tool_count() { echo "${#TOOL_LIST[@]}"; }

# ── get_venv_bin <project_name> ─────────────────────────────────────
get_venv_bin() {
  local proj="$WS/projects/$1"
  [ -f "$proj/.venv/bin/python" ] || [ -f "$proj/.venv/bin/python3" ] && echo "$proj/.venv/bin" || echo ""
}

# ── list ────────────────────────────────────────────────────────────
cmd_list() {
  local total=$(tool_count)
  echo -e "\n${B}${C}eCOS v5 可用工具 (${total} 个)${Z}\n"
  printf "  %-26s %-8s %s\n" "工具" "层级" "项目"
  printf "  %-26s %-8s %s\n" "────" "───" "────"

  # Layer lookup
  for entry in "${TOOL_LIST[@]}"; do
    local name="${entry%%:*}" proj="${entry##*:}"
    local layer=""
    case "$proj" in
      agora) layer="I0" ;; cockpit) layer="L3" ;; runtime) layer="L1" ;;
      ecos) layer="L0" ;; omo) layer="L2" ;; metaos) layer="L2" ;;
      kairon) layer="L2" ;; *) layer="--" ;;
    esac
    local link="$BIN_DIR/$name"
    local status=""; [ -L "$link" ] && status="[已安装]" || status="[未安装]"
    printf "  ${C}%-26s${Z} ${D}%-8s${Z} %-8s %s\n" "$name" "$layer" "$proj" "$status"
  done
  echo ""
}

# ── install ──────────────────────────────────────────────────────────
cmd_install() {
  mkdir -p "$BIN_DIR"
  local i=0 s=0 f=0

  echo -e "\n${B}安装 eCOS v5 工具到 ${BIN_DIR}${Z}\n"

  for entry in "${TOOL_LIST[@]}"; do
    local name="${entry%%:*}" proj="${entry##*:}"
    local venv_bin=$(get_venv_bin "$proj")
    local src="${venv_bin}/${name}"
    local dst="${BIN_DIR}/${name}"

    [ -z "$venv_bin" ] && warn "$name — venv 未找到" && ((f++)) && continue
    [ ! -f "$src" ] && warn "$name — 源不存在" && ((f++)) && continue

    # 已存在且指向同目标 → 跳过
    if [ -L "$dst" ] && [ "$(readlink "$dst")" = "$src" ]; then
      ((s++)); continue
    fi

    [ -e "$dst" ] && rm -f "$dst"
    ln -s "$src" "$dst" && ok "$name" && ((i++)) || { err "$name — 创建失败"; ((f++)); }
  done

  echo -e "\n${B}结果:${Z} ${G}安装 ${i}${Z}, ${Y}跳过 ${s}${Z}, ${R}失败 ${f}${Z}"
  echo -e "${D}确保 PATH 含 ~/.local/bin: export PATH=\"\$HOME/.local/bin:\$PATH\"${Z}\n"
}

# ── sync ─────────────────────────────────────────────────────────────
cmd_sync() { cmd_install; }

# ── check ────────────────────────────────────────────────────────────
cmd_check() {
  echo -e "\n${B}检查 ~/.local/bin 工具状态${Z}\n"

  local v=0 br=0 st=0 u=0

  # 失效软链
  for entry in "$BIN_DIR"/*; do
    [ -L "$entry" ] || continue
    if [ ! -e "$entry" ]; then
      local target=$(readlink "$entry" 2>/dev/null || echo "?")
      err "$(basename "$entry") → $target (目标不存在)"
      ((br++))
    fi
  done

  # 过时文件
  for entry in "$BIN_DIR"/*; do
    local name=$(basename "$entry")
    for s in "${KNOWN_STALE[@]}"; do
      if [ "$s" = "$name" ]; then
        if [ -f "$entry" ] && [ ! -L "$entry" ]; then
          local sz=$(du -sh "$entry" 2>/dev/null | cut -f1)
          warn "$name (${sz}) — 已知过时，建议手动清理"
        else
          warn "$name — 已知过时链接"
        fi
        ((st++)); break
      fi
    done
  done

  # 有效链接
  for entry in "$BIN_DIR"/*; do
    [ -L "$entry" ] && [ -e "$entry" ] && ((v++))
  done

  echo ""
  echo -e "${B}统计:${Z} 有效 ${G}${v}${Z} | 失效 ${R}${br}${Z} | 过时 ${Y}${st}${Z}"
  echo ""
}

# ── clean ────────────────────────────────────────────────────────────
cmd_clean() {
  echo -e "\n${B}清理失效软链${Z}\n"
  local c=0
  for entry in "$BIN_DIR"/*; do
    [ -L "$entry" ] || continue
    if [ ! -e "$entry" ]; then
      local name=$(basename "$entry")
      rm -f "$entry" && ok "$name — 已删除" && ((c++))
    fi
  done
  echo -e "\n清理了 ${c} 个失效链接\n"
}

# ── main ─────────────────────────────────────────────────────────────
case "${1:-}" in
  install) cmd_install ;;  sync) cmd_sync ;;
  list)    cmd_list ;;     check) cmd_check ;;
  clean)   cmd_clean ;;
  *)
    echo -e "\n${B}ecos-link — eCOS v5 工具管理${Z}\n"
    echo "  用法: ecos-link <命令>"
    echo ""
    echo "  命令:"
    echo "    install  首次安装 (创建所有软链)"
    echo "    sync     增量同步 (只添加缺失的)"
    echo "    list     列出所有 $(tool_count) 个可用工具"
    echo "    check    检查链接有效性 + 过时报告"
    echo "    clean    清理失效软链"
    echo ""
    ;;
esac
