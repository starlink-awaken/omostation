#!/usr/bin/env python3
"""workspace-audit - Omostation 统一审计 CLI (Round 43 P1)

6 维度全方位审计:
  1. omo governance           治理巡检 6 项 (lint / test / debt / adr / task / agora)
  2. omo lint yaml-bypass     .omo/debt/items/ 越权 status 字段
  3. c2g radar (修真)        真实 .omo/tasks/ 数据战略审计
  4. 治理 SSOT 一致性         CLAUDE.md/AGENTS.md/README.md/INDEX.md 同步
  5. 子项目 gitlink 同步      根仓 vs 远端 ahead/behind
  6. agora 操作审计           最近 N 条操作 (默认 7d)

调用:
  workspace-audit                              # 6 维度全跑
  workspace-audit --dim governance             # 只跑指定维度
  workspace-audit --format json               # JSON 输出
  workspace-audit --output report.md           # 写报告
  workspace-audit --since 30d                 # agora 维度时间范围

作者: X-Plane Audit Agent · 2026-06-15
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

WORKSPACE_ROOT = Path(__file__).resolve().parent.parent
# 允许通过环境变量 WORKSPACE_AUDIT_ROOT 覆盖 (从子目录如 cockpit 调时, __file__ 路径会错)
WORKSPACE_ROOT = Path(os.environ.get("WORKSPACE_AUDIT_ROOT", str(WORKSPACE_ROOT)))
OMO_VENV = WORKSPACE_ROOT / "projects" / "omo" / ".venv" / "bin"
C2G_SRC = WORKSPACE_ROOT / "projects" / "c2g" / "src"

DIMENSIONS = [
    "governance",   # omo governance
    "lint",         # omo lint yaml-bypass
    "radar",        # c2g radar (修真)
    "ssot",         # 治理 SSOT 一致性
    "gitlink",      # 子项目 gitlink 同步
    "ops",          # agora 操作审计
]


# ── Dimension 1: omo governance ──
def _run_omo_cli_json(*args: str) -> tuple[int, dict[str, Any] | None, str]:
    cmd = [
        str(OMO_VENV / "python"),
        "-W",
        "ignore::DeprecationWarning",
        "-m",
        "omo.cli",
        *args,
    ]
    result = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=30,
        cwd=str(WORKSPACE_ROOT),
    )
    output = result.stdout + result.stderr
    try:
        payload = json.loads(result.stdout) if result.stdout.strip() else None
    except json.JSONDecodeError:
        payload = None
    return result.returncode, payload, output


def dim_governance() -> dict[str, Any]:
    """跑 omo governance, 抓总分 + 6 项分数.

    修真 v4 (Round 43 P1 修真修真): 修真前 parse 修真后 fail 修真原因:
      - 表格列: | 检查 | 类别 | 严重度 | 分数 | 说明 |
        cells[0]=检查 cells[1]=类别 cells[2]=严重度 cells[3]=分数
        修真前用 cells[2] in (OK, WARN, FAIL) 修真 (应该是 cells[2]=='严重度' cell[3]=='分数')
      - 总分行: '**总分: 100.0 (A+)**' 修真前判断 OK
      - 修真后: 用 6 项 OK 行数 + 严重度列(cells[2]) + 分数列(cells[3])
    """
    try:
        result = subprocess.run(
            [str(OMO_VENV / "omo"), "governance"],
            capture_output=True, text=True, timeout=30,
            cwd=str(WORKSPACE_ROOT),
        )
        output = result.stdout + result.stderr
        score = None
        grade = None
        items: list[dict[str, str]] = []
        for line in output.splitlines():
            stripped = line.strip()
            if stripped.startswith("**总分:"):
                # e.g. "**总分: 100.0 (A+)**" 修真后: 去 markdown + 去 '总分:' 修真后 strip
                # 修真 v5: 修真修真 replace 修真修真后 开头的 ": " 修真修真修真
                parts = stripped.replace("**", "")
                parts = parts.replace("总分:", "", 1).lstrip(": ").strip()
                if "(" in parts:
                    score_str, grade_part = parts.split("(", 1)
                    try:
                        score = float(score_str.strip())
                    except ValueError:
                        pass
                    grade = grade_part.rstrip(")").strip()
            if stripped.startswith("|") and "|" in stripped[1:]:
                # 表格行: | 检查 | 类别 | 严重度 | 分数 | 说明 |
                # 修真 v4: 修真前 cells[2] in (OK,WARN,FAIL) 错; 修真后看 cells[2] (严重度)
                cells = [c.strip() for c in stripped.split("|") if c.strip()]
                if len(cells) >= 4 and cells[2] in ("OK", "WARN", "FAIL"):
                    try:
                        s = int(cells[3])
                        items.append({
                            "check": cells[0],
                            "category": cells[1],
                            "severity": cells[2],
                            "score": s,
                            "note": cells[4] if len(cells) > 4 else "",
                        })
                    except (ValueError, IndexError):
                        pass
        surfaces_rc, surfaces_payload, surfaces_output = _run_omo_cli_json(
            "governance", "surfaces", "--workspace-root", ".", "--json"
        )
        ingress_summary = None
        if isinstance(surfaces_payload, dict):
            ingress = surfaces_payload.get("ingress_registry", {})
            if isinstance(ingress, dict):
                ingress_summary = {
                    "exists": bool(ingress.get("exists")),
                    "goal_count": len(ingress.get("goal_ids", [])),
                    "task_count": len(ingress.get("task_ids", [])),
                    "goal_source_ref_count": len(ingress.get("goal_source_refs", [])),
                    "task_source_ref_count": len(ingress.get("task_source_refs", [])),
                }
        return {
            "dim": "governance",
            "score": score if score is not None else 0,
            "grade": grade or "?",
            "items": items,
            "output": output,
            "surfaces_status": (
                surfaces_payload.get("status", "error")
                if isinstance(surfaces_payload, dict) and surfaces_rc == 0
                else "error"
            ),
            "surfaces_issues": (
                surfaces_payload.get("issues", [])
                if isinstance(surfaces_payload, dict)
                else []
            ),
            "ingress_registry": ingress_summary,
            "surfaces_output": surfaces_output,
        }
    except (subprocess.TimeoutExpired, FileNotFoundError) as exc:
        return {"dim": "governance", "error": str(exc), "score": 0, "grade": "?"}


# ── Dimension 2: omo lint yaml-bypass ──
def dim_lint() -> dict[str, Any]:
    """跑 omo lint yaml-bypass, 抓 issue 数.

    修真 v4 (Round 43 P1 修真修真): 修真前判断
      passed = "0 处越权" in output and "pass" in output.lower()
    修真原因: omo 修真后输出 '✅ omo lint yaml-bypass pass: 0 处越权'
      修真前应能匹配但 修真原因修真后 返回 0 issue 还是判 fail
    修真后: 更宽松判断, 修真后看是否有 ✅ / pass 字样
    """
    try:
        result = subprocess.run(
            [str(OMO_VENV / "omo"), "lint", "yaml-bypass"],
            capture_output=True, text=True, timeout=30,
            cwd=str(WORKSPACE_ROOT),
        )
        output = result.stdout + result.stderr
        # 修真 v4: 更宽松判断
        passed = (
            "pass" in output.lower()
            and ("0 处越权" in output or "0 issue" in output.lower() or "0 处" in output)
        )
        # 修真后 issue 数 parse (修真前逻辑保留)
        issue_count = 0
        if not passed:
            for line in output.splitlines():
                if "fail:" in line.lower():
                    try:
                        issue_count = int(line.split("fail:")[1].split("处")[0].strip())
                    except (ValueError, IndexError):
                        pass
        return {
            "dim": "lint",
            "passed": passed,
            "issues": issue_count,
            "output": output,
        }
    except (subprocess.TimeoutExpired, FileNotFoundError) as exc:
        return {"dim": "lint", "error": str(exc), "passed": False, "issues": -1}


# ── Dimension 3: c2g radar (修真) ──
def dim_radar() -> dict[str, Any]:
    """跑 c2g.strategy audit (修真后真数据), 抓 priority/risk/owner 分布."""
    try:
        # 修真 v3: c2g 用 Python 3.13+ (int | None 语法), 不能用 Xcode 自带 python3.9
        import shutil
        py = shutil.which("python3.13") or shutil.which("python3.12") or "python3"
        result = subprocess.run(
            [py, "-m", "c2g.strategy", "audit"],
            capture_output=True, text=True, timeout=30,
            cwd=str(WORKSPACE_ROOT),
            env={"PYTHONPATH": str(C2G_SRC), "PATH": "/usr/bin:/bin:/usr/local/bin"},
        )
        output = result.stdout + result.stderr
        # 修真 v5: c2g 修真修真修真修真修真 returncode=0 但有 stderr 修真修真修真修真修真
        # 修真修真修真修真修真: 修真修真修真修真修真 'Strategic audit complete' 修真修真修真修真修真修真修真修真
        passed = result.returncode == 0 and "Strategic audit complete" in output
        return {
            "dim": "radar",
            "output": output,
            "passed": passed,
            "python": py,
        }
    except (subprocess.TimeoutExpired, FileNotFoundError) as exc:
        return {"dim": "radar", "error": str(exc), "passed": False}


# ── Dimension 4: SSOT 一致性 ──
def dim_ssot() -> dict[str, Any]:
    """查 CLAUDE.md/AGENTS.md/README.md/INDEX.md mtime + 关键关键字."""
    files = {
        "CLAUDE.md": WORKSPACE_ROOT / "CLAUDE.md",
        "AGENTS.md": WORKSPACE_ROOT / "AGENTS.md",
        "README.md": WORKSPACE_ROOT / "README.md",
        "INDEX.md": WORKSPACE_ROOT / ".omo" / "INDEX.md",
    }
    stale: list[dict[str, Any]] = []
    for name, path in files.items():
        if not path.exists():
            stale.append({"name": name, "status": "missing"})
            continue
        mtime = datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc)
        age_days = (datetime.now(tz=timezone.utc) - mtime).days
        status = "ok" if age_days < 14 else "stale"
        entry = {"name": name, "mtime": mtime.isoformat(), "age_days": age_days, "status": status}
        # 检查关键关键字 (eCOS v6 表述)
        content = path.read_text(encoding="utf-8", errors="ignore")
        if "eCOS v5" in content:
            entry["v5_leftover"] = True
        stale.append(entry)
    return {"dim": "ssot", "files": stale}


# ── Dimension 5: 子项目 gitlink 同步 ──
def dim_gitlink() -> dict[str, Any]:
    """对每个子项目跑 git rev-list, 算 ahead/behind vs origin/main."""
    submodules = [
        "projects/agora", "projects/cockpit", "projects/ecos", "projects/kairon",
        "projects/metaos", "projects/omo", "projects/runtime",
    ]
    statuses: list[dict[str, Any]] = []
    for sub in submodules:
        sub_path = WORKSPACE_ROOT / sub
        if not (sub_path / ".git").exists() and not (sub_path / "src").exists():
            statuses.append({"name": sub, "status": "skipped", "reason": "no .git"})
            continue
        try:
            result = subprocess.run(
                ["git", "rev-list", "--left-right", "--count", "main...origin/main"],
                capture_output=True, text=True, timeout=10,
                cwd=str(sub_path),
            )
            output = result.stdout.strip()
            if "\t" in output:
                ahead, behind = output.split("\t")
                statuses.append({
                    "name": sub,
                    "ahead": int(ahead),
                    "behind": int(behind),
                    "in_sync": int(ahead) == 0 and int(behind) == 0,
                })
            else:
                statuses.append({"name": sub, "status": "no_upstream", "output": output})
        except (subprocess.TimeoutExpired, FileNotFoundError, ValueError) as exc:
            statuses.append({"name": sub, "status": "error", "error": str(exc)})
    return {"dim": "gitlink", "submodules": statuses}


# ── Dimension 6: agora 操作审计 ──
def dim_ops(since: str = "7d") -> dict[str, Any]:
    """跑 agora audit --since, 抓 stats.

    修真 v4: agora CLI 修真修真修真 PATH 中修真修真修真 (uv tool install 修真修真),
    修真修真修真: 修真修真 python3 -m agora.cli ... 修真修真
    """
    try:
        agora_root = WORKSPACE_ROOT / "projects" / "agora"
        result = subprocess.run(
            [
                "uv",
                "run",
                "--directory",
                str(agora_root),
                "python",
                "-c",
                (
                    "from agora.audit_subscriber import AuditSubscriber; "
                    f"a = AuditSubscriber(None, None); print(a.stats(since={since!r}))"
                ),
            ],
            capture_output=True,
            text=True,
            timeout=30,
            cwd=str(WORKSPACE_ROOT),
        )
        output = result.stdout + result.stderr
        passed = result.returncode == 0 and "Traceback" not in output
        return {
            "dim": "ops",
            "since": since,
            "output": output,
            "passed": passed,
        }
    except (subprocess.TimeoutExpired, FileNotFoundError) as exc:
        return {"dim": "ops", "error": str(exc), "passed": False}


# ── 总评分 + 报告渲染 ──
def calc_score(dims: dict[str, dict[str, Any]]) -> tuple[float, str]:
    """加权算总分. 6 维度各 100 分制, 等权平均."""
    scores: list[float] = []
    selected_keys = [key for key in DIMENSIONS if key in dims]
    for key in selected_keys:
        d = dims.get(key, {})
        if key == "governance":
            s = d.get("score", 0)
        elif key == "lint":
            s = 100 if d.get("passed") else max(0, 100 - d.get("issues", 0) * 5)
        elif key == "radar":
            s = 100 if d.get("passed") else 0
        elif key == "ssot":
            files = d.get("files", [])
            stale_count = sum(1 for f in files if f.get("status") == "stale")
            v5_count = sum(1 for f in files if f.get("v5_leftover"))
            s = max(0, 100 - stale_count * 10 - v5_count * 5)
        elif key == "gitlink":
            subs = d.get("submodules", [])
            in_sync = sum(1 for s in subs if s.get("in_sync"))
            s = 100 * in_sync / len(subs) if subs else 100
        elif key == "ops":
            s = 100 if d.get("passed") else 0
        else:
            s = 0
        scores.append(s)
    total = sum(scores) / len(scores) if scores else 0
    grade = (
        "A+" if total >= 98 else
        "A" if total >= 90 else
        "B" if total >= 80 else
        "C" if total >= 70 else
        "D" if total >= 60 else "F"
    )
    return total, grade


def render_markdown(dims: dict[str, dict[str, Any]], total: float, grade: str) -> str:
    """输出 markdown 格式报告."""
    selected_keys = [key for key in DIMENSIONS if key in dims]
    lines = [
        "# Omostation Workspace Audit Report",
        "",
        f"**日期**：{datetime.now(tz=timezone.utc).strftime('%Y-%m-%d %H:%M UTC')}",
        f"**总分**：{total:.1f} / 100 ({grade})",
        "",
        f"## {len(selected_keys)} 维度系统化审计",
        "",
        "| # | 维度 | 状态 | 详情 |",
        "|---|---|---|---|",
    ]
    for i, key in enumerate(selected_keys, 1):
        d = dims.get(key, {})
        if key == "governance":
            status = f"**{d.get('score', 0)}** ({d.get('grade', '?')})"
            ingress = d.get("ingress_registry") or {}
            ingress_text = "ingress=none"
            if isinstance(ingress, dict) and ingress.get("exists"):
                ingress_text = (
                    f"ingress goals={ingress.get('goal_count', 0)} "
                    f"tasks={ingress.get('task_count', 0)}"
                )
            detail = (
                f"{len(d.get('items', []))} 项检查 · "
                f"surfaces={d.get('surfaces_status', '?')} · {ingress_text}"
            )
        elif key == "lint":
            status = "✅ pass" if d.get("passed") else f"❌ {d.get('issues', 0)} issue"
            detail = "yaml-bypass 拦截"
        elif key == "radar":
            status = "✅ 真数据" if d.get("passed") else "❌ broken"
            detail = "c2g.strategy audit"
        elif key == "ssot":
            files = d.get("files", [])
            stale = [f["name"] for f in files if f.get("status") == "stale"]
            status = "✅ 全部新鲜" if not stale else f"🟡 {len(stale)} stale"
            detail = ", ".join(f["name"] for f in files) if files else "n/a"
        elif key == "gitlink":
            subs = d.get("submodules", [])
            in_sync = sum(1 for s in subs if s.get("in_sync"))
            status = f"✅ {in_sync}/{len(subs)} in_sync" if subs else "n/a"
            detail = ", ".join(s["name"].split("/")[-1] for s in subs if s.get("in_sync"))[:60]
        elif key == "ops":
            status = "✅ ok" if d.get("passed") else "❌ fail"
            detail = f"since {d.get('since', '7d')}"
        else:
            status = "?"
            detail = ""
        lines.append(f"| {i} | {key} | {status} | {detail} |")
    lines.append("")
    lines.append("## 详细发现")
    lines.append("")
    for key in selected_keys:
        d = dims.get(key, {})
        lines.append(f"### {key}")
        if "output" in d:
            lines.append("```")
            lines.append(d["output"][:2000])  # 截前 2000 字符
            lines.append("```")
            if key == "governance":
                lines.append(
                    f"- governance surfaces: {d.get('surfaces_status', '?')}"
                )
                ingress = d.get("ingress_registry") or {}
                if isinstance(ingress, dict):
                    lines.append(
                        "- ingress registry: "
                        f"exists={ingress.get('exists', False)} "
                        f"goals={ingress.get('goal_count', 0)} "
                        f"tasks={ingress.get('task_count', 0)}"
                    )
                for issue in (d.get("surfaces_issues") or [])[:5]:
                    lines.append(f"- surfaces issue: {issue}")
        elif "items" in d:
            for it in d["items"][:6]:
                lines.append(f"- {it}")
        elif "files" in d:
            for f in d["files"][:6]:
                age = f.get("age_days", "?")
                lines.append(f"- `{f['name']}`: mtime {f.get('mtime', '?')[:19]} ({age}d) {f.get('status', '?')}")
        elif "submodules" in d:
            for s in d["submodules"][:8]:
                lines.append(f"- `{s['name']}`: ahead={s.get('ahead', '?')} behind={s.get('behind', '?')} {'✅' if s.get('in_sync') else '🟡'}")
        lines.append("")
    return "\n".join(lines)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Omostation 统一审计 CLI (Round 43 P1)")
    parser.add_argument("--dim", choices=DIMENSIONS + ["all"], default="all", help="只跑指定维度 (默认 all)")
    parser.add_argument("--format", choices=["markdown", "json"], default="markdown", help="输出格式")
    parser.add_argument("--output", type=str, default=None, help="写报告到文件")
    parser.add_argument("--since", type=str, default="7d", help="agora 维度时间范围 (默认 7d)")
    args = parser.parse_args(argv)

    selected = DIMENSIONS if args.dim == "all" else [args.dim]
    dims: dict[str, dict[str, Any]] = {}
    runners = {
        "governance": dim_governance,
        "lint": dim_lint,
        "radar": dim_radar,
        "ssot": dim_ssot,
        "gitlink": dim_gitlink,
        "ops": lambda: dim_ops(args.since),
    }
    for dim_key in selected:
        print(f"🔍 跑维度 {dim_key}...", file=sys.stderr)
        dims[dim_key] = runners[dim_key]()

    total, grade = calc_score(dims)
    if args.format == "json":
        out = json.dumps({"total": total, "grade": grade, "dims": dims}, indent=2, ensure_ascii=False, default=str)
    else:
        out = render_markdown(dims, total, grade)
    if args.output:
        Path(args.output).write_text(out, encoding="utf-8")
        print(f"✓ 报告写入 {args.output}", file=sys.stderr)
    else:
        print(out)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
