#!/usr/bin/env python3
"""MOF 模型版本管理 — 记录变更 + diff 对比"""

import subprocess
import sys
from datetime import datetime
from pathlib import Path

import yaml

M1_DIR = Path(__file__).parent.parent / "projects/ecos/src/ecos/ssot/mof/m1"
VERSION_FILE = Path(__file__).parent.parent / ".omo/_truth/mof-version.yaml"


def get_current_version() -> dict:
    """获取当前版本 (P45 兼容: 处理可选 frontmatter)"""
    if VERSION_FILE.exists():
        text = VERSION_FILE.read_text()
        # P45: 可能有 frontmatter --- ... --- 在最前
        if text.startswith("---"):
            # 跳过第一个 --- 块
            end = text.find("---", 4)
            if end > 0:
                text = text[end+4:]
        return yaml.safe_load(text) or {"version": "0.0.0", "history": []}
    return {"version": "0.0.0", "history": []}


def save_version(version_data: dict):
    """保存版本"""
    VERSION_FILE.parent.mkdir(parents=True, exist_ok=True)
    VERSION_FILE.write_text(yaml.dump(version_data, allow_unicode=True, default_flow_style=False))


def record_change(description: str):
    """记录变更"""
    version_data = get_current_version()
    
    # Increment version
    parts = version_data["version"].split(".")
    parts[2] = str(int(parts[2]) + 1)
    new_version = ".".join(parts)
    
    # Add to history
    version_data["history"].append({
        "version": new_version,
        "timestamp": datetime.now().isoformat(),
        "description": description,
    })
    
    version_data["version"] = new_version
    save_version(version_data)
    
    print(f"✅ Recorded change: v{new_version} — {description}")


def show_version():
    """显示当前版本"""
    version_data = get_current_version()
    print(f"Current version: v{version_data['version']}")
    print(f"\nHistory ({len(version_data['history'])} changes):")
    for h in version_data["history"][-10:]:
        print(f"  v{h['version']} [{h['timestamp'][:10]}] {h['description']}")


def diff_versions(v1: str, v2: str):
    """对比两个版本"""
    version_data = get_current_version()
    
    # Find versions in history
    history = version_data["history"]
    changes_v1 = [h for h in history if h["version"] >= v1]
    changes_v2 = [h for h in history if h["version"] <= v2]
    
    relevant = [h for h in history if v1 <= h["version"] <= v2]
    
    print(f"=== Changes from v{v1} to v{v2} ===\n")
    for h in relevant:
        print(f"  v{h['version']}: {h['description']}")
    
    if not relevant:
        print("  No changes found.")


def main():
    if len(sys.argv) < 2:
        print("Usage: mof-version <command> [args]")
        print("Commands: show, record <description>, diff <v1> <v2>")
        sys.exit(1)
    
    command = sys.argv[1]
    
    if command == "show":
        show_version()
    
    elif command == "record":
        if len(sys.argv) < 3:
            print("Usage: mof-version record <description>")
            sys.exit(1)
        record_change(" ".join(sys.argv[2:]))
    
    elif command == "diff":
        if len(sys.argv) < 4:
            print("Usage: mof-version diff <v1> <v2>")
            sys.exit(1)
        diff_versions(sys.argv[2], sys.argv[3])
    
    else:
        print(f"Unknown command: {command}")
        sys.exit(1)


if __name__ == "__main__":
    main()
