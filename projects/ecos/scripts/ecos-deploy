#!/usr/bin/env python3
"""
eCOS v5 — 统一部署器 (ecos-deploy)
=====================================
四模式部署状态机: COLD → HOT → SHARED | SWARM

用法:
    # 冷启动 — 全新用户
    python3 ecos-deploy --mode cold

    # 热启动 — 已有数据，重建运行时
    python3 ecos-deploy --mode hot [--from /path/to/scripts]

    # 共享模式 — 建立共享体系
    python3 ecos-deploy --mode shared --role architect
    python3 ecos-deploy --mode shared --role operator --upstream /path/to/architect

    # 蜂群模式 — 多 Agent 协同
    python3 ecos-deploy --mode swarm --node-id my-agent

    # 查看当前模式
    python3 ecos-deploy --status

状态机:
    COLD → (用户填写身份) → HOT → SHARED | SWARM
"""

import sys
import json
import shutil
import subprocess
import argparse
import os
from datetime import datetime, timezone
from pathlib import Path


# ── 常量 ──
ECOS = Path.home() / ".ecos"
DOCS = Path.home() / "Documents"
SCRIPTS_DIR = DOCS / "驾驶舱" / "scripts"
ECOS_STATE_FILE = ECOS / "deploy-state.json"

G = "\033[92m"; C = "\033[96m"; Y = "\033[93m"; R = "\033[91m"; B = "\033[1m"; N = "\033[0m"


# ── 状态管理 ──

def read_state(target: Path = None) -> dict:
    state_file = (target / ".ecos/deploy-state.json") if target else ECOS_STATE_FILE
    if state_file.exists():
        return json.loads(state_file.read_text())
    return {"mode": "unknown", "initialized_at": None, "role": None, "node_id": None}


def write_state(mode: str, target: Path = None, **kwargs):
    ecos_dir = (target / ".ecos") if target else ECOS
    ecos_dir.mkdir(parents=True, exist_ok=True)
    state_file = ecos_dir / "deploy-state.json"
    state = {
        "mode": mode,
        "initialized_at": datetime.now(timezone.utc).isoformat(),
        **kwargs,
    }
    state_file.write_text(json.dumps(state, ensure_ascii=False, indent=2))


# ── COLD: 冷启动 ──

def deploy_cold(target: Path = None):
    """最小骨架 — 零数据 · 三脚本 · 空画布"""
    target = target or DOCS

    print(f"\n{B}  🥶 冷启动 — 生成最小骨架{N}\n")
    print(f"  目标: {target}")

    dirs = [
        "驾驶舱/scripts", "驾驶舱/CARDS",
        "学习进化/1-active/自我剖析", "学习进化/1-active/收件箱",
        "学习进化/2-knowledge/体系", "学习进化/2-knowledge/基建架构",
        "学习进化/2-knowledge/经验积累/lessons",
        "学习进化/3-archive/资料库", "学习进化/3-archive/灵感顿悟",
        "工具箱", "领域知识库", "工作文档", "家庭生活",
    ]
    for d in dirs:
        (target / d).mkdir(parents=True, exist_ok=True)

    # 网关
    (target / "CLAUDE_COWORK_GLOBAL.md").write_text(
        f"# L4 网关\n\n> eCOS v5 · 冷启动\n> {datetime.now().strftime('%Y-%m-%d')}\n\n"
        "## §0 我是谁\n\n**[你的名字]** — **[你的身份]**\n\n"
        "## §1 启动链\n\n"
        "1. `python3 驾驶舱/scripts/ecos-brief.py`\n"
        "2. 读 `驾驶舱/brief.md`\n"
        "3. 读本文件\n"
    )
    if not (target / "claude.md").exists():
        (target / "claude.md").symlink_to("CLAUDE_COWORK_GLOBAL.md")

    # 三核心脚本
    for sname, content in {
        "ecos-brief.py": '#!/usr/bin/env python3\nfrom pathlib import Path\nfrom datetime import datetime\nstale = 0\nfor f in Path.home().glob("Documents/**/CLAUDE.md"):\n    if f.is_file() and not f.is_symlink():\n        age = (datetime.now() - datetime.fromtimestamp(f.stat().st_mtime)).days\n        if age > 60: stale += 1\nprint(f"# 会话简报\\n\\nCLAUDE.md: {stale} 过期\\n检查时间: {datetime.now()}")\n',
        "ecos-health-check.py": '#!/usr/bin/env python3\nfrom pathlib import Path\nDOCS = Path.home() / "Documents"\nissues = []\nfor p in ["CLAUDE_COWORK_GLOBAL.md", "驾驶舱/CLAUDE.md", "学习进化/CLAUDE.md"]:\n    if not (DOCS / p).exists(): issues.append(p)\nprint(f"健康检查: {len(issues)} 项异常" if issues else "✅ 全部通过")\n',
        "ecos-whoami.py": '#!/usr/bin/env python3\nfrom pathlib import Path\nfrom datetime import datetime\nDOCS = Path.home() / "Documents"\nprint(f"eCOS v5 · 冷启动\\n时间: {datetime.now().strftime(\'%Y-%m-%d %H:%M\')}\\n位置: {DOCS}")\nfor d in ["驾驶舱", "学习进化", "工作文档", "家庭生活"]:\n    print(f"  {\"✅\" if (DOCS/d).exists() else \"❌\"} {d}")\n',
    }.items():
        p = target / "驾驶舱/scripts" / sname
        if not p.exists():
            p.write_text(content)

    (target / "驾驶舱/DASHBOARD.md").write_text("# DASHBOARD\n\n> 冷启动\n")
    (target / "驾驶舱/SIGNALS.md").write_text("# SIGNALS\n\n> 冷启动\n")
    (target / "学习进化/STATE.md").write_text("# STATE\n\n> 冷启动\n")

    write_state("cold", target)
    print(f"\n  {G}✅ 冷启动完成{N}")
    print(f"  下一步: 编辑 CLAUDE_COWORK_GLOBAL.md §0 填写你的身份")
    print(f"  然后: ecos-deploy --mode hot 升级到热启动\n")


# ── HOT: 热启动 ──

def deploy_hot(scripts_src: Path = None):
    """全量脚本 + 运行时初始化"""
    state = read_state(target=DOCS)

    if state["mode"] == "cold":
        print(f"\n  {C}从冷启动升级到热启动...{N}\n")
    else:
        print(f"\n{B}  🔥 热启动 — 初始化运行时{N}\n")

    # 运行时目录
    for sub in ["runtime", "events", "sla", "sessions", "audit/minerva"]:
        (ECOS / sub).mkdir(parents=True, exist_ok=True)

    # 注册表
    reg = ECOS / "runtime/registry.json"
    reg.write_text('{"services":[],"updated_at":"' + datetime.now(timezone.utc).isoformat() + '"}')

    # 复制全量脚本 (如果提供了源)
    if scripts_src and scripts_src.exists():
        count = 0
        for f in scripts_src.glob("*.py"):
            if f.name not in ("ecos-bootstrap.py", "ecos-bootstrap.sh", "__init__.py"):
                dst = SCRIPTS_DIR / f.name
                if dst.resolve() != f.resolve():
                    shutil.copy2(f, SCRIPTS_DIR)
                count += 1
        print(f"  📜 {count} 个脚本已安装")
    else:
        print(f"  {Y}⚠️ 未提供脚本源 — 使用 --from 指定{N}")

    # 复制运营文档
    cockpit_src_dir = scripts_src.parent if scripts_src and scripts_src.parent else None
    if cockpit_src_dir:
        doc_count = 0
        for doc in ["ACCESS.md", "ONBOARD.md", "OPS.md", "DEPLOY.md", "DEPLOY-MODES.md",
                     "agent-manifest.yaml", "meta-model-ecos.yaml"]:
            src = cockpit_src_dir / doc
            dst = DOCS / "驾驶舱" / doc
            if src.exists() and src.resolve() != dst.resolve():
                shutil.copy2(src, dst)
                doc_count += 1
        if doc_count:
            print(f"  📄 {doc_count} 个运营文档已安装")

    # 首次 health-check
    hs = SCRIPTS_DIR / "ecos-health-check.py"
    if hs.exists():
        r = subprocess.run(["python3", str(hs)], capture_output=True, text=True, timeout=30)
        if "✅" in r.stdout:
            print(f"  🩺 首次健康检查: {G}✅{N}")
        else:
            print(f"  🩺 健康检查: {Y}⚠️ 存在告警{N}")

    write_state("hot", DOCS)
    print(f"\n  {G}✅ 热启动完成{N}")
    print(f"  守护进程: python3 驾驶舱/scripts/ecos-daemon.py --once")
    print(f"  SLA:    python3 驾驶舱/scripts/ecos-sla-tracker.py")
    print(f"  升级到: ecos-deploy --mode shared 或 ecos-deploy --mode swarm\n")


# ── SHARED: 共享模式 ──

def deploy_shared(role: str, upstream: str = None):
    """多人共享架构"""
    state = read_state()

    if role == "architect":
        print(f"\n{B}  👷 共享模式 — 架构师{N}\n")
        print(f"  你的角色: 维护脚本和结构")
        print(f"  操作者通过 --upstream 指向你的路径获取更新")
        # 标记此目录为 canonical source
        manifest = DOCS / "驾驶舱" / "shared-manifest.yaml"
        manifest.write_text(
            f"# 共享清单 — 架构师节点\n"
            f"version: 1\n"
            f"updated: {datetime.now(timezone.utc).isoformat()}\n"
            f"mode: shared\n"
            f"role: architect\n"
        )
        write_state("shared", DOCS, role="architect")
        print(f"  {G}✅ 已标记为架构师节点{N}")
        print(f"  操作者用: ecos-deploy --mode shared --role operator --upstream my-architect-path\n")

    elif role == "operator":
        print(f"\n{B}  👤 共享模式 — 操作者{N}\n")
        print(f"  你的角色: 维护数据和域内容")

        if upstream:
            upstream_path = Path(upstream).expanduser().resolve()
            print(f"  上游(架构师): {upstream_path}")

            # 同步脚本
            upstream_scripts = upstream_path / "驾驶舱" / "scripts"
            if upstream_scripts.exists():
                synced = 0
                for f in upstream_scripts.glob("*.py"):
                    if not (SCRIPTS_DIR / f.name).exists():
                        shutil.copy2(f, SCRIPTS_DIR)
                        synced += 1
                print(f"  📜 {synced} 个新脚本已同步")
        else:
            print(f"  {Y}⚠️ 未指定上游 — 使用 --upstream 指向架构师路径{N}")

        write_state("shared", DOCS, role="operator", upstream=str(upstream))
        print(f"\n  {G}✅ 共享模式就绪{N}")

    print(f"  定期同步: ecos-deploy --mode hot 从上游更新\n")


# ── SWARM: 蜂群模式 ──

def deploy_swarm(node_id: str):
    """多 Agent 跨机器协同"""
    state = read_state()

    print(f"\n{B}  🐝 蜂群模式 — 节点注册{N}\n")
    print(f"  节点 ID: {node_id}")

    # 创建节点目录
    nodes_dir = ECOS / "nodes"
    nodes_dir.mkdir(parents=True, exist_ok=True)

    node_file = nodes_dir / f"{node_id}.json"
    node_info = {
        "node_id": node_id,
        "registered_at": datetime.now(timezone.utc).isoformat(),
        "hostname": os.uname().nodename if hasattr(os, "uname") else "unknown",
        "ecos_version": "5.0.0",
        "mode": "swarm",
        "shared_layers": ["L3", "L0", "I0"],
        "independent_layers": ["L4"],
    }
    node_file.write_text(json.dumps(node_info, ensure_ascii=False, indent=2))

    # 蜂群事件流
    swarm_events = ECOS / "events" / "swarm-stream.jsonl"
    swarm_events.parent.mkdir(parents=True, exist_ok=True)
    if not swarm_events.exists():
        swarm_events.write_text(
            json.dumps({
                "type": "swarm.join",
                "node_id": node_id,
                "timestamp": datetime.now(timezone.utc).isoformat(),
            }, ensure_ascii=False) + "\n"
        )

    write_state("swarm", DOCS, node_id=node_id)

    print(f"  📍 节点: {node_file}")
    print(f"  📡 事件: {swarm_events}")
    print(f"  {G}✅ 蜂群模式就绪{N}")
    print(f"\n  共享层 (L3/L0/I0):")
    print(f"    L3 入口协议: 跨节点代理可达")
    print(f"    L0 约束:     统一协议注册表")
    print(f"    I0 事件:     swarm-stream.jsonl → 跨节点聚合")
    print(f"\n  独立层 (L4):")
    print(f"    每节点独立身份 · 独立数据 · 独立域\n")


# ── STATUS: 状态查询 ──

def show_status():
    state = read_state(target=DOCS)
    mode = state.get("mode", "unknown")
    role = state.get("role")
    node_id = state.get("node_id")
    init_at = state.get("initialized_at", "未知")

    mode_icons = {"cold": "🥶", "hot": "🔥", "shared": "👥", "swarm": "🐝", "unknown": "❓"}

    print(f"\n{B}  eCOS v5 — 部署状态{N}\n")
    print(f"  {mode_icons.get(mode, '?')} 模式: {mode.upper()}")
    print(f"  初始化: {init_at}")
    if role:
        print(f"  角色:   {role}")
    if node_id:
        print(f"  节点:   {node_id}")
    print()

    # 检查关键资产
    checks = {
        "L4 网关": DOCS / "CLAUDE_COWORK_GLOBAL.md",
        "驾驶舱": DOCS / "驾驶舱/CLAUDE.md",
        "Vault": DOCS / "学习进化/CLAUDE.md",
        "脚本目录": SCRIPTS_DIR,
        "健康检查": SCRIPTS_DIR / "ecos-health-check.py",
    }
    for name, path in checks.items():
        ok = path.exists()
        print(f"  {'✅' if ok else '❌'} {name}")

    print()


# ── MAIN ──

def main():
    parser = argparse.ArgumentParser(description="eCOS v5 统一部署器")
    parser.add_argument("--mode", choices=["cold", "hot", "shared", "swarm"],
                        help="部署模式")
    parser.add_argument("--from", dest="scripts_src", type=str,
                        help="脚本源路径")
    parser.add_argument("--role", choices=["architect", "operator"],
                        help="共享模式角色")
    parser.add_argument("--upstream", type=str,
                        help="共享模式上游路径")
    parser.add_argument("--node-id", type=str,
                        help="蜂群模式节点 ID")
    parser.add_argument("--target", type=str,
                        help="目标路径 (默认 ~/Documents)")
    parser.add_argument("--status", action="store_true",
                        help="查看当前部署状态")
    args = parser.parse_args()

    if args.status:
        show_status()
        return

    target = Path(args.target).expanduser().resolve() if args.target else DOCS
    scripts_src = Path(args.scripts_src).expanduser().resolve() if args.scripts_src else None

    if args.mode == "cold":
        deploy_cold(target)
    elif args.mode == "hot":
        deploy_hot(scripts_src)
    elif args.mode == "shared":
        deploy_shared(args.role or "operator", args.upstream)
    elif args.mode == "swarm":
        deploy_swarm(args.node_id or f"node-{os.uname().nodename}" if hasattr(os, "uname") else "node-01")
    else:
        parser.print_help()

        # 自动检测: 如果无参数, 显示状态
        if not any([args.mode, args.status]):
            show_status()
            print(f"  {C}部署指南: ~/Documents/驾驶舱/DEPLOY-MODES.md{N}")
            print(f"  {C}冷启动:   ecos-deploy --mode cold{N}")
            print(f"  {C}热启动:   ecos-deploy --mode hot --from /path/to/scripts{N}")


if __name__ == "__main__":
    main()
