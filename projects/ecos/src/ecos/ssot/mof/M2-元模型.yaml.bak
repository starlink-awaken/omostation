# ============================================================================
# 织星 MOF — M2 元模型 (Meta-Model)
# ============================================================================
# MOF Layer: M2
# 定义 8 种要素类型的完整结构——M1 节点声明的"模具"。
# 每种类型是 M3 中对应 Element 子类型的实例化。
#
# 版本: 1.0.0 | 日期: 2026-06-06
# SSOT: 驾驶舱/元模型/M2-元模型.yaml
# 依赖: M3-元元模型.yaml
# ============================================================================

m2:
  version: "1.0.0"
  created: "2026-06-06"
  description: >
    织星 MOF 的 M2 层。为 8 种要素类型定义结构模板、状态机、
    验证规则和关系约束。所有 M1 节点声明必须遵守对应的 M2 定义。
    覆盖: 模型·架构·机制·协议·模式·规范·流程·实体

  # =========================================================================
  # §0 通用属性 (所有 M2 类型共享)
  # =========================================================================
  common:
    required_properties: [id, type, name, description, status, domain, created, version]
    optional_properties: [tags, parent, cross_refs, owner, layer]
    status_values: [draft, active, deprecated, archived]
    id_pattern: "{TYPE}-{YYYY}-{MM}-{DD}-{NNN}"

  # =========================================================================
  # 要素类型 1: 模型 (Model)
  # =========================================================================
  Model:
    m3_parent: DescriptiveElement.Model
    description: "系统的抽象表示——定义元素之间的映射、投影和转换规则。"
    icon: "🧩"

    stateMachine:
      draft:     { description: "草稿·概念阶段", transitions: [active, discarded] }
      active:    { description: "生效中·被系统引用", transitions: [deprecated, superseded] }
      deprecated: { description: "已废弃·仍可读", transitions: [archived] }
      superseded: { description: "被新版本替代", transitions: [archived] }
      archived:  { description: "归档·仅历史参考", transitions: [] }
      discarded: { description: "放弃", transitions: [] }

    requiredProperties:
      source:       { type: ref,     description: "建模源 (被建模的元素)" }
      mapping:      { type: map,     description: "映射规则 (source→target 的转换逻辑)" }
      formality:    { type: enum,    description: "形式化程度", values: [informal, semiformal, formal] }

    optionalProperties:
      target:       { type: ref,     description: "建模目标" }
      projects_to:  { type: list,    description: "可投影为哪些 View" }
      assumptions:  { type: list,    description: "建模假设" }
      limitations:  { type: string,  description: "已知局限" }

    validationRules:
      - { rule: "source != null", level: error, message: "模型必须声明建模源" }
      - { rule: "mapping.size > 0", level: error, message: "模型必须定义至少一条映射规则" }
      - { rule: "status == 'active' implies formality != 'informal'", level: warning, message: "生效中的模型应至少有 semi-formal 定义" }

    relationConstraints:
      can_be_source_of: [References, EquivalentTo, Generalizes]
      can_be_target_of: [References, Realizes, Constrains]
      cardinality_rules:
        - { relation: Realizes, from: Architecture, to: Model, cardinality: "1:N", note: "一个架构可实现多个模型" }

    examples:
      - id: "MODEL-2026-06-05-001"
        name: "统一架构模型"
        description: "5+4+1 ↔ L0-L4+X1-X4 双向映射模型"
      - id: "MODEL-2026-06-06-001"
        name: "M3-元元模型"
        description: "MOF 类型系统本身的模型（自反）"

  # =========================================================================
  # 要素类型 2: 架构 (Architecture)
  # =========================================================================
  Architecture:
    m3_parent: DescriptiveElement.Architecture
    description: "系统的组件-连接器-拓扑结构——定义'系统如何组织'。"
    icon: "🏗️"

    stateMachine:
      draft:     { description: "设计阶段", transitions: [active] }
      active:    { description: "当前架构·系统遵循", transitions: [evolving, deprecated] }
      evolving:  { description: "演化中·部分变更", transitions: [active] }
      deprecated: { description: "已废弃·新架构生效", transitions: [archived] }
      archived:  { description: "历史归档", transitions: [] }

    requiredProperties:
      topology:     { type: enum,    description: "拓扑类型", values: [layered, mesh, hub_spoke, pipeline, modular] }
      components:   { type: list,    description: "组件清单 (至少列出顶层组件)" }

    optionalProperties:
      connectors:   { type: list,    description: "连接器/协议清单" }
      quality_attrs: { type: map,    description: "{属性: 目标值}" }
      evolution_path: { type: list,  description: "演化路径 [当前→下一阶段→目标]" }
      debts:        { type: list,    description: "架构债务" }

    validationRules:
      - { rule: "components.size >= 1", level: error, message: "架构必须声明至少一个组件" }
      - { rule: "topology != null", level: error, message: "架构必须声明拓扑类型" }
      - { rule: "status == 'active' implies debts == []", level: warning, message: "活跃架构不应有未解决的架构债务" }

    relationConstraints:
      can_be_source_of: [Contains, References, Generalizes]
      can_be_target_of: [Realizes, Constrains, Audits]

    examples:
      - id: "ARCH-2026-06-05-001"
        name: "eCOS v5 架构"
        description: "5+4+1 层结构: L0-L4+X1-X4+I0+P0"
      - id: "ARCH-2026-06-06-001"
        name: "织星架构"
        description: "5层技术栈·4维治理·1织物·1界面"

  # =========================================================================
  # 要素类型 3: 机制 (Mechanism)
  # =========================================================================
  Mechanism:
    m3_parent: BehavioralElement.Mechanism
    description: "自动化或半自动化的运行机制——定义'系统如何自动运作'。"
    icon: "⚙️"

    stateMachine:
      designed:  { description: "设计完成·待实现", transitions: [implemented] }
      implemented: { description: "已实现·待部署", transitions: [active] }
      active:    { description: "运行中", transitions: [degraded, stopped] }
      degraded:  { description: "降级运行·部分功能异常", transitions: [active, stopped] }
      stopped:   { description: "已停止", transitions: [active, archived] }
      archived:  { description: "已移除", transitions: [] }

    requiredProperties:
      trigger:     { type: string,  description: "触发条件 (cron/event/manual/api)" }
      action:      { type: string,  description: "执行动作描述" }
      interval:    { type: integer, description: "执行间隔(秒)，0=事件驱动" }

    optionalProperties:
      feedback:    { type: string,  description: "反馈方式 (log/alert/event/cards)" }
      fallback:    { type: string,  description: "降级策略" }
      depends_on:  { type: list,    description: "依赖的其他机制/组件" }
      sla_target:  { type: map,     description: "SLA 目标 {metric: target}" }

    validationRules:
      - { rule: "trigger != null", level: error, message: "机制必须有触发条件" }
      - { rule: "action != null", level: error, message: "机制必须有执行动作" }
      - { rule: "status == 'active' implies feedback != null", level: warning, message: "运行中的机制应有反馈方式" }

    relationConstraints:
      can_be_source_of: [Invokes, Triggers]
      can_be_target_of: [Invokes, Triggers, Constrains]
      cardinality_rules:
        - { relation: Invokes, from: Mechanism, to: Artifact, cardinality: "N:M", note: "机制可调用多个脚本" }
        - { relation: Triggers, from: Mechanism, to: Mechanism, cardinality: "1:N", note: "一个机制可触发多个子机制" }

    examples:
      - id: "MECH-2026-06-06-001"
        name: "Daemon 定时循环"
        description: "每 6h 触发健康检查+保鲜+协议校验"
      - id: "MECH-2026-06-06-002"
        name: "自愈框架"
        description: "检测异常→尝试恢复→失败告警→创建 DEBT 卡片"

  # =========================================================================
  # 要素类型 4: 协议 (Protocol)
  # =========================================================================
  Protocol:
    m3_parent: BehavioralElement.Protocol
    description: "层间或系统间通信协议——定义'系统组件如何对话'。"
    icon: "🔌"

    stateMachine:
      planned:   { description: "规划中·未实现", transitions: [active, cancelled] }
      active:    { description: "活跃使用中", transitions: [aging, deprecated] }
      aging:     { description: "超半衰期·需审查", transitions: [active, deprecated] }
      deprecated: { description: "已废弃·迁移中", transitions: [archived] }
      archived:  { description: "已完全移除", transitions: [] }
      cancelled: { description: "规划取消", transitions: [] }

    requiredProperties:
      version_spec: { type: semver, description: "协议版本" }
      introduced:   { type: date,   description: "引入日期" }
      half_life:    { type: integer, description: "价值半衰期(天)" }
      registered:   { type: boolean, description: "是否已在 L0 Protocol Registry 注册" }

    optionalProperties:
      value_tier:   { type: integer, description: "价值层级(1-5)", min: 1, max: 5 }
      mapping:      { type: map,    description: "操作映射 {operation: endpoint}" }
      successor:    { type: ref,    description: "替代协议 (→Protocol)" }
      compatibility: { type: enum,  description: "兼容性", values: [backward, forward, breaking, none] }

    validationRules:
      - { rule: "registered == true", level: error, message: "协议必须在 L0 注册" }
      - { rule: "version_spec matches '^\\\\d+\\\\.\\\\d+\\\\.\\\\d+$'", level: error, message: "版本号须为 semver" }
      - { rule: "introduced != null", level: error, message: "必须有引入日期" }
      - { rule: "status == 'aging' implies successor != null", level: warning, message: "老化协议应声明替代方案" }

    relationConstraints:
      can_be_source_of: [CommunicatesVia]
      can_be_target_of: [CommunicatesVia, Constrains, Realizes]

    examples:
      - id: "PROTO-2025-03-26-001"
        name: "MCP"
        description: "Model Context Protocol — 工具协议"
      - id: "PROTO-2026-01-01-001"
        name: "ACP"
        description: "Agent Communication Protocol"

  # =========================================================================
  # 要素类型 5: 模式 (Pattern)
  # =========================================================================
  Pattern:
    m3_parent: GovernanceElement.Pattern
    description: "可复用的解决方案模板——定义'这类问题怎么解决'。"
    icon: "📐"

    stateMachine:
      emerging:  { description: "浮现中·从实践中提炼", transitions: [documented] }
      documented: { description: "已记录·可供引用", transitions: [validated, deprecated] }
      validated: { description: "已验证·推荐使用", transitions: [deprecated] }
      deprecated: { description: "不再推荐·有更好的替代", transitions: [archived] }
      archived:  { description: "归档", transitions: [] }

    requiredProperties:
      problem:     { type: string, description: "要解决的问题" }
      context:     { type: string, description: "适用上下文 (何时用/何时不用)" }
      solution:    { type: string, description: "解决方案描述" }

    optionalProperties:
      known_uses:  { type: list,   description: "已知应用实例 (→M1节点引用)" }
      anti_pattern: { type: string, description: "反模式 (看起来像但实际不适用的情况)" }
      forces:      { type: list,   description: "权衡因素" }
      related_patterns: { type: list, description: "相关模式 (→Pattern)" }

    validationRules:
      - { rule: "problem != null and context != null and solution != null", level: error, message: "模式必须包含问题/上下文/解决方案" }
      - { rule: "status == 'validated' implies known_uses.size >= 2", level: warning, message: "验证过的模式应有≥2个应用实例" }

    relationConstraints:
      can_be_source_of: [Generalizes, References]
      can_be_target_of: [Generalizes, References, Realizes]

    examples:
      - id: "PATT-2026-06-06-001"
        name: "SSOT 级联模式"
        description: "上层定义·下层继承·不重复——确保每个事实只有一个权威位置"
      - id: "PATT-2026-06-06-002"
        name: "CARDS parent→child 模式"
        description: "单向 parent 指针替代双向 children 维护——降低 Agent 写入成本"

  # =========================================================================
  # 要素类型 6: 规范 (Specification)
  # =========================================================================
  Specification:
    m3_parent: GovernanceElement.Specification
    description: "形式化的规则集合——定义'必须遵守什么'。"
    icon: "📋"

    stateMachine:
      draft:     { description: "起草中", transitions: [active] }
      active:    { description: "生效中·强制执行", transitions: [amended, deprecated] }
      amended:   { description: "修订中·部分条款变更", transitions: [active] }
      deprecated: { description: "已废弃", transitions: [archived] }
      archived:  { description: "归档", transitions: [] }

    requiredProperties:
      constraints: { type: list,   description: "包含的约束规则 (→Constraint)" }
      scope:       { type: list,   description: "适用范围 (→Layer 或 →Component)" }

    optionalProperties:
      validator:   { type: ref,    description: "校验器 (→Artifact)" }
      enforcement: { type: enum,   description: "执行模式", values: [warn, enforce, audit_only], default: warn }
      exemptions:  { type: list,   description: "豁免条件" }

    validationRules:
      - { rule: "constraints.size >= 1", level: error, message: "规范必须包含至少一条约束" }
      - { rule: "scope.size >= 1", level: error, message: "规范必须声明适用范围" }
      - { rule: "status == 'active' implies enforcement != null", level: warning, message: "生效规范应明确执行模式" }

    relationConstraints:
      can_be_source_of: [Constrains, Contains]
      can_be_target_of: [Constrains, References, Audits]

    examples:
      - id: "SPEC-2026-06-06-001"
        name: "L0 协议约束规范"
        description: "L0-constraints.yaml — 9条约束覆盖X1-X3"
      - id: "SPEC-2026-06-06-002"
        name: "CLAUDE.md 写作规范"
        description: "§0 SSOT声明·§1模块定位·§2快速路由·更新规则·维护周期"

  # =========================================================================
  # 要素类型 7: 流程 (Process)
  # =========================================================================
  Process:
    m3_parent: BehavioralElement.Process
    description: "有明确步骤序列和状态机的工作流——定义'事情怎么做'。"
    icon: "🔄"

    stateMachine:
      defined:   { description: "已定义·待实例化", transitions: [active] }
      active:    { description: "运行中·实例在执行", transitions: [blocked, completed, cancelled] }
      blocked:   { description: "被阻塞", transitions: [active, cancelled] }
      completed: { description: "已完成", transitions: [archived] }
      cancelled: { description: "已取消", transitions: [archived] }
      archived:  { description: "归档", transitions: [] }

    requiredProperties:
      states:      { type: list,   description: "状态列表 [{name, description, transitions}]" }
      steps:       { type: list,   description: "步骤序列 [{order, name, action, input, output}]" }

    optionalProperties:
      input_type:  { type: ref,    description: "输入类型 (→Element)" }
      output_type: { type: ref,    description: "输出类型 (→Element)" }
      sla:         { type: map,    description: "{metric: target}" }
      owner:       { type: ref,    description: "流程负责人 (→Entity)" }
      decision_points: { type: list, description: "决策点 [{condition, branches}]" }

    validationRules:
      - { rule: "states.size >= 2", level: error, message: "流程至少需要起始和终止两个状态" }
      - { rule: "steps.size >= 1", level: error, message: "流程至少需要一个步骤" }
      - { rule: "has_terminal_state(states)", level: error, message: "流程必须有终止状态(completed/cancelled/archived)" }

    relationConstraints:
      can_be_source_of: [Triggers, DataFlow]
      can_be_target_of: [Constrains, Audits]

    examples:
      - id: "PROC-2026-06-06-001"
        name: "CARDS Idea→Delivery 流程"
        description: "flash→incubating→promoted→active→done→published→maintained"
      - id: "PROC-2026-06-06-002"
        name: "Agent 启动链"
        description: "workspace_context→cards_check→执行→cards_update (7个生命周期钩子)"

  # =========================================================================
  # 要素类型 8: 实体 (Entity)
  # =========================================================================
  Entity:
    m3_parent: StructuralElement.Entity
    description: "有身份、可跨域追踪的事物——定义'系统中有哪些重要的东西'。"
    icon: "🏷️"

    stateMachine:
      emerging:  { description: "浮现中·未正式定义", transitions: [active] }
      active:    { description: "活跃实体", transitions: [inactive, merged, archived] }
      inactive:  { description: "不活跃·保留", transitions: [active, archived] }
      merged:    { description: "已合并到其他实体", transitions: [archived] }
      archived:  { description: "归档", transitions: [] }

    requiredProperties:
      domain:      { type: string,  description: "SSOT 所在域 (如 领域知识库/人物)" }
      entity_type: { type: enum,    description: "实体分类", values: [person, organization, project, asset, concept, document, system] }

    optionalProperties:
      identity:    { type: map,     description: "跨域解析键 (用于 entity resolution)" }
      attributes:  { type: map,     description: "域特有属性" }
      relations:   { type: list,    description: "与其他实体的关系 (→Entity)" }
      sources:     { type: list,    description: "SSOT 来源文件列表" }
      cross_domain_refs: { type: list, description: "跨域指针" }

    validationRules:
      - { rule: "domain != null", level: error, message: "实体必须声明 SSOT 所在域" }
      - { rule: "identity != null or sources != null", level: error, message: "实体必须有身份键或来源文件" }
      - { rule: "status == 'merged' implies relations exists (target of merge)", level: warning, message: "合并的实体应指向合并目标" }

    relationConstraints:
      can_be_source_of: [References, DependsOn, BelongsTo]
      can_be_target_of: [References, DependsOn, BelongsTo, Attributes]
      cardinality_rules:
        - { relation: BelongsTo, from: Entity, to: Entity, cardinality: "N:1", note: "多个实体可属于同一个组织/域" }

    examples:
      - id: "ENT-2026-05-22-001"
        name: "夏明星"
        description: "个人实体 — SSOT: 领域知识库/人物/实体/"
      - id: "ENT-2026-05-22-002"
        name: "房山区卫健委"
        description: "组织实体 — SSOT: 领域知识库/组织/实体/"

  # =========================================================================
  # §8.5 组件 (Component) — 可部署功能单元 [NEW]
  # =========================================================================
  Component:
    m3_parent: StructuralElement.Component
    description: "可部署/可运行的功能单元——服务、库、项目。回答'系统由哪些部件组成'。"
    icon: "🧱"
    stateMachine:
      active: { description: "运行中", transitions: [degraded, stopped, archived] }
      degraded: { description: "降级运行", transitions: [active, stopped] }
      stopped: { description: "已停止", transitions: [active, archived] }
      archived: { description: "已归档", transitions: [] }
    requiredProperties:
      layer: { type: string, description: "所属架构层 (L0-L4/I0/P0/X1-X4)" }
      runtime: { type: enum, values: [active, idle, stopped, unknown], description: "运行时状态" }
    optionalProperties:
      protocol: { type: ref, description: "使用的协议" }
      port: { type: integer, description: "监听端口" }
      has_tests: { type: boolean, description: "是否有测试" }
    validationRules:
      - { rule: "layer != null", level: error, message: "组件必须声明所属层" }
    examples:
      - id: "COMP-WS-agora"
        name: "Agora Service Mesh"
        description: "I0 集成织物 — MCP路由·动态代理"
      - id: "COMP-WS-cockpit"
        name: "Cockpit Entry Bridge"
        description: "L3 入口桥接 — 多Agent接入"

  # =========================================================================
  # §8.6 产物 (Artifact) — 补充类型（脚本/配置/文档的通用父类型）
  # =========================================================================
  Artifact:
    m3_parent: StructuralElement.Artifact
    description: "可寻址的文件/数据产物——脚本、配置、文档、数据库。"
    icon: "📄"

    stateMachine:
      active:    { description: "活跃使用中", transitions: [deprecated, archived] }
      deprecated: { description: "已废弃", transitions: [archived] }
      archived:  { description: "归档", transitions: [] }

    requiredProperties:
      path:       { type: string, description: "文件路径或数据源路径" }
      format:     { type: enum, description: "格式", values: [python, yaml, markdown, sqlite, json, shell] }

    optionalProperties:
      size:       { type: integer, description: "字节数" }
      mtime:      { type: string, description: "最后修改时间" }
      layer:      { type: string, description: "所属层" }

    validationRules:
      - { rule: "path != null", level: error, message: "产物必须声明路径" }

    relationConstraints:
      can_be_target_of: [Invokes, References, Constrains]

    examples:
      - id: "ARTIFACT-SCRIPT-ecos-daemon"
        name: "ecos-daemon.py"
        description: "L1 守护进程脚本"

  # =========================================================================
  # §8.6 决策 (Decision) — 架构决策记录 [NEW]
  # =========================================================================
  Decision:
    m3_parent: GovernanceElement.Policy
    description: "架构决策记录 (ADR) — 记录关键设计决策及其理由。回答'为什么这样做'。"
    icon: "🧭"
    stateMachine:
      proposed: { description: "提议中", transitions: [accepted, rejected, superseded] }
      accepted: { description: "已接受·当前生效", transitions: [superseded, deprecated] }
      rejected: { description: "已拒绝", transitions: [archived] }
      superseded: { description: "被替代", transitions: [archived] }
      deprecated: { description: "不再适用", transitions: [archived] }
      archived: { description: "归档", transitions: [] }
    requiredProperties:
      problem: { type: string, description: "要解决的问题或背景" }
      decision: { type: string, description: "最终选择的方案" }
      rationale: { type: string, description: "选择理由" }
    optionalProperties:
      options: { type: list, description: "候选方案" }
      consequences: { type: string, description: "决策后果" }
      superseded_by: { type: ref, description: "替代决策" }
    validationRules:
      - { rule: "problem != null and decision != null", level: error, message: "决策必须有 问题/决策" }
    examples:
      - id: "DEC-2026-06-05-001"
        name: "CARDS v2.0 SQLite 替代 Markdown"
        description: "追踪系统 SSOT 从 Markdown → SQLite + MCP"

  # =========================================================================
  # §8.7 教训 (Lesson) — 经验教训 [NEW]
  # =========================================================================
  Lesson:
    m3_parent: GovernanceElement.Pattern
    description: "从实践中提炼的经验教训——记录'发生了什么、学到了什么'。"
    icon: "📖"
    stateMachine:
      recorded: { description: "已记录", transitions: [validated, archived] }
      validated: { description: "已验证", transitions: [promoted, archived] }
      promoted: { description: "已升级为 Pattern/Constraint", transitions: [] }
      archived: { description: "归档", transitions: [] }
    requiredProperties:
      incident: { type: string, description: "触发事件" }
      lesson: { type: string, description: "学到的教训" }
    optionalProperties:
      root_cause: { type: string, description: "根因分析" }
      prevention: { type: string, description: "预防措施" }
      source: { type: ref, description: "来源文件" }
      severity: { type: enum, values: [critical, high, medium, low], description: "严重度" }
    validationRules:
      - { rule: "incident != null and lesson != null", level: error, message: "教训必须有 事件/教训" }
    examples:
      - id: "LESS-2026-06-06-001"
        name: "Daemon 需要运行存在而非设计存在"
        description: "文件存在 ≠ 系统在运行 — launchctl 未加载"

  # =========================================================================
  # §8.8 约定 (Convention) — 命名与编码规范 [NEW]
  # =========================================================================
  Convention:
    m3_parent: GovernanceElement.Specification
    description: "命名约定·编码规范·文档结构标准。回答'怎么写才对'。"
    icon: "📏"
    stateMachine:
      proposed: { description: "提议中", transitions: [adopted, rejected] }
      adopted: { description: "已采纳", transitions: [amended, deprecated] }
      amended: { description: "已修订", transitions: [adopted] }
      deprecated: { description: "已废弃", transitions: [archived] }
      archived: { description: "归档", transitions: [] }
      rejected: { description: "已拒绝", transitions: [] }
    requiredProperties:
      rule: { type: string, description: "约定规则" }
      scope: { type: enum, values: [global, layer, domain, project], description: "适用范围" }
    optionalProperties:
      enforcement: { type: enum, values: [mandatory, recommended, optional], description: "强制级别" }
      examples_good: { type: list, description: "正例" }
      examples_bad: { type: list, description: "反例" }
      auto_check: { type: boolean, description: "是否可自动检测" }
    validationRules:
      - { rule: "rule != null and scope != null", level: error, message: "约定必须有 规则/范围" }
    examples:
      - id: "CONV-2026-06-06-001"
        name: "CLAUDE.md 标准模板"
        description: "§0 SSOT·§1定位·§2路由·维护节"
      - id: "CONV-2026-06-06-002"
        name: "CARDS ID 格式"
        description: "{TYPE}-{YYYY}-{MM}-{DD}-{NNN}"

  # =========================================================================
  # §9 跨类型约束 (Cross-Type Constraints)
  # =========================================================================
  cross_type_constraints:
    - { id: CTC-01, description: "协议必须被至少一个组件使用", rule: "for each Protocol, exists Component with protocol=Protocol.id", level: warning }
    - { id: CTC-02, description: "架构的组件必须在 M1 中有对应的 Component 节点", rule: "Architecture.components subset of Component.ids", level: warning }
    - { id: CTC-03, description: "规范的约束必须引用有效的约束 ID", rule: "Specification.constraints subset of Constraint.ids", level: error }
    - { id: CTC-04, description: "流程的 owner 必须存在对应的 Entity", rule: "Process.owner ∈ Entity.ids if Process.owner != null", level: warning }
    - { id: CTC-05, description: "模型不能自引用（除非是元模型）", rule: "Model.source != Model.id unless Model is meta-model", level: warning }

  # =========================================================================
  # §10 从 eCOS 现有系统映射
  # =========================================================================
  ecos_mapping:
    description: "现有 eCOS 资产到 M2 类型的映射——用于自动扫描"
    mappings:
      - { source: "驾驶舱/scripts/*.py",          target_type: Artifact, subtype: Script }
      - { source: "L0-constraints.yaml",          target_type: Specification }
      - { source: "meta-model-ecos.yaml",         target_type: Model }
      - { source: "5+4+1架构全景.md",              target_type: Architecture }
      - { source: "CARDS SQLite (cards.db)",       target_type: Entity, subtype: Card }
      - { source: "领域知识库/**/实体/*.md",        target_type: Entity }
      - { source: "ecos-daemon.py (daemon cycle)", target_type: Mechanism }
      - { source: "ecos-healer.py (自愈)",          target_type: Mechanism }
      - { source: "CARDS README (状态机定义)",      target_type: Process }
      - { source: "ecos-constraint-validator.py",  target_type: Specification, subtype: Validator }

meta:
  maintained_by: "织星 MOF 治理框架"
  next_review: "2026-07-06"
  change_log:
    - "v1.0.0 (2026-06-06): 初始版本 — 8要素完整定义·状态机·验证规则·关系约束·跨类型约束·eCOS映射"
