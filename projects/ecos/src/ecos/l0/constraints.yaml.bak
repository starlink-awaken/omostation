    x2_freshness: true
    x3_value: false
    kems_planes: [_control, _entities, _knowledge, _runtime, _storage, _archive]
    description: "全国高校绿色能源区域技转中心 — ALE框架·四阶转化·平台建设"

  - id: obsidian-vault
    name: "Obsidian Vault (iCloud)"
    layer: L4
    domain_type: document
    governance_tier: 3
    storage: "/Users/xiamingxing/Library/Mobile Documents/iCloud~md~obsidian/Documents/"
    claude_md: null
    state_md: null
    cards_domain: null
    i0_connected: false
    x1_audit: false
    x2_freshness: false
    x3_value: false
