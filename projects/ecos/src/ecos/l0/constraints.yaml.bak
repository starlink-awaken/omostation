  # ── 异构域 (Config/Engine/Tool/Workspace) v2.0 NEW ──
  - id: ai-config
    name: "~/.ai"
    layer: L3-L4
    domain_type: config
    storage: "/Users/xiamingxing/.ai/"
    description: "AI配置 — agents/skills/mcp/lessons · Claude Code管理"

  - id: agents-config
    name: "~/.agents"
    layer: L3
    domain_type: config
    storage: "/Users/xiamingxing/.agents/"
    description: "Agent运行时配置 — agent/skills/workflows/memory/mcp_config"

  - id: minerva
    name: "Minerva引擎"
    layer: L2
    domain_type: engine
    storage: "/Users/xiamingxing/minerva/"
    description: "Minerva研究引擎 — knowledge.db/state/vectors"

  - id: knowledge-engine
    name: "知识引擎"
    layer: L2
    domain_type: engine
    storage: "/Users/xiamingxing/knowledge/"
    description: "Kairon知识引擎 — ingested/reports"

  - id: bin
    name: "~/bin"
    layer: L1
    domain_type: tool
    storage: "/Users/xiamingxing/bin/"
    description: "系统脚本 — backup/gbrain/kb/vault"

  - id: toolbox-tools
    name: "~/ToolBox"
    layer: L1-L3
    domain_type: tool
    storage: "/Users/xiamingxing/ToolBox/"
    description: "MCP工具集 — bos-skill-cli/wps-office-mcp/wps-skills"

  - id: sharedwork
    name: "SharedWork"
    layer: L4
    domain_type: workspace
    storage: "/Users/xiamingxing/SharedWork/"
    description: "协作工作空间 — Agent/CLI/DeepResearch/Design/Ecology/Edu/Gateway/Knowledge/MCP"

  # ── 存储域 + 模型域 (Volumes) ──
  - id: shareddisk
    name: "SharedDisk"
    layer: "L4-Storage"
    domain_type: storage
    storage: "/Volumes/SharedDisk/"
    description: "大容量存储 — 01媒体·02教育·03家庭档案·04AI仓库·05软件·06下载·07备份·08配置·09云文件·99更多"

  - id: sharedmodel
    name: "SharedModel"
    layer: "L2-Storage"
    domain_type: model
    storage: "/Volumes/SharedModel/"
    description: "AI模型共享 — models/ollama/lmstudio/DockerDesktop/Orbstack"

  - id: model-volume
    name: "Model"
    layer: "L2-Storage"
    domain_type: model
    storage: "/Volumes/Model/"
    description: "AI模型存储 — mineru/ollama/lmstudio/omlx/models/DockerDesktop"

# ── 协议注册表 (含 half_life 价值衰减) ──
protocol_registry:
  - id: MCP
    version: "2025-03-26"
    introduced: "2026-06-06"  # 审查日期重置 — 协议仍为核心基础设施
    half_life_days: 365
    status: active
    value_tier: 1
    description: "Model Context Protocol — 工具协议 (cockpit/agora 活跃使用中)"

  - id: ACP
    version: "1.0"
    introduced: "2026-01-01"
    half_life_days: 180
    status: active
    value_tier: 1
    description: "Agent Communication Protocol — Agent通信"

  - id: A2A
    version: "1.0"
    introduced: "2026-01-01"
    half_life_days: 180
    status: active
    value_tier: 2
    description: "Agent-to-Agent 任务协议"

  - id: BOS_URI
    version: "0.2"  # Phase 33 重建中
    introduced: "2026-06-06"  # 审查日期重置 — Phase 33 活跃开发中
    half_life_days: 180
    status: active
    value_tier: 2
    description: "全域 BOS URI 挂载方案 (Phase 33: DEL-006-004 进行中)"

  - id: L0_YAML
    version: "1.0.0"
    introduced: "2026-06-06"
    half_life_days: 180
    status: active
    value_tier: 2
    description: "L0 协议约束 YAML 格式"

# 约束执行记录
execution:
  validator: "ecos-constraint-validator.py"
  mode: "warn"  # warn | enforce — 当前 PoC 阶段为 warn
  last_run: null
