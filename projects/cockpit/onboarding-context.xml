/* ── 服务拓扑图 SVG ─────────────────────────────────────── */
const PROTOCOL_COLORS = {
  mcp:'#38bdf8', rest:'#4ade80', grpc:'#fbbf24', stdio:'#a78bfa', websocket:'#f87171'
};

function renderTopology(services){
  const svg = document.getElementById('topology-svg');
  const badge = document.getElementById('topo-badge');
  if(!services || !services.length){
    svg.innerHTML = '';
    badge.textContent = '0 spokes';
    return;
  }
  badge.textContent = services.length + ' spokes';
  const spokeCount = services.length;
  const angleStep = (2 * Math.PI) / Math.max(spokeCount, 1);
  const radius = 220;

  let html = '';
  // Hub-Agora
  html += '<circle cx="0" cy="0" r="28" class="hub"/><text x="0" y="4" class="hub-label">🏛 Hub</text>';
  // Lines spokes -> Hub
  services.forEach((s,i)=>{
    const a = angleStep * i - Math.PI/2;
    const cx = Math.cos(a) * radius;
    const cy = Math.sin(a) * radius;
    const color = PROTOCOL_COLORS[s.protocol]||'#38bdf8';
    const cls = s.circuit==='CLOSED'?'spoke':'spoke unhealthy';
    html += `<line x1="0" y1="0" x2="${cx}" y2="${cy}" stroke="${color}" stroke-opacity="${s.circuit==='CLOSED'?0.6:0.2}"/>`;
    html += `<circle cx="${cx}" cy="${cy}" r="18" class="${cls}" stroke="${color}"/>`;
    html += `<text x="${cx}" y="${cy+28}" class="spoke-label" fill="${color}">${s.name}</text>`;
  });
  svg.innerHTML = html;
}

async function loadResearch(){
  const statusFilter = document.getElementById('research-status-filter')?.value || 'active';
  const tagFilter = document.getElementById('research-tag-filter')?.value?.trim() || '';
  try{
    let url = API+'/research?status='+statusFilter;
    if(tagFilter) url += '&tag='+encodeURIComponent(tagFilter);
    const r = await fetch(url);
    const data = await r.json();
    renderResearchTable(data);
  }catch(e){}
}

async function searchResearch(){
  const q = document.getElementById('research-search')?.value?.trim() || '';
  const statusFilter = document.getElementById('research-status-filter')?.value || 'active';
  const tagFilter = document.getElementById('research-tag-filter')?.value?.trim() || '';
  try{
    let url = API+'/research?q='+encodeURIComponent(q)+'&status='+statusFilter;
    if(tagFilter) url += '&tag='+encodeURIComponent(tagFilter);
    const r = await fetch(url);
    const data = await r.json();
    renderResearchTable(data);
  }catch(e){}
}

function renderResearchTable(data){
  const tbody = document.getElementById('research-table');
  if(!data.research || data.research.length===0){
    tbody.innerHTML = '<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">🔬</div>暂无研究记录</div></td></tr>';
    return;
  }
  tbody.innerHTML = data.research.map(rs=>{
    const d = new Date(rs.date*1000).toLocaleDateString('zh-CN');
    const s = formatResearchSnippet(rs.snippet || rs.summary || '');
    return `<tr class="svc-row" onclick="showResearchDetail(${rs.id})"><td><span class="tag" style="background:var(--accent-glow);color:var(--accent)">#${rs.id}</span></td>
      <td><span style="color:var(--text-bright);font-weight:500">${escapeHtml(rs.topic)}</span></td>
      <td class="text-dim">${s || '—'}</td>
      <td>${rs.sources}</td>
      <td class="text-dim">${d}</td></tr>`;
  }).join('');
}

connectWS();
loadResearch();
</script>
