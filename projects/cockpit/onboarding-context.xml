async function submitAsk(id){
  const input = document.getElementById('ask-input-'+id);
  const resultEl = document.getElementById('ask-result-'+id);
  if(!input || !input.value.trim()) return;
  const q = input.value.trim();
  input.disabled = true;
  resultEl.innerHTML = '<span class="text-dim">⏳ 正在追问...</span>';
  try{
    const r = await fetch(API+'/research/'+id+'/ask?question='+encodeURIComponent(q), {method:'POST'});
    const data = await r.json();
    if(r.ok){
      const preview = (data.output||'').slice(0,300).replace(/\n/g, '<br>');
      resultEl.innerHTML = '<span style="color:var(--accent)">✅ 追问已回答</span><br><span class="text-dim" style="font-size:0.78rem">'+preview+'</span>';
    }else{
      resultEl.innerHTML = '<span style="color:var(--danger)">❌ '+(data.error||'追问失败')+'</span>';
    }
  }catch(e){
    resultEl.innerHTML = '<span style="color:var(--danger)">❌ '+e.message+'</span>';
  }
  input.disabled = false;
  input.value = '';
  setTimeout(()=>showResearchDetail(id), 1500);
}

