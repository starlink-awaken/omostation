/* ── WebSocket 实时推送 ─────────────────────────────────── */
const WS_URL = (window.location.protocol === 'https:' ? 'wss://' : 'ws://') + window.location.host + '/ws';
let ws = null;
let wsReconnectTimer = null;

function connectWS(){
  if(ws && (ws.readyState===WebSocket.OPEN||ws.readyState===WebSocket.CONNECTING)) return;
  try{
    ws = new WebSocket(WS_URL);
    ws.onopen = ()=>{
      if(wsTimer){clearInterval(wsTimer);wsTimer=null}  // WS通了就停轮询
    };
    ws.onmessage = (e)=>{
      try{
        const data = JSON.parse(e.data);
        const snapshot = JSON.stringify(data.services);
        if(snapshot === _lastServices) return;
        _lastServices = snapshot;
        allServices = data.services;
        renderDashboard(data);
      }catch(_){}
    };
    ws.onclose = ()=>{
      ws = null;
      if(!wsTimer) wsTimer = setInterval(refresh, 5000);  // 断线恢复轮询
      if(wsReconnectTimer) clearTimeout(wsReconnectTimer);
      wsReconnectTimer = setTimeout(connectWS, 3000);       // 3s重连
    };
    ws.onerror = ()=>{ws && ws.close()};
  }catch(_){}
}

