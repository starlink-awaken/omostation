        row = conn.execute(
            "SELECT id, topic, summary, full_text, created_at, source_count, follow_ups, tags, archived_at, archive_reason, quarantined_at, quarantine_reason, agent FROM research WHERE id = ?",
            (research_id,),
        ).fetchone()
        conn.close()
        if row:
            result = dict(row)
