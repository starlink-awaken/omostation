#!/usr/bin/env python3
from __future__ import annotations

import sys
from pathlib import Path


SRC_ROOT = Path(__file__).resolve().parents[2]
if str(SRC_ROOT) not in sys.path:
    sys.path.insert(0, str(SRC_ROOT))

from cockpit.commands.base import _discover_services, _http_health
from cockpit.storage import get_data_access


def compute_product_health() -> dict[str, int]:
    services = _discover_services()
    total_services = len(services)
    healthy_services = sum(1 for _, _, _, url, _ in services if url and _http_health(url, timeout=1.5))
    research_items = len(get_data_access().list_research(limit=50))

    service_score = 100 if total_services == 0 else round((healthy_services / total_services) * 100)
    research_score = min(research_items, 10) * 10
    score = round(service_score * 0.7 + research_score * 0.3)

    return {
        "score": score,
        "healthy_services": healthy_services,
        "total_services": total_services,
        "research_items": research_items,
    }


def main() -> int:
    report = compute_product_health()
    print(f"Product Health Score: {report['score']}")
    print(f"Healthy services: {report['healthy_services']}/{report['total_services']}")
    print(f"Research items tracked: {report['research_items']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
