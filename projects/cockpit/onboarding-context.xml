  --glass-hover: rgba(255,255,255,0.08); --border: rgba(255,255,255,0.06);
  --border-active: rgba(56,189,248,0.3); --text: #e2e8f0; --text-dim: #64748b;
  --text-bright: #f8fafc; --accent: #38bdf8; --accent-glow: rgba(56,189,248,0.15);
  --success: #4ade80; --success-glow: rgba(74,222,128,0.15);
  --warning: #fbbf24; --warning-glow: rgba(251,191,36,0.15);
  --danger: #f87171; --danger-glow: rgba(248,113,113,0.15);
  --radius: 16px; --radius-sm: 10px;
}
*{margin:0;padding:0;box-sizing:border-box}
body{
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", system-ui, sans-serif;
  background: var(--bg); color: var(--text); min-height: 100vh;
  background-image:
    radial-gradient(ellipse 80% 60% at 20% 0%, rgba(56,189,248,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 60% 80% at 80% 100%, rgba(74,222,128,0.04) 0%, transparent 60%);
}
header{
  padding: 1.25rem 2rem; display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid var(--border); backdrop-filter: blur(20px);
  background: rgba(10,10,15,0.8); position: sticky; top: 0; z-index: 100;
}
header .brand{display:flex;align-items:center;gap:0.75rem}
header .logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--accent),#818cf8);display:flex;align-items:center;justify-content:center;font-size:1.2rem}
header h1{font-size:1.2rem;font-weight:600;color:var(--text-bright);letter-spacing:-0.02em}
header .version{font-size:0.7rem;color:var(--accent);background:var(--accent-glow);padding:0.15rem 0.5rem;border-radius:4px;font-weight:500}
.stats-bar{display:flex;gap:1.5rem}
.stat-item{display:flex;align-items:center;gap:0.5rem;font-size:0.85rem}
.stat-dot{width:8px;height:8px;border-radius:50%}
.stat-dot.ok{background:var(--success);box-shadow:0 0 8px var(--success)}
.stat-dot.warn{background:var(--warning);box-shadow:0 0 8px var(--warning)}
.stat-dot.err{background:var(--danger);box-shadow:0 0 8px var(--danger)}
.stat-value{font-weight:600;color:var(--text-bright)}
.stat-label{color:var(--text-dim)}
main{padding:1.5rem 2rem;max-width:1600px;margin:0 auto}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.25rem}
.card{
  background:var(--glass);border:1px solid var(--border);border-radius:var(--radius);
  padding:1.5rem;backdrop-filter:blur(20px);transition:border-color 0.2s,background 0.2s;
}
.card:hover{border-color:var(--border-active);background:var(--glass-hover)}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.card-header h2{font-size:0.95rem;font-weight:600;color:var(--text-bright);display:flex;align-items:center;gap:0.5rem}
.card-badge{font-size:0.7rem;padding:0.2rem 0.6rem;border-radius:6px;font-weight:500}
.card-badge.live{background:var(--success-glow);color:var(--success)}
table{width:100%;border-collapse:collapse}
th{text-align:left;padding:0.6rem 0.75rem;font-size:0.72rem;font-weight:600;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.05em;border-bottom:1px solid var(--border)}
td{padding:0.6rem 0.75rem;font-size:0.85rem;border-bottom:1px solid rgba(255,255,255,0.03)}
tr.svc-row{cursor:pointer;transition:background 0.15s}
tr.svc-row:hover td{background:rgba(56,189,248,0.06)}
.circuit-badge{display:inline-flex;align-items:center;gap:0.3rem;padding:0.2rem 0.6rem;border-radius:6px;font-size:0.72rem;font-weight:600}
.circuit-badge .circuit-dot{width:6px;height:6px;border-radius:50%}
.circuit-正常{background:var(--success-glow);color:var(--success)}
.circuit-正常 .circuit-dot{background:var(--success);box-shadow:0 0 6px var(--success)}
.circuit-断路{background:var(--danger-glow);color:var(--danger)}
.circuit-断路 .circuit-dot{background:var(--danger);box-shadow:0 0 6px var(--danger)}
.circuit-半开{background:var(--warning-glow);color:var(--warning)}
.circuit-半开 .circuit-dot{background:var(--warning);box-shadow:0 0 6px var(--warning)}
.tag{display:inline-block;padding:0.15rem 0.45rem;margin:0.1rem;border-radius:4px;font-size:0.65rem;background:rgba(255,255,255,0.06);color:var(--text-dim)}
.empty-state{text-align:center;padding:2rem;color:var(--text-dim);font-size:0.85rem}
.empty-state .empty-icon{font-size:2rem;margin-bottom:0.5rem;opacity:0.5}
button,input,select,textarea{
  font-family:inherit;padding:0.55rem 0.9rem;border-radius:var(--radius-sm);
  border:1px solid var(--border);background:rgba(255,255,255,0.04);color:var(--text);
  font-size:0.82rem;cursor:pointer;transition:all 0.15s;outline:none;
}
button:hover,input:hover,select:hover{border-color:var(--border-active)}
button:focus-visible,input:focus-visible{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow)}
.btn-primary{background:linear-gradient(135deg,var(--accent),#818cf8);border-color:transparent;color:#fff;font-weight:500}
.btn-primary:hover{opacity:0.9;box-shadow:0 0 20px var(--accent-glow)}
.btn-danger{background:rgba(248,113,113,0.1);border-color:rgba(248,113,113,0.2);color:var(--danger)}
.btn-danger:hover{background:rgba(248,113,113,0.2)}
.btn-ghost{background:transparent;border-color:var(--border)}
.btn-ghost:hover{background:var(--glass-hover)}
.form-group{display:flex;flex-direction:column;gap:0.35rem}
.form-group label{font-size:0.72rem;font-weight:600;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.04em}
.form-row{display:flex;gap:0.5rem}
.form-inline{display:flex;gap:0.5rem;align-items:flex-end;margin-top:0.5rem}
.action-bar{display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem}
.output-panel{
  background:rgba(0,0,0,0.3);border:1px solid var(--border);border-radius:var(--radius-sm);
  padding:1rem;font-family:"SF Mono","Fira Code","JetBrains Mono",monospace;
  font-size:0.75rem;line-height:1.6;max-height:280px;overflow-y:auto;white-space:pre-wrap;color:var(--text-dim);margin-top:0.75rem;
}
.output-panel .ok{color:var(--success)}.output-panel .err{color:var(--danger)}.output-panel .info{color:var(--accent)}
.flex-1{flex:1}.mt-1{margin-top:0.5rem}.mt-2{margin-top:1rem}.mb-1{margin-bottom:0.5rem}
.text-dim{color:var(--text-dim);font-size:0.75rem}
.refresh-indicator{font-size:0.7rem;color:var(--text-dim)}
.refresh-indicator::before{content:"";display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--success);margin-right:0.4rem;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* Modal */
.modal-overlay{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:200;
  justify-content:center;align-items:center;backdrop-filter:blur(4px);
}
.modal-overlay.active{display:flex}
.modal{
  background:var(--bg);border:1px solid var(--border-active);border-radius:var(--radius);
  padding:2rem;width:520px;max-width:92vw;max-height:85vh;overflow-y:auto;
  box-shadow:0 0 60px rgba(56,189,248,0.08);
}
.modal h3{font-size:1.1rem;color:var(--text-bright);margin-bottom:1.25rem;display:flex;align-items:center;gap:0.5rem}
.modal .detail-row{display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid var(--border);font-size:0.85rem}
.modal .detail-label{color:var(--text-dim)}
.modal .detail-value{color:var(--text-bright);font-weight:500}
.modal .detail-tags{display:flex;flex-wrap:wrap;gap:0.3rem;margin-top:0.75rem}
.modal-close{
  position:absolute;top:1rem;right:1rem;background:none;border:none;color:var(--text-dim);
  font-size:1.5rem;cursor:pointer;padding:0.25rem 0.5rem;border-radius:6px;
}
.modal-close:hover{color:var(--text-bright);background:var(--glass-hover)}

/* Auto-detect result */
.auto-detect-result{
  background:rgba(0,0,0,0.3);border:1px solid var(--border);border-radius:var(--radius-sm);
  padding:0.75rem;margin-top:0.5rem;font-size:0.75rem;display:none;
}
.auto-detect-result.active{display:block}
.auto-detect-result .detect-name{color:var(--accent);font-weight:600}
.auto-detect-result .detect-type{color:var(--text-dim);font-size:0.7rem}

.advanced-toggle{cursor:pointer;color:var(--text-dim);font-size:0.7rem;padding:0.25rem 0;user-select:none;display:flex;align-items:center;gap:0.3rem}
.advanced-toggle:hover{color:var(--accent)}
.advanced-toggle .arrow{transition:transform 0.2s;font-size:0.6rem}
.advanced-toggle.open .arrow{transform:rotate(90deg)}
.advanced-panel{display:none;padding:0.5rem 0;border-top:1px solid var(--border);margin-top:0.25rem}
.advanced-panel.active{display:block}
select.protocol-select{background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.45rem 0.75rem;font-size:0.8rem;width:100%}
select.protocol-select:focus{outline:none;border-color:var(--border-active)}
textarea.mono-input{font-family:"SF Mono","Fira Code",monospace;font-size:0.7rem;background:rgba(0,0,0,0.3);color:var(--text);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.5rem;width:100%;resize:vertical;min-height:48px}
textarea.mono-input:focus{outline:none;border-color:var(--border-active)}
.form-inline-2{display:flex;gap:0.5rem;align-items:flex-end}
.form-inline-2 .form-group{flex:1;min-width:0}

@media(max-width:1000px){.grid{grid-template-columns:1fr}}
.topology-container{display:flex;justify-content:center;align-items:center;padding:0.5rem 0}
#topology-svg line{stroke:rgba(255,255,255,0.08);stroke-width:1.5}
#topology-svg circle.hub{fill:var(--bg);stroke:var(--accent);stroke-width:3}
#topology-svg text.hub-label{fill:var(--text-bright);font-size:14px;font-weight:600;text-anchor:middle}
#topology-svg circle.spoke{stroke-width:2;fill:var(--bg)}
#topology-svg circle.spoke.unhealthy{stroke-dasharray:4 3}
#topology-svg text.spoke-label{fill:var(--text);font-size:10px;text-anchor:middle}
.topology-legend{display:flex;gap:1rem;justify-content:center;margin-top:0.5rem;flex-wrap:wrap}
.legend-item{display:flex;align-items:center;gap:0.3rem;font-size:0.7rem;color:var(--text-dim)}
.legend-dot{width:8px;height:8px;border-radius:50%}
</style>
</head>
<body>

<header>
  <div class="brand">
    <div class="logo">🏛</div>
    <h1>Agora 服务中心</h1>
    <span class="version">v1.5</span>
  </div>
  <div class="stats-bar">
    <div class="stat-item"><span class="stat-dot ok"></span> 已注册 <span class="stat-value" id="svc-total">-</span></div>
    <div class="stat-item"><span class="stat-dot ok"></span> 健康 <span class="stat-value" id="svc-healthy">-</span></div>
    <div class="stat-item refresh-indicator" id="refresh-time"></div>
  </div>
</header>

<main>
<div class="grid">
  <!-- 服务列表 -->
  <div class="card" style="grid-row:span 2">
    <div class="card-header">
      <h2>🔌 已注册服务</h2>
      <span class="card-badge live" id="svc-live-badge">运行中</span>
    </div>
    <table>
      <thead><tr><th>名称</th><th>协议</th><th>断路器</th><th>失败</th><th>标签</th></tr></thead>
      <tbody id="svc-table">
        <tr><td colspan="5"><div class="empty-state"><div class="empty-icon">📡</div>暂无服务 — 点击「发现服务」</div></td></tr>
      </tbody>
    </table>
  </div>

  <!-- 操作面板 -->
  <div class="card">
    <div class="card-header">
      <h2>⚡ 快捷操作</h2>
    </div>
    <div class="action-bar">
      <button type="button" class="btn-primary" onclick="discover()">🔍 发现服务</button>
      <button type="button" class="btn-ghost" onclick="healthCheck()">🫀 健康检查</button>
      <button type="button" class="btn-danger" onclick="clearAll()">清空全部</button>
    </div>
    <div class="output-panel" id="action-output">就绪。</div>
  </div>

  <!-- 注册服务 -->
  <div class="card">
    <div class="card-header">
      <h2>📋 注册服务</h2>
    </div>
    <div class="form-group mb-1">
      <label>服务地址或路径</label>
      <input type="text" id="reg-addr" placeholder="http://localhost:8765 或 /path/to/project 或 stdio://my-svc" oninput="autoDetect()">
    </div>
    <div class="auto-detect-result" id="detect-result">
      <span class="detect-name" id="detect-name"></span>
      <span class="detect-type" id="detect-type"></span>
    </div>
    <div class="form-group mb-1">
      <label>名称（自动识别或手动填写）</label>
      <input type="text" id="reg-name" placeholder="自动识别中...">
    </div>
    <div class="form-group mb-1">
      <label>协议</label>
      <select class="protocol-select" id="reg-protocol">
        <option value="mcp">MCP（默认）</option>
        <option value="rest">REST API</option>
        <option value="grpc">gRPC</option>
        <option value="stdio">stdio 命令行</option>
        <option value="websocket">WebSocket</option>
      </select>
    </div>
    <div class="form-group mb-1">
      <label>标签（逗号分隔）</label>
      <input type="text" id="reg-tags" placeholder="research, knowledge">
    </div>
    <!-- 高级选项 -->
    <span class="advanced-toggle" onclick="toggleAdvanced()">
      <span class="arrow">▶</span> 高级选项（协议配置）
    </span>
    <div class="advanced-panel" id="advanced-panel">
      <div class="form-group mb-1">
        <label>协议配置（JSON）</label>
        <textarea class="mono-input" id="reg-protocol-config" placeholder='{"method":"GET","headers":{"Authorization":"Bearer xxx"}}'></textarea>
      </div>
    </div>
    <button type="button" class="btn-primary" onclick="registerSvc()" style="width:100%">注册</button>
  </div>
</div>

<!-- 服务拓扑图 -->
<div class="card" style="grid-column:1/-1">
  <div class="card-header">
    <h2>🔗 服务拓扑</h2>
    <span class="card-badge live" id="topo-badge">0 spokes</span>
  </div>
  <div class="topology-container">
    <svg id="topology-svg" viewBox="-400 -300 800 600" style="width:100%;max-height:450px">
      <title>Agora 服务拓扑图</title>
      <!-- Hub-Spoke 在这里动态渲染 -->
    </svg>
  </div>
  <div class="topology-legend">
    <span class="legend-item"><span class="legend-dot" style="background:var(--accent)"></span>MCP</span>
    <span class="legend-item"><span class="legend-dot" style="background:var(--success)"></span>REST</span>
    <span class="legend-item"><span class="legend-dot" style="background:var(--warning)"></span>gRPC</span>
    <span class="legend-item"><span class="legend-dot" style="background:#a78bfa"></span>stdio</span>
    <span class="legend-item"><span class="legend-dot" style="background:var(--danger)"></span>WS</span>
  </div>
</div>

<!-- Pipeline + 事件日志 -->
<div class="grid">
  <div class="card">
    <div class="card-header">
      <h2>🚀 流水线执行</h2>
    </div>
    <div class="form-row mb-1">
      <select id="pl-name" class="flex-1">
        <option>full-pipeline</option><option>match-derive</option><option>research-derive</option><option>derive-check</option>
      </select>
    </div>
    <div class="form-group mb-1">
      <label>目标</label>
      <input type="text" id="pl-goal" value="分析新能源汽车市场">
    </div>
    <div class="form-row mb-1">
      <div class="form-group flex-1"><label>上下文</label><input type="text" id="pl-context" value="竞争,政策"></div>
      <div class="form-group flex-1"><label>项目路径</label><input type="text" id="pl-project" value="."></div>
    </div>
    <div class="form-inline">
      <button type="button" class="btn-primary" onclick="runPipeline('sequential')">▶ 执行</button>
      <button type="button" class="btn-ghost" onclick="runPipeline('parallel')">⚡ 并行</button>
      <button type="button" class="btn-ghost" onclick="runPipeline('stream')">📡 流式</button>
    </div>
    <div class="output-panel" id="pipeline-output">流水线输出 →</div>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>📡 事件日志</h2>
      <button type="button" class="btn-ghost" style="padding:0.3rem 0.6rem;font-size:0.7rem" onclick="loadEvents()">↻ 刷新</button>
    </div>
    <div class="output-panel" id="event-output" style="max-height:200px">加载中...</div>
    <div class="form-inline mt-1">
      <input type="text" id="evt-type" placeholder="事件类型" class="flex-1" style="font-size:0.75rem;padding:0.4rem 0.6rem">
      <input type="text" id="evt-payload" placeholder='{"key":"val"}' style="font-size:0.75rem;padding:0.4rem 0.6rem;width:140px">
      <button type="button" class="btn-primary" onclick="publishEvent()" style="font-size:0.75rem;padding:0.4rem 0.8rem">发布</button>
    </div>
  </div>
</div>

<!-- 最近研究 -->
<div class="card" style="grid-column:1/-1">
  <div class="card-header">
    <h2>📚 研究对象</h2>
    <button type="button" class="btn-ghost" style="padding:0.3rem 0.6rem;font-size:0.7rem" onclick="loadResearch()">↻ 刷新</button>
  </div>
  <div class="form-inline" style="margin-bottom:0.75rem">
    <div class="form-group flex-1">
      <input type="search" id="research-search" placeholder="搜索研究..." style="padding:0.4rem 0.6rem;font-size:0.82rem"
        onkeydown="if(event.key==='Enter')searchResearch()">
    </div>
    <select id="research-status-filter" onchange="loadResearch()">
      <option value="active">活跃</option>
      <option value="all">全部</option>
      <option value="archived">已归档</option>
      <option value="quarantined">已隔离</option>
    </select>
    <input type="text" id="research-tag-filter" placeholder="标签筛选..." style="padding:0.4rem 0.5rem;font-size:0.82rem;width:100px"
      onkeydown="if(event.key==='Enter')searchResearch()">
    <button type="button" class="btn-primary" onclick="searchResearch()" style="padding:0.4rem 0.7rem;font-size:0.8rem">🔍 搜索</button>
  </div>
  <table>
    <thead><tr><th>ID</th><th>主题</th><th>摘要</th><th>来源</th><th>日期</th></tr></thead>
    <tbody id="research-table">
      <tr><td colspan="5"><div class="empty-state"><div class="empty-icon">🔬</div>暂无研究记录 — 试试 <code>workspace research</code></div></td></tr>
    </tbody>
  </table>
</div>

<div class="card" style="grid-column:1/-1">
  <div class="card-header">
    <h2>🧾 研究详情</h2>
    <span class="card-badge">研究时间线 · 发布产物</span>
  </div>
  <div class="text-dim" style="font-size:0.9rem">
    点击上方研究记录可查看研究详情、研究时间线、发布产物。
  </div>
</div>

<!-- 服务详情弹出层 -->
<div class="modal-overlay" id="detail-modal">
  <div class="modal" id="detail-content"></div>
</div>

</main>

<script>
const API = '/api';
let allServices = [];

function escapeHtml(value){
  return String(value ?? '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
}

function formatResearchSnippet(value){
  const escaped = escapeHtml((value || '').slice(0, 160));
  return escaped
    .replace(/&lt;mark&gt;/g, '<mark>')
    .replace(/&lt;\/mark&gt;/g, '</mark>');
}

function formatDate(value){
  if(!value) return '—';
  return new Date(value*1000).toLocaleString('zh-CN');
}

function circuitName(s){
  if(s==='CLOSED') return '正常';
  if(s==='OPEN') return '断路';
  if(s==='HALF_OPEN') return '半开';
  return s;
}
function protocolName(p){
  const m = {mcp:'MCP', rest:'REST', grpc:'gRPC', stdio:'stdio', websocket:'WS'};
  return m[p]||p||'mcp';
}

let _lastServices = '';
async function refresh(){
  try{
    const r = await fetch(API+'/services');
    const data = await r.json();
    const snapshot = JSON.stringify(data);
    if (snapshot === _lastServices) return;  // no change, skip DOM rebuild
    _lastServices = snapshot;
    allServices = data;
    const healthy = allServices.filter(s=>s.circuit==='CLOSED').length;
    document.getElementById('svc-total').textContent = allServices.length;
    document.getElementById('svc-healthy').textContent = healthy;
    document.getElementById('refresh-time').textContent = new Date().toLocaleTimeString('zh-CN');

    const badge = document.getElementById('svc-live-badge');
    if(allServices.length===0){badge.textContent='空';badge.className='card-badge'}
    else{badge.textContent= healthy===allServices.length ? '运行中' : `${healthy}/${allServices.length}`;badge.className='card-badge live'}

