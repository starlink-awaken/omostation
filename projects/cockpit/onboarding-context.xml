// Auto-detect service from URL/path
let detectTimer;
function autoDetect(){
  clearTimeout(detectTimer);
  detectTimer = setTimeout(async ()=>{
    const addr = document.getElementById('reg-addr').value.trim();
    if(!addr){document.getElementById('detect-result').classList.remove('active');return}
    const result = document.getElementById('detect-result');
    const nameEl = document.getElementById('detect-name');
    const typeEl = document.getElementById('detect-type');
    result.classList.add('active');
    nameEl.textContent = '🔍 识别中...';
    typeEl.textContent = '';

    let detected = null;
    if(addr.startsWith('http://')||addr.startsWith('https://')){
      const u = new URL(addr); const host = u.hostname; const port = u.port||'80';
      const parts = u.pathname.split('/').filter(Boolean);
      const isMCP = addr.endsWith('/mcp');
      detected = {name:host+(port!=='80'?'-'+port:''), type:isMCP?'HTTP MCP 服务':'HTTP 服务', endpoint:addr, health:addr.replace(/\/mcp$/,'')+'/health', protocol:isMCP?'mcp':'rest'};
    }else if(addr.startsWith('stdio://')){
      const name = addr.replace('stdio://','');
      detected = {name:name, type:'标准输入输出', endpoint:addr, protocol:'stdio'};
    }else if(addr.startsWith('/')||addr.startsWith('~')||addr.startsWith('.')){
      const parts = addr.replace(/^~\/|^\.\//,'').split('/').filter(Boolean);
      detected = {name:parts[parts.length-1]||parts[0]||'project', type:'本地项目', endpoint:'stdio://'+ (parts[parts.length-1]||parts[0]), protocol:'stdio'};
    }else{
      detected = {name:addr, type:'未知类型', endpoint:'stdio://'+addr, protocol:'stdio'};
    }

    nameEl.textContent = '📦 ' + detected.name;
    typeEl.textContent = (detected.type||'') + ' · ' + (detected.protocol||'mcp').toUpperCase();
    document.getElementById('reg-name').value = detected.name;
    document.getElementById('reg-name').dataset.endpoint = detected.endpoint||'';
    if(detected.protocol) document.getElementById('reg-protocol').value = detected.protocol;
  }, 500);
}

