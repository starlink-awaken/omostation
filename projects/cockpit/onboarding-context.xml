        "- `workspace research --list`",
        "- `workspace research --timeline <ID>`",
    ]
    if missing:
        lines.insert(2, f"[yellow]未找到这些研究 ID: {', '.join(str(item) for item in missing)}[/yellow]")
    _get_console().print(_panel("\n".join(lines), "green"))
    return 0


