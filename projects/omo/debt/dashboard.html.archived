{"id": "SB_ROOT_CLEANUP", "title": "Root SharedBrain shell cleanup remains deferred", "dimension": "architecture", "subdimension": "residual_surface", "domain": "workspace", "scope": "cross_project", "severity": "low", "weight": 0.05, "entropy_class": "classification", "lifecycle_state": "closed", "owner": "sharedbrain-governance", "affected_roots": ["projects/SharedBrain", ".omo/tasks/active"], "evidence_refs": [".omo/_knowledge/design/sharedbrain-decomposition-architecture.md", ".omo/_knowledge/design/debt-cleanup-plan.md"], "mitigation_refs": [".omo/tasks/active/SHAREDBRAIN-FORMAL-DECISION.yaml"], "opened_at": "2026-06-01T10:30:00Z", "last_reviewed_at": "2026-06-03T00:00:00Z", "next_review_at": null, "gate_level": "none", "history": [{"at": "2026-06-03T00:00:00Z", "action": "close", "note": "SharedBrain root shell cleanup verified: organs/ directory contains only residual metadata (INDEX.md, AGENTS.md). Business logic fully migrated to kairon packages. lifecycle_state corrected from 'resolved' to 'closed' for sync script compatibility."}, {"at": "2026-06-03T00:00:00Z", "action": "resolve", "note": "SharedBrain README.md and AGENTS.md updated to reflect post-decomposition architecture. All business logic references point to kairon packages. organs/ directory empty (contents archived to _archived/organs/)."}, {"at": "2026-06-02T00:00:00Z", "action": "register", "note": "Seeded from the SharedBrain cleanup backlog without copying implementation state."}], "x3_tier": "Framework", "x1_policy_refs": ["X1-AUDIT-001", "X1-TRUST-001"], "x2_rules": ["X2-LIFECYCLE-001", "X2-LIFECYCLE-002"], "x2_freshness": ""}, {"id": "X1-NO_AUDIT_CHAIN", "title": "无实际操作审计链 — MCP 工具调用无日志记录", "dimension": "governance_process", "subdimension": "security", "domain": ".omo", "scope": "governance_kernel", "severity": "low", "weight": 0.2, "entropy_class": "behavior", "lifecycle_state": "resolved", "owner": "omo-governance", "affected_roots": ["~/Workspace/projects/runtime/", ".omo/"], "evidence_refs": [".omo/_knowledge/management/ecos-layer-audit-2026-06-05.md"], "mitigation_refs": [], "opened_at": "2026-06-05T21:00:00Z", "last_reviewed_at": null, "next_review_at": null, "gate_level": "phase17", "history": [{"at": "2026-06-05T21:00:00Z", "action": "register", "note": "Debt registered from Layer Audit 2026-06-05."}], "x3_tier": "Principle", "x1_policy_refs": ["X1-AUDIT-001", "X1-AUDIT-002", "X1-CONST-001", "X1-TRUST-001"], "x2_rules": ["X2-LIFECYCLE-002"], "x2_freshness": ""}, {"id": "X2-NO_FRESHNESS", "title": "无保鲜机制 — 所有服务无 age/freshness 追踪，无自动恢复逻辑", "dimension": "governance_process", "subdimension": "anti_entropy", "domain": "workspace", "scope": "governance_kernel", "severity": "low", "weight": 0.3, "entropy_class": "behavior", "lifecycle_state": "resolved", "owner": "omo-governance", "affected_roots": ["~/Workspace/projects/runtime/"], "evidence_refs": [".omo/_knowledge/management/ecos-layer-audit-2026-06-05.md"], "mitigation_refs": [], "opened_at": "2026-06-05T21:00:00Z", "last_reviewed_at": null, "next_review_at": null, "gate_level": "phase17", "history": [{"at": "2026-06-05T21:00:00Z", "action": "register", "note": "Debt registered from Layer Audit 2026-06-05."}], "x3_tier": "Principle", "x1_policy_refs": ["X1-AUDIT-001", "X1-TRUST-001"], "x2_rules": ["X2-LIFECYCLE-002"], "x2_freshness": ""}, {"id": "X3-NO_COSTING", "title": "无成本核算 — _STATS 计数器定义在 mcp_server.py 中但从未递增", "dimension": "governance_process", "subdimension": "cost_accounting", "domain": "workspace", "scope": "governance_kernel", "severity": "low", "weight": 0.2, "entropy_class": "behavior", "lifecycle_state": "resolved", "owner": "omo-governance", "affected_roots": ["~/Workspace/projects/runtime/src/runtime/mcp_server.py"], "evidence_refs": [".omo/_knowledge/management/ecos-layer-audit-2026-06-05.md"], "mitigation_refs": [], "opened_at": "2026-06-05T21:00:00Z", "last_reviewed_at": null, "next_review_at": null, "gate_level": "phase17", "history": [{"at": "2026-06-05T21:00:00Z", "action": "register", "note": "Debt registered from Layer Audit 2026-06-05."}], "x3_tier": "Principle", "x1_policy_refs": ["X1-AUDIT-001", "X1-TRUST-001"], "x2_rules": ["X2-LIFECYCLE-002"], "x2_freshness": ""}];
const TIERS = [{"id": "Axiom", "color": "#c084fc", "weight": 2.0, "half_life": "50 years"}, {"id": "Principle", "color": "#818cf8", "weight": 1.5, "half_life": "8 years"}, {"id": "Theory", "color": "#38bdf8", "weight": 1.5, "half_life": "20 years"}, {"id": "Framework", "color": "#4ade80", "weight": 1.2, "half_life": "4 years"}, {"id": "Knowledge", "color": "#fbbf24", "weight": 1.0, "half_life": "2 years"}, {"id": "Skill", "color": "#fb923c", "weight": 0.8, "half_life": "9 months"}, {"id": "Tool", "color": "#f87171", "weight": 0.6, "half_life": "3 months"}];
const POLICIES = [{"id": "X1-AUDIT-001", "name": "\u5ba1\u8ba1\u5b8c\u6574\u6027", "category": "audit", "level": "mandatory"}, {"id": "X1-AUDIT-002", "name": "\u6743\u9650\u6700\u5c0f\u5316", "category": "authorization", "level": "mandatory"}, {"id": "X1-AUTH-001", "name": "\u8eab\u4efd\u8ffd\u8e2a", "category": "identity", "level": "advisory"}, {"id": "X1-TRUST-001", "name": "\u6cbb\u7406\u94fe\u5b8c\u6574\u6027", "category": "trust", "level": "advisory"}, {"id": "X1-CONST-001", "name": "\u5baa\u6cd5\u9075\u4ece", "category": "constitution", "level": "mandatory"}];
const RULES = [{"id": "X2-FRESH-001", "name": "\u670d\u52a1\u4fdd\u9c9c", "category": "freshness", "interval": "30 days"}, {"id": "X2-FRESH-002", "name": "\u77e5\u8bc6\u4fdd\u9c9c", "category": "freshness", "interval": "7 days"}, {"id": "X2-LIFECYCLE-001", "name": "\u95f2\u7f6e\u9000\u5f79", "category": "lifecycle", "interval": "30 days"}, {"id": "X2-LIFECYCLE-002", "name": "\u503a\u52a1\u534a\u8870\u671f", "category": "lifecycle", "interval": "N/A"}];
const TIER_COUNTS = {"Axiom": {"count": 0, "color": "#c084fc"}, "Principle": {"count": 7, "color": "#818cf8"}, "Theory": {"count": 1, "color": "#38bdf8"}, "Framework": {"count": 10, "color": "#4ade80"}, "Knowledge": {"count": 3, "color": "#fbbf24"}, "Skill": {"count": 3, "color": "#fb923c"}, "Tool": {"count": 1, "color": "#f87171"}};
const POLICY_COUNTS = {"X1-AUDIT-001": {"name": "\u5ba1\u8ba1\u5b8c\u6574\u6027", "count": 12, "category": "audit", "level": "mandatory"}, "X1-AUDIT-002": {"name": "\u6743\u9650\u6700\u5c0f\u5316", "count": 11, "category": "authorization", "level": "mandatory"}, "X1-AUTH-001": {"name": "\u8eab\u4efd\u8ffd\u8e2a", "count": 1, "category": "identity", "level": "advisory"}, "X1-TRUST-001": {"name": "\u6cbb\u7406\u94fe\u5b8c\u6574\u6027", "count": 11, "category": "trust", "level": "advisory"}, "X1-CONST-001": {"name": "\u5baa\u6cd5\u9075\u4ece", "count": 12, "category": "constitution", "level": "mandatory"}};
const RULE_COUNTS = {"X2-FRESH-001": {"name": "\u670d\u52a1\u4fdd\u9c9c", "count": 1, "category": "freshness"}, "X2-FRESH-002": {"name": "\u77e5\u8bc6\u4fdd\u9c9c", "count": 1, "category": "freshness"}, "X2-LIFECYCLE-001": {"name": "\u95f2\u7f6e\u9000\u5f79", "count": 15, "category": "lifecycle"}, "X2-LIFECYCLE-002": {"name": "\u503a\u52a1\u534a\u8870\u671f", "count": 25, "category": "lifecycle"}};
const SEV_COLORS = {"critical": "#f87171", "high": "#fb923c", "medium": "#fbbf24", "low": "#a3e635"};

// Populate tier chart
function renderTierChart() {
  const chart = document.getElementById('tierChart');
  const maxCount = Math.max(1, ...Object.values(TIER_COUNTS).map(t => t.count));
  chart.innerHTML = '';
  TIERS.forEach(tier => {
    const tc = TIER_COUNTS[tier.id] || {count: 0, color: tier.color};
    const pct = (tc.count / maxCount) * 100;
    const bar = document.createElement('div');
    bar.className = 'tier-bar';
    bar.innerHTML = `
      <div class="tier-bar-inner" style="height:${pct}%;background:${tier.color};">
        <div class="count" style="color:${tier.color}">${tc.count}</div>
      </div>
      <div class="tier-label">${tier.id}<br><span style="font-size:10px;opacity:0.6">×${tier.weight}</span></div>
    `;
    chart.appendChild(bar);
  });
}

// Populate policy grid
function renderPolicyGrid() {
  const grid = document.getElementById('policyGrid');
  const maxCount = Math.max(1, ...Object.values(POLICY_COUNTS).map(p => p.count));
  grid.innerHTML = '';
  POLICIES.forEach(p => {
    const pc = POLICY_COUNTS[p.id] || {count: 0, name: p.name, category: p.category, level: p.level};
    const pct = (pc.count / maxCount) * 100;
    const card = document.createElement('div');
    card.className = 'policy-card';
    card.innerHTML = `
      <div class="pol-id">${p.id}</div>
      <div class="pol-name">${pc.name}</div>
      <div class="pol-meta">${pc.category} · ${pc.level}</div>
      <div class="pol-count" style="color:${pc.count > 0 ? '#38bdf8' : '#64748b'}">${pc.count} debts</div>
      <div class="policy-bar-wrap"><div class="policy-bar-fill" style="width:${pct}%;background:${pc.count > 0 ? '#38bdf8' : '#64748b'}"></div></div>
    `;
    grid.appendChild(card);
  });
}

// Populate X2 grid
function renderX2Grid() {
  const grid = document.getElementById('x2Grid');
  grid.innerHTML = '';
  RULES.forEach(r => {
    const rc = RULE_COUNTS[r.id] || {count: 0, name: r.name, category: r.category};
    const card = document.createElement('div');
    card.className = 'x2-card';
    card.innerHTML = `
      <div class="x2-id">${r.id}</div>
      <div class="x2-name">${rc.name}</div>
      <div class="x2-count">${rc.count} debts</div>
      <div style="font-size:10px;color:var(--text-muted);margin-top:2px">${rc.category}</div>
    `;
    grid.appendChild(card);
  });
}

// Render debt table
function renderTable(items) {
  const body = document.getElementById('debtTableBody');
  body.innerHTML = '';
  items.forEach(d => {
    const sevColor = SEV_COLORS[d.severity] || '#94a3b8';
    const tier = TIERS.find(t => t.id === d.x3_tier) || {color: '#94a3b8', id: d.x3_tier || '?'};
    const isClosed = d.lifecycle_state === 'closed';
    const policies = (d.x1_policy_refs || []).map(p => `<span class="badge-policy">${p}</span>`).join('');

    const row = document.createElement('tr');
    row.className = isClosed ? 'row-closed' : '';
    const freshness = d.x2_freshness || '';
    row.innerHTML = `
      <td class="id-cell">${d.id}</td>
      <td class="title-cell">${d.title || d.id}</td>
      <td><span class="badge-sev" style="background:${sevColor}22;color:${sevColor}">${d.severity||'?'}</span></td>
      <td><span class="badge-tier" style="background:${tier.color}22;color:${tier.color}">${tier.id}</span></td>
      <td class="policy-cell">${policies}</td>
      <td><span class="badge-state-${d.lifecycle_state||'open'}">${d.lifecycle_state||'open'}</span></td>
      <td style="font-size:11px;color:var(--text-muted)">${freshness ? freshness.slice(0,10) : '—'}</td>
      <td style="font-size:11px;color:var(--text-muted)">${d.dimension||''}</td>
    `;
    body.appendChild(row);
  });
  document.getElementById('filterCount').textContent = `Showing ${items.length} of ${DEBTS.length} items`;
}

// Populate filter dropdowns
function populateFilters() {
  const sevSet = new Set(); const tierSet = new Set(); const polSet = new Set();
  DEBTS.forEach(d => {
    if (d.severity) sevSet.add(d.severity);
    if (d.x3_tier) tierSet.add(d.x3_tier);
    (d.x1_policy_refs || []).forEach(p => polSet.add(p));
  });

  const sev = document.getElementById('filterSeverity');
  ['critical','high','medium','low'].forEach(s => {
    if (sevSet.has(s)) { const o = document.createElement('option'); o.value=s; o.textContent=s.charAt(0).toUpperCase()+s.slice(1); sev.appendChild(o); }
  });

  const tier = document.getElementById('filterTier');
  TIERS.forEach(t => {
    if (tierSet.has(t.id)) { const o = document.createElement('option'); o.value=t.id; o.textContent=t.id; tier.appendChild(o); }
  });

  const pol = document.getElementById('filterPolicy');
  [...polSet].sort().forEach(p => { const o = document.createElement('option'); o.value=p; o.textContent=p; pol.appendChild(o); });
}

// Apply filters
function applyFilters() {
  const sev = document.getElementById('filterSeverity').value;
  const tier = document.getElementById('filterTier').value;
  const pol = document.getElementById('filterPolicy').value;
  const state = document.getElementById('filterState').value;
  const lens = document.getElementById('filterLens').value;

  let filtered = DEBTS.filter(d => {
    if (sev && d.severity !== sev) return false;
    if (tier && d.x3_tier !== tier) return false;
    if (pol && !(d.x1_policy_refs || []).includes(pol)) return false;
    if (state && d.lifecycle_state !== state) return false;
    if (lens === 'X1' && (!d.x1_policy_refs || d.x1_policy_refs.length === 0)) return false;
    if (lens === 'X2' && !d.x2_freshness) return false;
    if (lens === 'X3' && !d.x3_tier) return false;
    return true;
  });
  renderTable(filtered);
}

// Init
renderTierChart();
renderPolicyGrid();
renderX2Grid();
populateFilters();
renderTable(DEBTS);
</script>
</body>
</html>