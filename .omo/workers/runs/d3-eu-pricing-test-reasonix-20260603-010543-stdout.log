            agent_id="agent-e", operation="MEMBRANE_CROSS"
        )
        assert result["success"] is True
        assert result["amount"] == 0.5  # TAX_RATES["MEMBRANE_CROSS"]

    def test_deduct_usage_unknown_operation_default_tax(self):
        """deduct_usage with unknown operation should use TAX_RATE_DEFAULT."""
        result = self.ledger.deduct_usage(
            agent_id="agent-f", operation="UNKNOWN_OP"
        )
        assert result["success"] is True
        assert result["amount"] == 1.0  # TAX_RATE_DEFAULT

    def test_deduct_usage_with_dynamic_pricing(self, monkeypatch):
        """deduct_usage with apply_dynamic_pricing should use market multiplier."""
        # NOTE: deduct_usage imports get_market_analyzer from eu_pricing.market
        # inside its function body, so the monkeypatch must target that module.
        import eu_pricing.market as _mkt_mod

        monkeypatch.setattr(
            _mkt_mod,
            "get_market_analyzer",
            lambda: type("MockAnalyzer", (), {"get_current_multiplier": lambda self: 2.0})(),
        )
