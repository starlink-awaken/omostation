class TestIdempotencyManagerKey:
    """Tests for IdempotencyManager._make_key deterministic behavior."""

    def test_same_input_same_key(self):
        manager = IdempotencyManager(persist_dir="/tmp")
        k1 = manager._make_key("trace-abc", 10.0)
        k2 = manager._make_key("trace-abc", 10.0)
        assert k1 == k2
        assert len(k1) == 16  # sha256 hex[:16]

    def test_different_trace_different_key(self):
        manager = IdempotencyManager(persist_dir="/tmp")
        k1 = manager._make_key("trace-1", 10.0)
        k2 = manager._make_key("trace-2", 10.0)
        assert k1 != k2

    def test_different_amount_different_key(self):
        manager = IdempotencyManager(persist_dir="/tmp")
        k1 = manager._make_key("trace-abc", 10.0)
        k2 = manager._make_key("trace-abc", 20.0)
        assert k1 != k2


