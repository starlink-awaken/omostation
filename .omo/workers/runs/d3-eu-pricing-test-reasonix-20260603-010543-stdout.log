class TestEnergyLedgerInit:
    """Tests for EnergyLedger initialization."""

    def test_init_with_memory_db(self):
        """EnergyLedger should initialize with :memory: database."""
        ledger = EnergyLedger(db_path=":memory:")
        try:
            assert ledger.status == "active"
        finally:
            ledger.close()

    def test_init_with_default_balance(self):
        """Initial balance should be 100,000.0 after initialization."""
        ledger = EnergyLedger(db_path=":memory:")
        try:
            assert ledger.get_balance() == 100_000.0
        finally:
            ledger.close()

    def test_init_sets_default_mode(self):
        """Default metabolic mode should be STRICT."""
        ledger = EnergyLedger(db_path=":memory:")
        try:
            assert ledger.mode == MetabolicMode.STRICT
        finally:
            ledger.close()

    def test_init_with_advisory_mode(self, monkeypatch):
        """ADVISORY mode should be set via environment variable."""
        monkeypatch.setenv("BOS_METABOLIC_MODE", "advisory")
        ledger = EnergyLedger(db_path=":memory:")
        try:
            assert ledger.mode == MetabolicMode.ADVISORY
        finally:
            ledger.close()

    def test_init_default_mode_strict(self):
        """Default metabolic mode with no env override should be STRICT."""
        # Our conftest sets BOS_METABOLIC_MODE=strict, so this should hold.
        import os

        assert os.environ.get("BOS_METABOLIC_MODE") == "strict"
        ledger = EnergyLedger(db_path=":memory:")
        try:
            assert ledger.mode == MetabolicMode.STRICT
        finally:
            ledger.close()


class TestEnergyLedgerBalance:
    """Tests for EnergyLedger balance operations."""

    def setup_method(self):
        self.ledger = EnergyLedger(db_path=":memory:")

    def teardown_method(self):
        self.ledger.close()

    def test_get_balance_after_init(self):
        """get_balance should return 100_000.0 after init."""
        assert self.ledger.get_balance() == 100_000.0

    def test_get_agent_balance_returns_balance(self):
        """get_agent_balance should return the ledger balance for a specific agent."""
        balance = self.ledger.get_agent_balance("@Prime")
        assert balance == 100_000.0

    def test_get_agent_balance_unknown_agent(self):
        """get_agent_balance for unknown agent should return 0."""
        balance = self.ledger.get_agent_balance("non_existent")
        assert balance == 0.0

    def test_get_all_balances(self):
        """get_all_balances should return all agent balances."""
        balances = self.ledger.get_all_balances()
        assert "@Prime" in balances
        assert balances["@Prime"] == 100_000.0

    def test_balances_after_deduct(self):
        """Balances should update after deduct_eu."""
        self.ledger.deduct_eu(agent_id="test-agent", operation="test_op", amount=50.0)
        balance = self.ledger.get_balance()
        assert balance == 100_000.0 - 50.0


class TestEnergyLedgerDeduct:
    """Tests for EnergyLedger deduction operations."""

    def setup_method(self):
        self.ledger = EnergyLedger(db_path=":memory:")

    def teardown_method(self):
        self.ledger.close()

    def test_deduct_eu_success(self):
        """deduct_eu should decrease balance and return success."""
        result = self.ledger.deduct_eu(agent_id="agent-a", operation="test", amount=30.0)
        assert result["success"] is True
        assert result["amount"] == 30.0
        assert self.ledger.get_balance() == 100_000.0 - 30.0

    def test_deduct_eu_starvation(self):
        """deduct_eu should raise InsufficientEnergyError when balance is too low."""
        with pytest.raises(InsufficientEnergyError):
            self.ledger.deduct_eu(agent_id="agent-b", operation="test", amount=200_000.0)

    def test_deduct_eu_emergency_eligible(self):
        """Emergency-eligible operations should bypass strict mode."""
        result = self.ledger.deduct_eu(
            agent_id="agent-c", operation="EVOLUTION_COMMIT", amount=200_000.0
        )
        assert result["success"] is True

    def test_deduct_usage_with_tokens(self):
        """deduct_usage with tokens should calculate cost based on tokens."""
        result = self.ledger.deduct_usage(
            agent_id="agent-d",
            operation="test",
            usage={"prompt_tokens": 100, "completion_tokens": 50},
            cost_per_token=***REDACTED***
        )
        assert result["success"] is True
        # total_tokens = 150, cost = 150 * 0.001 = 0.15
        assert result["amount"] == 0.15

    def test_deduct_usage_no_tokens_falls_back_to_tax_rate(self):
        """deduct_usage without tokens should use TAX_RATES lookup."""
        result = self.ledger.deduct_usage(
            agent_id="agent-e", operation="MEMBRANE_CROSS"
        )
        assert result["success"] is True
        assert result["amount"] == 0.5  # TAX_RATES["MEMBRANE_CROSS"]

    def test_deduct_usage_unknown_operation_default_tax(self):
        """deduct_usage with unknown operation should use TAX_RATE_DEFAULT."""
        result = self.ledger.deduct_usage(
            agent_id="agent-f", operation="UNKNOWN_OP"
        )
        assert result["success"] is True
        assert result["amount"] == 1.0  # TAX_RATE_DEFAULT

    def test_deduct_usage_with_dynamic_pricing(self, monkeypatch):
        """deduct_usage with apply_dynamic_pricing should use market multiplier."""
        # NOTE: deduct_usage imports get_market_analyzer from eu_pricing.market
        # inside its function body, so the monkeypatch must target that module.
        import eu_pricing.market as _mkt_mod

        monkeypatch.setattr(
            _mkt_mod,
            "get_market_analyzer",
            lambda: type("MockAnalyzer", (), {"get_current_multiplier": lambda self: 2.0})(),
        )
        result = self.ledger.deduct_usage(
            agent_id="agent-g", operation="test", usage={}, apply_dynamic_pricing=True
        )
        assert result["success"] is True
        # TAX_RATE_DEFAULT = 1.0 * multiplier 2.0 = 2.0
        assert result["amount"] == 2.0

    def test_deduct_usage_starvation(self):
        """deduct_usage should raise InsufficientEnergyError when insufficient."""
        with pytest.raises(InsufficientEnergyError):
            self.ledger.deduct_usage(
                agent_id="agent-h", operation="test", usage={"prompt_tokens": 100_000_000}
            )


class TestEnergyLedgerCredit:
    """Tests for EnergyLedger credit operations."""

    def setup_method(self):
        self.ledger = EnergyLedger(db_path=":memory:")

    def teardown_method(self):
        self.ledger.close()

    def test_credit_eu_increases_balance(self):
        """credit_eu should increase the balance."""
        result = self.ledger.credit_eu(amount=500.0, memo="test reward")
        assert result["success"] is True
        assert self.ledger.get_balance() == 100_500.0

    def test_grant_gc_incentive(self):
        """grant_gc_incentive should reward EU for purged records."""
        result = self.ledger.grant_gc_incentive(purged_count=200)
        assert result.get("status") != "skipped"
        expected_reward = 200.0 / 100.0
        # Balance: 100_000 + 2.0
        assert self.ledger.get_balance() == 100_000.0 + expected_reward

    def test_grant_gc_incentive_zero(self):
        """grant_gc_incentive with zero purged should be skipped."""
        result = self.ledger.grant_gc_incentive(purged_count=0)
        assert result["status"] == "skipped"
        assert result["reward"] == 0.0


