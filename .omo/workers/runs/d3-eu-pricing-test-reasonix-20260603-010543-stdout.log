class TestEnergyLedgerDeduct:
    """Tests for EnergyLedger deduction operations."""

    def setup_method(self):
        self.ledger = EnergyLedger(db_path=":memory:")

    def teardown_method(self):
        self.ledger.close()

    def test_deduct_eu_success(self):
        """deduct_eu should decrease balance and return success."""
        result = self.ledger.deduct_eu(agent_id="agent-a", operation="test", amount=30.0)
        assert result["success"] is True
        assert result["amount"] == 30.0
        assert self.ledger.get_balance() == 100_000.0 - 30.0

    def test_deduct_eu_starvation(self):
        """deduct_eu should raise InsufficientEnergyError when balance is too low."""
        with pytest.raises(InsufficientEnergyError):
            self.ledger.deduct_eu(agent_id="agent-b", operation="test", amount=200_000.0)

    def test_deduct_eu_emergency_eligible(self):
        """Emergency-eligible operations should bypass strict mode."""
        result = self.ledger.deduct_eu(
            agent_id="agent-c", operation="EVOLUTION_COMMIT", amount=200_000.0
        )
        assert result["success"] is True

    def test_deduct_usage_with_tokens(self):
        """deduct_usage with tokens should calculate cost based on tokens."""
        result = self.ledger.deduct_usage(
            agent_id="agent-d",
            operation="test",
            usage={"prompt_tokens": 100, "completion_tokens": 50},
            cost_per_token=***REDACTED***
        )
        assert result["success"] is True
        # total_tokens = 150, cost = 150 * 0.001 = 0.15
        assert result["amount"] == 0.15

    def test_deduct_usage_no_tokens_falls_back_to_tax_rate(self):
        """deduct_usage without tokens should use TAX_RATES lookup."""
        result = self.ledger.deduct_usage(
            agent_id="agent-e", operation="MEMBRANE_CROSS"
        )
        assert result["success"] is True
        assert result["amount"] == 0.5  # TAX_RATES["MEMBRANE_CROSS"]

    def test_deduct_usage_unknown_operation_default_tax(self):
        """deduct_usage with unknown operation should use TAX_RATE_DEFAULT."""
        result = self.ledger.deduct_usage(
            agent_id="agent-f", operation="UNKNOWN_OP"
        )
        assert result["success"] is True
        assert result["amount"] == 1.0  # TAX_RATE_DEFAULT

    def test_deduct_usage_with_dynamic_pricing(self, monkeypatch):
        """deduct_usage with apply_dynamic_pricing should use market multiplier."""
        # NOTE: deduct_usage imports get_market_analyzer from eu_pricing.market
        # inside its function body, so the monkeypatch must target that module.
        import eu_pricing.market as _mkt_mod

        monkeypatch.setattr(
            _mkt_mod,
            "get_market_analyzer",
            lambda: type("MockAnalyzer", (), {"get_current_multiplier": lambda self: 2.0})(),
        )
        result = self.ledger.deduct_usage(
            agent_id="agent-g", operation="test", usage={}, apply_dynamic_pricing=True
        )
        assert result["success"] is True
        # TAX_RATE_DEFAULT = 1.0 * multiplier 2.0 = 2.0
        assert result["amount"] == 2.0

    def test_deduct_usage_starvation(self):
        """deduct_usage should raise InsufficientEnergyError when insufficient."""
        with pytest.raises(InsufficientEnergyError):
            self.ledger.deduct_usage(
                agent_id="agent-h", operation="test", usage={"prompt_tokens": 100_000_000}
            )


