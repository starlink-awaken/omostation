class TestParseMemoField:
    """Tests for the standalone _parse_memo_field helper."""

    def test_extracts_provider(self):
        from eu_pricing.ledger import _parse_memo_field
        result = _parse_memo_field(
            "llm_call provider=anthropic model=claude-3 tokens=500", "provider"
        )
        assert result == "anthropic"

    def test_extracts_model(self):
        from eu_pricing.ledger import _parse_memo_field
        result = _parse_memo_field(
            "llm_call provider=openai model=gpt-4 tokens=300", "model"
        )
        assert result == "gpt-4"

    def test_extracts_tokens(self):
        from eu_pricing.ledger import _parse_memo_field
        result = _parse_memo_field(
            "llm_call provider=test model=m tokens=1500", "tokens"
        )
        assert result == "1500"

    def test_returns_none_for_missing_field(self):
        from eu_pricing.ledger import _parse_memo_field
        result = _parse_memo_field(
            "llm_call provider=test model=m tokens=1500", "cost"
        )
        assert result is None

    def test_returns_none_for_empty_memo(self):
        from eu_pricing.ledger import _parse_memo_field
        result = _parse_memo_field("", "provider")
        assert result is None


# =============================================================================
# IdempotencyManager — key generation
# =============================================================================


class TestIdempotencyManagerKey:
    """Tests for IdempotencyManager._make_key deterministic behavior."""

    def test_same_input_same_key(self):
        manager = IdempotencyManager(persist_dir="/tmp")
        k1 = manager._make_key("trace-abc", 10.0)
        k2 = manager._make_key("trace-abc", 10.0)
        assert k1 == k2
        assert len(k1) == 16  # sha256 hex[:16]

    def test_different_trace_different_key(self):
        manager = IdempotencyManager(persist_dir="/tmp")
        k1 = manager._make_key("trace-1", 10.0)
        k2 = manager._make_key("trace-2", 10.0)
        assert k1 != k2

    def test_different_amount_different_key(self):
        manager = IdempotencyManager(persist_dir="/tmp")
        k1 = manager._make_key("trace-abc", 10.0)
        k2 = manager._make_key("trace-abc", 20.0)
        assert k1 != k2


