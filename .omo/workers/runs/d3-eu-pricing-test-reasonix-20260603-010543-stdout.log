        assert summary["total_eu"] == 4.0
        assert summary["calls"] == 2
        assert "anthropic" in summary["by_provider"]
        assert "openai" in summary["by_provider"]

    def test_get_llm_cost_summary_no_calls(self):
        """get_llm_cost_summary with no calls should return zeros."""
        summary = self.ledger.get_llm_cost_summary(since_hours=24)
        assert summary["success"] is True
        assert summary["total_eu"] == 0.0
        assert summary["calls"] == 0


class TestEnergyLedgerHandleConsume:
    """Tests for internal _handle_consume logic."""

    def setup_method(self):
        self.ledger = EnergyLedger(db_path=":memory:")

    def teardown_method(self):
        self.ledger.close()

    def test_handle_consume_success(self):
        """_handle_consume should process a successful deduction."""
        result = self.ledger._handle_consume({
            "agent_id": "agent-x",
            "amount": 100.0,
            "operation": "TEST_OP",
        })
        assert result["success"] is True
        assert result["consumed"] == 100.0

    def test_handle_consume_starvation(self):
        """_handle_consume should return error on starvation."""
        result = self.ledger._handle_consume({
            "agent_id": "agent-y",
            "amount": 200_000.0,
            "operation": "TEST_OP",
        })
        assert result["success"] is False
        assert result["error_type"] == "STARVATION"

    def test_handle_consume_emergency_bypass(self):
        """_handle_consume with emergency op should bypass starvation."""
        result = self.ledger._handle_consume({
            "agent_id": "agent-z",
            "amount": 200_000.0,
            "operation": "EVOLUTION_COMMIT",
        })
        assert result["success"] is True

    def test_handle_consume_advisory_mode(self, monkeypatch):
        """In ADVISORY mode, insufficient balance should not raise."""
        monkeypatch.setenv("BOS_METABOLIC_MODE", "advisory")
        ledger = EnergyLedger(db_path=":memory:")
        try:
            result = ledger._handle_consume({
                "agent_id": "agent-w",
                "amount": 200_000.0,
                "operation": "TEST_OP",
            })
            assert result["success"] is True
            # Balance should be negative
            assert ledger.get_balance() < 0
        finally:
            ledger.close()

    def test_handle_consume_with_account_alias(self):
        """_handle_consume should accept 'account' as alias for agent_id."""
        result = self.ledger._handle_consume({
            "account": "agent-act",
            "amount": 25.0,
            "operation": "TEST_OP",
        })
        assert result["success"] is True
        assert result["consumed"] == 25.0

    def test_handle_consume_default_agent(self):
        """_handle_consume should use 'UNKNOWN' as default agent_id."""
        result = self.ledger._handle_consume({
            "amount": 5.0,
            "operation": "DEFAULT_OP",
        })
        assert result["success"] is True


