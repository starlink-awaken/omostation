        """_handle_consume should propagate ref_id as trace_id."""
        result = self.ledger._handle_consume({
            "agent_id": "agent-x",
            "amount": 10.0,
            "operation": "TEST",
            "ref_id": "my-trace",
        })
        assert result["ref_id"] == "my-trace"


class TestEnergyLedgerQueryByRef:
    """Tests for query_by_ref functionality."""

    def setup_method(self):
        self.ledger = EnergyLedger(db_path=":memory:")

    def teardown_method(self):
        self.ledger.close()

    def test_query_by_ref_no_ref(self):
        """query_by_ref without ref_id should return error."""
        result = self.ledger._handle_query_by_ref({})
        assert result["status"] == "error"

    def test_query_by_ref_with_consumption(self):
        """query_by_ref should return total consumed for a ref_id."""
        self.ledger.deduct_eu(agent_id="agent-r", operation="test", ref_id="ref-1", amount=10.0)
        self.ledger.deduct_eu(agent_id="agent-r", operation="test", ref_id="ref-1", amount=20.0)
        result = self.ledger._handle_query_by_ref({"ref_id": "ref-1"})
        assert result["status"] == "success"
        assert result["total_consumed"] == 30.0


