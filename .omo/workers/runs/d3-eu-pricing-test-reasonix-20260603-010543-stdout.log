        """deduct_usage with tokens should calculate cost based on tokens."""
        result = self.ledger.deduct_usage(
            agent_id="agent-d",
            operation="test",
            usage={"prompt_tokens": 100, "completion_tokens": 50},
            cost_per_token=***REDACTED***
        )
        assert result["success"] is True
        # total_tokens = 150, cost = 150 * 0.001 = 0.15
        assert result["amount"] == 0.15

    def test_deduct_usage_no_tokens_falls_back_to_tax_rate(self):
        """deduct_usage without tokens should use TAX_RATES lookup."""
