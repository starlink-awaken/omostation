import os
import time
from unittest.mock import patch

import pytest

from eu_pricing.ledger import (
    EnergyLedger,
    IdempotencyManager,
    IdempotentRecord,
    InsufficientEnergyError,
    MetabolicMode,
    _PersistentConn,
    get_ledger,
    reset_ledger,
)


# =============================================================================
# _PersistentConn
# =============================================================================


class TestPersistentConn:
    """Tests for _PersistentConn wrapper."""

    def test_close_is_noop(self):
        import sqlite3

        raw = sqlite3.connect(":memory:")
        wrapper = _PersistentConn(raw)
        wrapper.close()  # Should not close the underlying connection
        wrapper.execute("CREATE TABLE t (x int)")  # Should work if not closed


# =============================================================================
# IdempotencyManager
# =============================================================================


class TestIdempotencyManager:
    """Tests for IdempotencyManager."""

    def setup_method(self):
        self.manager = IdempotencyManager(
            window_seconds=60.0, max_records=100, persist_dir="/tmp/test_idem"
        )
        # Clear the cache to start fresh
        self.manager._cache.clear()

    def test_check_and_mark_new_trace(self):
        """A new trace_id should be accepted."""
        should_process, existing = self.manager.check_and_mark(
            trace_id="trace-1", source="eventbus", amount=10.0
        )
        assert should_process is True
        assert existing is None

    def test_check_and_mark_duplicate(self):
        """The same trace_id should be detected as duplicate."""
        self.manager.check_and_mark(trace_id="trace-2", source="eventbus", amount=10.0)
        should_process, existing = self.manager.check_and_mark(
            trace_id="trace-2", source="coordinator", amount=10.0
        )
        assert should_process is False
        assert existing is not None
        assert existing.source == "eventbus"

    def test_check_and_mark_empty_trace(self):
        """Empty trace_id should always be processed."""
        should_process, existing = self.manager.check_and_mark(
            trace_id="", source="eventbus", amount=10.0
        )
        assert should_process is True
        assert existing is None

    def test_check_and_mark_diff_amount_new_key(self):
        """Different amount should create a different key."""
        self.manager.check_and_mark(trace_id="trace-3", source="eventbus", amount=10.0)
        # Different amount -> different key -> should process
        should_process, existing = self.manager.check_and_mark(
            trace_id="trace-3", source="eventbus", amount=20.0
        )
        assert should_process is True

    def test_cleanup_expired(self):
        """Expired records should be cleaned up."""
        now = time.time()
        old = now - 120.0  # 2 minutes old, beyond 60s window
        self.manager._cache["old_key"] = IdempotentRecord(
            trace_id="old", source="eventbus", amount=1.0, processed_at=old
        )
        self.manager._cleanup_expired(now)
        assert "old_key" not in self.manager._cache

    def test_cache_size_limit(self):
        """Cache should not exceed max_records."""
        manager = IdempotencyManager(window_seconds=3600, max_records=5, persist_dir="/tmp/test_idem2")
        manager._cache.clear()
        for i in range(10):
            manager.check_and_mark(trace_id=f"trace-{i}", source="eventbus", amount=float(i))
        assert len(manager._cache) <= 5

    def test_get_stats(self):
        """get_stats should return correct cache info."""
        stats = self.manager.get_stats()
        assert stats["cache_size"] >= 0
        assert stats["window_seconds"] == 60.0
        assert stats["max_records"] == 100


