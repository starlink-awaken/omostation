class TestEnergyLedgerInitEdgeCases:
    """Tests for EnergyLedger init edge cases."""

    def test_init_with_bos_economy_db_env(self, monkeypatch):
        """BOS_ECONOMY_DB env var should be used as db_path when no arg given."""
        monkeypatch.setenv("BOS_ECONOMY_DB", ":memory:")
        ledger = EnergyLedger()
        try:
            assert ledger.db_path == ":memory:"
        finally:
            ledger.close()

    def test_init_with_custom_data_dir(self, tmp_path):
        """Explicit data_dir should be used for db and idempotency paths."""
        import pathlib
        from eu_pricing.ledger import IdempotencyManager

        data_dir = str(tmp_path / "custom_economy")
        ledger = EnergyLedger(db_path=":memory:", data_dir=data_dir)
        try:
            assert ledger.status == "active"
            # IdempotencyManager should use data_dir as persist_dir
            assert ledger._idempotency._persist_path.parent.parent == pathlib.Path(data_dir) / "economy"
        finally:
            ledger.close()

    def test_initialize_with_force_clears_data(self):
        """initialize(force=True) should clear existing ledger entries."""
        ledger = EnergyLedger(db_path=":memory:")
        try:
            ledger.deduct_eu(agent_id="test", operation="op", amount=50.0)
            assert ledger.get_balance() < 100_000.0
            # Force re-init resets to initial_balance
            ledger.initialize(initial_balance=2000.0, force=True)
            assert ledger.get_balance() == 2000.0
        finally:
            ledger.close()

    def test_init_default_db_path_uses_data_dir(self, tmp_path, monkeypatch):
        """Default db_path should be under EU_PRICING_DATA_DIR."""
        data_dir = str(tmp_path / "test_db")
        monkeypatch.setenv("EU_PRICING_DATA_DIR", data_dir)
        monkeypatch.delenv("BOS_ECONOMY_DB", raising=False)
        ledger = EnergyLedger()
        try:
            assert "metabolic.db" in ledger.db_path
            assert data_dir in ledger.db_path
        finally:
            ledger.close()


