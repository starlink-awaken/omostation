[tool filesystem_read_text_file] """Energy resource accounting data models — extracted from SharedBrain D_Economy.

Provides core abstractions independent of SharedBrain's BaseMembrane/PersistenceProvider.
"""

from __future__ import annotations

from dataclasses import dataclass, field
from enum import Enum
from typing import Any


class ResourceType(Enum):
    EU = "eu"
    NECTAR = "nectar"
    QUOTA = "quota"


@dataclass
class EnergyEntry:
    """A single energy consumption/budget record."""

    caller_id: str
    operation: str
    cost: float
    balance_before: float
    balance_after: float
    idempotency_key: str = ""

    def to_dict(self) -> dict[str, Any]:
        return {
            "caller_id": self.caller_id,
            "operation": self.operation,
            "cost": self.cost,
            "balance_before": self.balance_before,
            "balance_after": self.balance_after,
            "idempotency_key": self.idempotency_key,
        }


@dataclass
class EnergyBudget:
    """Per-caller energy budget."""

    caller_id: str
    limit: float = 1000.0
    consumed: float = 0.0
    entries: list[EnergyEntry] = field(default_factory=list)

    @property
    def balance(self) -> float:
        return max(0.0, self.limit - self.consumed)

    def can_afford(self, cost: float) -> bool:
        return self.balance >= cost

    def consume(self, operation: str, cost: float, idempotency_key: str = "") -> EnergyEntry | None:
        if not self.can_afford(cost):
            return None
        balance_before = self.balance
        entry = EnergyEntry(
            caller_id=self.caller_id,
            operation=operation,
            cost=cost,
            balance_before=balance_before,
            balance_after=balance_before - cost,
            idempotency_key=idempotency_key,
        )
        self.consumed += cost
        self.entries.append(entry)
        return entry


DEFAULT_PRICING: dict[str, float] = {
    "minerva_research": 10.0,
    "ontoderive_engine": 5.0,
    "eidos_validate": 2.0,
    "kos_index": 3.0,
    "kronos_ingest": 1.0,
    "sophia_compile": 5.0,
    "agora_route": 0.5,
    "codeanalyze_scan": 2.0,
}

[tool filesystem_read_text_file] """EU Ledger — core energy accounting extracted from SharedBrain D_Economy.

Provides virtual resource accounting with idempotency support for duplicate
billing prevention. This is L2 capability layer — independent of SharedBrain's
BaseMembrane, PersistenceProvider, and ProjectPaths infrastructure.

Key concepts:
- MetabolicMode: strict (insufficient funds → block) or advisory (warn only)
- Idempotency: sliding-window cache prevents double-billing from dual paths
- Worker leverage: dynamic multiplier for Nectar reward rates
- LLM cost tracking: per-provider EU cost aggregation
"""

from __future__ import annotations

import hashlib
import json
import logging
import os
import sqlite3 as _sqlite3
import time
import weakref
from collections import OrderedDict
from dataclasses import dataclass
from enum import Enum
from pathlib import Path
from threading import Lock
from types import TracebackType
from typing import Any

_log = logging.getLogger(__name__)

# =============================================================================
# 0. 形式化摘要 ≝
# =============================================================================
# Economy_Organ ≡ Resource_Manager
# 内涵 ≝ {EU_Management, Nectar_Rewarding, Quota_Allocation}
# 外延 ≝ {e | e ∈ D-Economy ∧ manages(e, Resources)}
# 功能 ⊢ {ManageEU, TrackNectar, AllocateQuota}
# =============================================================================


class MetabolicMode(Enum):
    STRICT = "strict"  # 余额不足立即熔断 (P0/P1 除外)
    ADVISORY = "advisory"  # 允许负债运行，仅记录警告


class InsufficientEnergyError(Exception):
    def __init__(self, current: float, required: float) -> None:
        super().__init__(
            f"Insufficient EU: current {current}, required {required}. Metabolic starvation triggered."
        )


# ── Idempotency Manager (inlined from D_Economy/idempotency_manager.py) ──────


@dataclass
class IdempotentRecord:
    """幂等记录"""

    trace_id: str
    source: str  # "eventbus" or "coordinator"
    amount: float
    processed_at: float


class IdempotencyManager:
    """
    幂等性管理器 - 防止能量流重复计费

    设计:
    - 使用 trace_id 作为幂等键
    - 维护滑动窗口缓存（默认 10 秒）
    - 支持两种来源：EventBus 和 Coordinator
    - 任一来源处理后，另一来源会被去重
    - 持久化到 JSON 文件，进程重启后可恢复（LRU 策略）
    """

    DEFAULT_WINDOW_SECONDS: float = 10.0
    DEFAULT_MAX_RECORDS: int = 1000
    _PERSIST_FILE = "idempotency_cache.json"

    def __init__(
        self,
        window_seconds: float = DEFAULT_WINDOW_SECONDS,
        max_records: int = DEFAULT_MAX_RECORDS,
        persist_dir: str | None = None,
    ) -> None:
        self._window_seconds = window_seconds
        self._max_records = max_records

        # 使用 OrderedDict 实现 LRU 缓存
        self._cache: OrderedDict[str, IdempotentRecord] = OrderedDict()
        self._lock = Lock()

        # 持久化路径
        base = Path(persist_dir) if persist_dir else Path("/tmp")
        self._persist_path = base / "economy" / self._PERSIST_FILE
        self._persist_path.parent.mkdir(parents=True, exist_ok=True)

        # 启动时恢复缓存
        self._restore_from_disk()

        _log.info(
            "[IdempotencyManager] Initialized (window=%ss, max=%d, persist=%s)",
            window_seconds,
            max_records,
            self._persist_path,
        )

    def _persist_to_disk(self) -> None:
        """持久化缓存到磁盘"""
        try:
            data = {
                key: {
                    "trace_id": rec.trace_id,
                    "source": rec.source,
                    "amount": rec.amount,
                    "processed_at": rec.processed_at,
                }
                for key, rec in self._cache.items()
            }
            with open(self._persist_path, "w", encoding="utf-8") as f:
                json.dump(data, f)
        except (OSError, TypeError, ValueError) as e:
            _log.debug("[IdempotencyManager] Failed to persist cache: %s", e)

    def _restore_from_disk(self) -> None:
        """从磁盘恢复缓存（仅恢复未过期的记录）"""
        if not self._persist_path.exists():
            return
        try:
            with open(self._persist_path, encoding="utf-8") as f:
                data = json.load(f)
            now = time.time()
            cutoff = now - self._window_seconds
            restored = 0
            for key, rec_data in data.items():
                if rec_data["processed_at"] >= cutoff:
                    self._cache[key] = IdempotentRecord(**rec_data)
                    restored += 1
            if restored > 0:
                _log.info("[IdempotencyManager] Restored %d records from disk", restored)
        except (OSError, KeyError, TypeError, ValueError, json.JSONDecodeError) as e:
            _log.debug("[IdempotencyManager] Failed to restore cache: %s", e)

    def check_and_mark(
        self,
        trace_id: str,
        source: str,
        amount: float,
    ) -> tuple[bool, IdempotentRecord | None]:
        """
        检查并标记幂等操作

        返回:
            (should_process, existing_record)
            - should_process: True 表示应该处理，False 表示已处理过
            - existing_record: 如果已处理过，返回原记录
        """
        if not trace_id:
            return True, None

        now = time.time()
        key = self._make_key(trace_id, amount)

        with self._lock:
            self._cleanup_expired(now)

            if key in self._cache:
                existing = self._cache[key]
                _log.info(
                    "[IdempotencyManager] Duplicate detected: trace_id=%s, source=%s, existing_source=%s",
                    trace_id,
                    source,
                    existing.source,
                )
                return False, existing

            record = IdempotentRecord(
                trace_id=trace_id,
                source=source,
                amount=amount,
                processed_at=now,
            )
            self._cache[key] = record
            self._cache.move_to_end(key)

            while len(self._cache) > self._max_records:
                self._cache.popitem(last=False)

            return True, None

    def _make_key(self, trace_id: str, amount: float) -> str:
        content = f"{trace_id}:{repr(amount)}"
        return hashlib.sha256(content.encode()).hexdigest()[:16]

    def _cleanup_expired(self, now: float) -> None:
        cutoff = now - self._window_seconds
        expired_keys = [key for key, record in self._cache.items() if record.processed_at < cutoff]
        for key in expired_keys:
            del self._cache[key]

    def get_stats(self) -> dict[str, Any]:
        with self._lock:
            return {
                "cache_size": len(self._cache),
                "window_seconds": self._window_seconds,
                "max_records": self._max_records,
            }


# ── Persistent Connection Wrapper ────────────────────────────────────────────


class _PersistentConn:
    """Wraps a sqlite3 connection so that close() is a no-op.

    Used for in-memory databases where the schema must survive across
    multiple get_connection() calls on the same EnergyLedger instance.
    """

    def __init__(self, conn: _sqlite3.Connection) -> None:
        self._conn = conn

    def __getattr__(self, name: str) -> object:
        return getattr(self._conn, name)

    def close(self) -> None:
        pass  # intentional no-op: keep the in-memory DB alive

    def __enter__(self) -> _PersistentConn:
        return self

    def __exit__(
        self,
        exc_type: type[BaseException] | None,
        exc_val: BaseException | None,
        exc_tb: TracebackType | None,
    ) -> bool:
        if exc_type is None:
            self._conn.commit()
        else:
            self._conn.rollback()
        return False


# ── Energy Ledger ────────────────────────────────────────────────────────────


class EnergyLedger:
    """能量代谢的物理执行器官 — 独立于 SharedBrain 基础设施。

    Handles EU (Energy Unit) accounting: deduct, credit, balance queries,
    idempotent billing, worker leverage adjustments, and LLM cost tracking.
    """

    TAX_RATE_DEFAULT: float = 1.0
    TAX_RATES: dict = {
        "MEMBRANE_CROSS": 0.5,
        "INTRA_DOMAIN": 0.1,
        "SYSTEM": 0.0,
        "query_by_ref": 0.0,  # 系统内部追踪，不计费 (RFC-001)
    }
    EMERGENCY_ELIGIBLE_OPS: frozenset = frozenset(
        ["EVOLUTION_COMMIT", "GENESIS_REBOOT", "IMMUNITY_AUDIT", "CORE_BOOT"]
    )

    DEFAULT_BALANCE: float = 100_000.0
    DEFAULT_DB_NAME: str = "metabolic.db"

    def __init__(
        self,
        db_path: str | None = None,
        idempotency_window: float = 10.0,
        data_dir: str | None = None,
    ) -> None:
        """Initialize the ledger.

        Args:
            db_path: Path to the ledger database (or :memory:).
            idempotency_window: Sliding window in seconds for the idempotency cache.
            data_dir: Directory for database and idempotency cache files.
        """
        self.status = "active"
        base_dir = data_dir or os.environ.get("EU_PRICING_DATA_DIR", "data/db/economy")

        raw_path = db_path or os.environ.get("BOS_ECONOMY_DB") or os.path.join(
            base_dir, self.DEFAULT_DB_NAME
        )

        if raw_path == ":memory:":
            _raw_conn = _sqlite3.connect(":memory:", check_same_thread=False)
            _raw_conn.row_factory = _sqlite3.Row
            self._mem_conn: _PersistentConn | None = _PersistentConn(_raw_conn)
            self._mem_conn_finalizer: weakref.finalize | None = weakref.finalize(
                self, _raw_conn.close
            )
            self.db_path = ":memory:"
        else:
            os.makedirs(os.path.dirname(raw_path), exist_ok=True)
            self._mem_conn = None
            self._mem_conn_finalizer = None
            self.db_path = raw_path

        self._idempotency: IdempotencyManager = IdempotencyManager(
            window_seconds=idempotency_window, persist_dir=base_dir
        )
        self.mode = MetabolicMode(os.environ.get("BOS_METABOLIC_MODE", "strict").lower())
        self.initialize()

    def close(self) -> None:
        if self._mem_conn_finalizer is not None and self._mem_conn_finalizer.alive:
            self._mem_conn_finalizer()
        self._mem_conn = None

    def _get_connection(self) -> _PersistentConn | _sqlite3.Connection:
        if self._mem_conn is not None:
            return self._mem_conn
        conn = _sqlite3.connect(self.db_path)
        conn.row_factory = _sqlite3.Row
        return conn

    def initialize(self, initial_balance: float = 100_000.0, force: bool = False) -> None:
        """初始化账本数据库。"""
        schema = """
        CREATE TABLE IF NOT EXISTS eu_ledger (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp   REAL    NOT NULL DEFAULT (strftime('%s', 'now')),
            agent_id    TEXT    NOT NULL,
            operation   TEXT    NOT NULL,
            amount      REAL    NOT NULL,
            balance_after REAL  NOT NULL,
            ref_id      TEXT,
            memo        TEXT,
            is_emergency INTEGER NOT NULL DEFAULT 0
        );
        CREATE INDEX IF NOT EXISTS idx_ledger_composite ON eu_ledger(agent_id, id DESC);
        CREATE INDEX IF NOT EXISTS idx_ledger_timestamp ON eu_ledger(timestamp);
        CREATE INDEX IF NOT EXISTS idx_transactions_agent_id ON eu_ledger(agent_id);
        CREATE INDEX IF NOT EXISTS idx_transactions_timestamp ON eu_ledger(timestamp);
        CREATE INDEX IF NOT EXISTS idx_transactions_agent_time ON eu_ledger(agent_id, timestamp);
        """
        conn = self._get_connection()
        try:
            conn.executescript(schema)

            if force:
                conn.execute("DELETE FROM eu_ledger")

            cursor = conn.execute("SELECT COUNT(*) FROM eu_ledger")
            if cursor.fetchone()[0] == 0:
                conn.execute(
                    "INSERT INTO eu_ledger (agent_id, operation, amount, balance_after, memo) "
                    "VALUES (?, ?, ?, ?, ?)",
                    ("@Prime", "GENESIS_INJECTION", initial_balance, initial_balance, "Genesis Nectar"),
                )
                conn.commit()
        finally:
            conn.close()

    def _handle_consume(self, params: dict[str, Any]) -> dict[str, Any]:
        """处理能量扣除请求。"""
        agent_id = params.get("account") or params.get("agent_id", "UNKNOWN")
        amount = params.get("amount", 0.0)
        operation = params.get("operation", "PHYSICAL_TAX")
        memo = params.get("reason", "")
        ref_id = params.get("ref_id") or params.get("trace_id")

        try:
            conn = self._get_connection()
            try:
                with conn:
                    row = conn.execute(
                        "SELECT balance_after FROM eu_ledger ORDER BY id DESC LIMIT 1"
                    ).fetchone()
                    current_balance = row["balance_after"] if row else 0.0

                    if self.mode == MetabolicMode.STRICT and (
                        current_balance <= 0 or current_balance < amount
                    ):
                        if operation not in self.EMERGENCY_ELIGIBLE_OPS:
                            raise InsufficientEnergyError(current_balance, amount)

                    new_balance = current_balance - amount
                    conn.execute(
                        "INSERT INTO eu_ledger (agent_id, operation, amount, balance_after, memo, ref_id) "
                        "VALUES (?, ?, ?, ?, ?, ?)",
                        (agent_id, operation, -amount, new_balance, memo, ref_id),
                    )
                return {
                    "status": "success",
                    "success": True,
                    "amount": amount,
                    "balance": new_balance,
                    "consumed": amount,
                    "ref_id": ref_id,
                }
            finally:
                conn.close()
        except InsufficientEnergyError as e:
            current = self.get_balance()
            return {
                "status": "error",
                "error_type": "STARVATION",
                "success": False,
                "message": str(e),
                "balance": current,
            }
        except (OSError, ValueError, RuntimeError) as e:
            _log.error("deduct_eu failed: %s", e, exc_info=True)
            return {"success": False, "status": "error", "message": str(e)}

    def _handle_query_by_ref(self, params: dict[str, Any]) -> dict[str, Any]:
        """根据 ref_id (trace_id) 查询消耗的总能量。"""
        ref_id = params.get("ref_id") or params.get("trace_id")
        if not ref_id:
            return {"status": "error", "message": "ref_id/trace_id required"}

        try:
            conn = self._get_connection()
            try:
                row = conn.execute(
                    "SELECT SUM(ABS(amount)) as total_consumed FROM eu_ledger WHERE ref_id = ?",
                    (ref_id,),
                ).fetchone()
                total = row["total_consumed"] if row and row["total_consumed"] else 0.0
                return {"status": "success", "total_consumed": total, "ref_id": ref_id}
            finally:
                conn.close()
        except (_sqlite3.Error, OSError, ValueError) as e:
            return {"status": "error", "message": str(e)}

    def deduct_usage(
        self,
        agent_id: str,
        operation: str = "INTENT_EXECUTION",
        ref_id: str = "",
        usage: dict | None = None,
        cost_per_token: ***REDACTED*** = 0.001,
        apply_dynamic_pricing: bool = False,
    ) -> dict[str, Any]:
        """按 token 用量扣费。usage = {prompt_tokens, completion_tokens}
        若无 token 用量（usage 为空），则退化为固定税率（TAX_RATES 查表）。
        """
        usage = usage or {}
        total_tokens = usage.get("prompt_tokens", 0) + usage.get("completion_tokens", 0)
        if total_tokens == 0:
            amount = self.TAX_RATES.get(operation, self.TAX_RATE_DEFAULT)
        else:
            amount = total_tokens * cost_per_token

        if apply_dynamic_pricing:
            # TODO-migrate: [PB-5] was `from organs.D_Economy.organs.amm_controller import DynamicPricingEngine`
            # Use the local market module instead:
            try:
                from eu_pricing.market import get_market_analyzer

                premium = get_market_analyzer().get_current_multiplier()
                amount = round(amount * premium, 4)
            except ImportError:
                pass

        current = self.get_balance()
        if (
            self.mode == MetabolicMode.STRICT
            and current < amount
            and operation not in self.EMERGENCY_ELIGIBLE_OPS
        ):
            raise InsufficientEnergyError(current, amount)
        return self._handle_consume(
            {
                "agent_id": agent_id,
                "amount": amount,
                "operation": operation,
                "reason": f"usage ref={ref_id}",
            }
        )

    def deduct_eu(
        self,
        agent_id: str,
        operation: str = "INTENT_EXECUTION",
        ref_id: str = "",
        amount: float = 1.0,
    ) -> dict[str, Any]:
        """按固定 EU 扣费。"""
        return self._handle_consume(
            {
                "agent_id": agent_id,
                "amount": amount,
                "operation": operation,
                "reason": f"deduct_eu ref={ref_id}",
            }
        )

    def credit_eu(self, amount: float, memo: str = "") -> dict[str, Any]:
        """奖励 EU（正值 = 增加余额；负值 = 扣减余额，可用于强制设定目标余额）。
        修复：移除 abs()，允许负向 credit 作为余额调整手段。
        """
        return self._handle_consume(
            {
                "agent_id": "@System",
                "amount": -amount,  # 正 amount → 增余额；负 amount → 减余额
                "operation": "NECTAR_REWARD",
                "reason": memo,
            }
        )

    def grant_gc_incentive(self, purged_count: int) -> dict[str, Any]:
        """[RFC-029] 为认知清理动作提供 EU 激励奖励。每清理 100 条记录奖励 1 EU。"""
        reward = purged_count / 100.0
        if reward <= 0:
            return {"status": "skipped", "reward": 0.0}
        return self.credit_eu(reward, memo=f"GC_INCENTIVE purged={purged_count}")

    # ── Idempotency integration ────────────────────────────────────────

    def record_debit_from_coordinator(
        self,
        amount: float,
        source: str,
        trace_id: str | None = None,
    ) -> dict[str, Any]:
        """
        处理来自 Coordinator 的直接调用 (fallback 路径)。

        关键: 先检查幂等性，防止 EventBus 和 Coordinator 双重计费。
        """
        if trace_id:
            should_process, existing = self._idempotency.check_and_mark(
                trace_id=trace_id,
                source="coordinator",
                amount=amount,
            )
            if not should_process:
                _log.info(
                    "[EnergyLedger] Skipping duplicate (Coordinator): "
                    "trace_id=%s, already processed via %s",
                    trace_id,
                    existing.source if existing else "unknown",
                )
                return {
                    "status": "success",
                    "idempotent": True,
                    "duplicate": True,
                    "trace_id": trace_id,
                    "message": "Already processed via another path",
                }
        return self._record_debit(amount=amount, source=source, trace_id=trace_id)

    def _record_debit(
        self,
        amount: float,
        source: str | None,
        trace_id: str | None,
    ) -> dict[str, Any]:
        """实际记录计费（内部方法）"""
        return self._handle_consume({
            "agent_id": source or "UNKNOWN",
            "amount": amount,
            "operation": "MEMBRANE_PHYSICAL_TAX",
            "reason": f"Energy consumption from {source}, trace={trace_id}",
            "ref_id": trace_id,
        })

    def get_idempotency_stats(self) -> dict[str, Any]:
        """获取幂等性统计信息"""
        return self._idempotency.get_stats()

    # ── Worker leverage ─────────────────────────────────────────────────

    def adjust_worker_leverage(self, worker_id: str, delta: float) -> bool:
        """
        联动 D-Economy，基于表现自动调整角色的权重参数（Nectar 倍率）。
        delta: 权重变化量 (e.g., +0.1)
        """
        _log.info("[Economy] Adjusting worker %s leverage (Delta: %s)...", worker_id, delta)
        try:
            with self._get_connection() as conn:
                conn.execute("""
                    CREATE TABLE IF NOT EXISTS worker_leverage (
                        worker_id TEXT PRIMARY KEY,
                        leverage_multiplier REAL DEFAULT 1.0,
                        updated_at REAL
                    )
                """)
                now = time.time()
                conn.execute(
                    """
                    INSERT INTO worker_leverage (worker_id, leverage_multiplier, updated_at)
                    VALUES (?, 1.0 + ?, ?)
                    ON CONFLICT(worker_id) DO UPDATE SET
                        leverage_multiplier = leverage_multiplier + ?,
                        updated_at = ?
                    """,
                    (worker_id, delta, now, delta, now),
                )
                conn.commit()
            return True
        except (OSError, RuntimeError, AttributeError) as e:
            _log.error("[Economy] Leverage adjustment failed: %s", e, exc_info=True)
            return False

    # ── Balance queries ─────────────────────────────────────────────────

    def _handle_balance(self, params: dict[str, Any]) -> dict[str, Any]:
        """Expose the current EU balance through the membrane action contract."""
        return {"status": "success", "success": True, "balance": self.get_balance()}

    def get_balance(self) -> float:
        with self._get_connection() as conn:
            row = conn.execute(
                "SELECT balance_after FROM eu_ledger ORDER BY id DESC LIMIT 1"
            ).fetchone()
            return row["balance_after"] if row else 0.0

    def get_all_balances(self) -> dict[str, float]:
        """Return the most-recent balance_after for every agent_id in the ledger."""
        with self._get_connection() as conn:
            rows = conn.execute(
                """
                SELECT agent_id, balance_after
                FROM eu_ledger
                WHERE id IN (
                    SELECT MAX(id) FROM eu_ledger GROUP BY agent_id
                )
                """
            ).fetchall()
        return {row["agent_id"]: row["balance_after"] for row in rows}

    def get_agent_balance(self, agent_id: str) -> float:
        """Return the current EU balance for a specific agent."""
        with self._get_connection() as conn:
            row = conn.execute(
                "SELECT balance_after FROM eu_ledger WHERE agent_id = ? ORDER BY id DESC LIMIT 1",
                (agent_id,),
            ).fetchone()
            return row["balance_after"] if row else 0.0

    # ── LLM EU Cost Tracking ────────────────────────────────────────────

    def record_llm_cost(
        self,
        provider: str,
        model: str,
        tokens_used: int,
        cost_eu: float,
        *,
        agent_id: str = "@LLM",
    ) -> dict[str, Any]:
        """Create an EU debit entry for an LLM call.

        Args:
            provider:   LLM provider name, e.g. ``"anthropic"``, ``"openai"``.
            model:      Model identifier, e.g. ``"claude-3-5-sonnet"``.
            tokens_used: Total tokens consumed (prompt + completion).
            cost_eu:    EU cost to debit.
            agent_id:   Agent that triggered the call (default ``@LLM``).

        Returns:
            Result dict from the ledger consume operation, or an error dict
            when the DB is unavailable.
        """
        memo = f"llm_call provider={provider} model={model} tokens={tokens_used}"
        try:
            return self._handle_consume(
                {
                    "agent_id": agent_id,
                    "amount": cost_eu,
                    "operation": "llm_call",
                    "reason": memo,
                }
            )
        except (OSError, RuntimeError, AttributeError) as exc:
            _log.warning("record_llm_cost: DB unavailable, skipping: %s", exc)
            return {"success": False, "status": "db_unavailable", "message": str(exc)}

    def get_llm_cost_summary(self, since_hours: int = 24) -> dict[str, Any]:
        """Return aggregated LLM EU cost totals by provider for the last *since_hours*.

        Args:
            since_hours: Look-back window in hours (default 24).

        Returns:
            Dict with ``total_eu``, ``total_tokens``, ``calls`` (int), and
            ``by_provider`` (mapping of provider name → sub-totals dict).
            Returns an error dict when the DB is unavailable.
        """
        cutoff = time.time() - since_hours * 3600

        query = """
            SELECT memo, amount
            FROM eu_ledger
            WHERE operation = 'llm_call'
              AND timestamp >= ?
        """
        try:
            with self._get_connection() as conn:
                rows = conn.execute(query, (cutoff,)).fetchall()
        except (OSError, RuntimeError, AttributeError) as exc:
            _log.warning("get_llm_cost_summary: DB unavailable: %s", exc)
            return {"success": False, "status": "db_unavailable", "message": str(exc)}

        total_eu = 0.0
        total_tokens = 0
        calls = 0
        by_provider: dict[str, dict[str, Any]] = {}

        for row in rows:
            memo: str = row["memo"] or ""
            eu_amount = abs(float(row["amount"]))

            provider = _parse_memo_field(memo, "provider") or "unknown"
            tokens_str = _parse_memo_field(memo, "tokens") or "0"
            try:
                tokens = int(tokens_str)
            except ValueError:
                tokens = 0

            total_eu += eu_amount
            total_tokens += tokens
            calls += 1

            if provider not in by_provider:
                by_provider[provider] = {"eu": 0.0, "tokens": 0, "calls": 0}
            by_provider[provider]["eu"] += eu_amount
            by_provider[provider]["tokens"] += tokens
            by_provider[provider]["calls"] += 1

        return {
            "success": True,
            "since_hours": since_hours,
            "total_eu": total_eu,
            "total_tokens": total_tokens,
            "calls": calls,
            "by_provider": by_provider,
        }


def _parse_memo_field(memo: str, field_name: str) -> str | None:
    """Extract a ``key=value`` field from a memo string."""
    import re

    match = re.search(rf"{re.escape(field_name)}=(\S+)", memo)
    return match.group(1) if match else None


# ── Singleton access ─────────────────────────────────────────────────────────

_LEDGER_SINGLETON: EnergyLedger | None = None


def get_ledger() -> EnergyLedger:
    global _LEDGER_SINGLETON
    if _LEDGER_SINGLETON is None:
        _LEDGER_SINGLETON = EnergyLedger()
    return _LEDGER_SINGLETON


def reset_ledger() -> None:
    """[Test Helper] 强制重置 Ledger 单例。"""
    global _LEDGER_SINGLETON
    if _LEDGER_SINGLETON:
        _LEDGER_SINGLETON.close()
    _LEDGER_SINGLETON = None


class _LedgerProxy:
    def __getattr__(self, name: str) -> object:
        return getattr(get_ledger(), name)


# Backward-compatible lazy singleton proxy.
Ledger = _LedgerProxy()

[tool filesystem_read_text_file] """Market Analyzer — metabolic market analysis for dynamic EU pricing.

Extracted from SharedBrain D_Economy market_analyzer.py.
Computes EU consumption multipliers based on system load and task pressure.

Key concepts:
- CPU load factor: overloaded systems pay higher EU cost
- Task pressure: more active tasks → higher multiplier
- Cached multiplier with configurable refresh interval
"""

from __future__ import annotations

import logging
import os
import time

_log = logging.getLogger(__name__)


class MarketAnalyzer:
    """
    [RFC-007] 代谢市场分析器。
    职责: 根据系统实时状态计算 EU 扣费倍率。
    """

    def __init__(self) -> None:
        self.status = "active"
        self._last_update = 0.0
        self._cached_multiplier = 1.0
        self._update_interval = 10.0  # 10秒刷新一次

    def get_current_multiplier(self) -> float:
        """获取当前的代谢扣费倍率。"""
        now = time.time()
        if now - self._last_update > self._update_interval:
            self._cached_multiplier = self._calculate_multiplier()
            self._last_update = now
        return self._cached_multiplier

    def _calculate_multiplier(self) -> float:
        """
        计算逻辑：
        Multiplier = 1.0 (基础) + Load_Impact + Scarcity_Impact
        """
        multiplier = 1.0

        # 1. CPU 负载影响 (Load Factor)
        load1 = 0.0
        try:
            load1, _, _ = os.getloadavg()
            # 负载超过 2.0 开始加价，每增加 1.0 负载加价 20%
            if load1 > 2.0:
                load_impact = (load1 - 2.0) * 0.2
                multiplier += load_impact
        except (AttributeError, OSError):
            pass

        # 2. 任务压力影响 (Execution Load Scarcity)
        # TODO-migrate: was `from organs.D_Execution.organs.execution_coordinator import Coordinator`
        # Use engine_core equivalent when available:
        active_tasks = 0
        try:
            # TODO-migrate: from engine_core.execution_coordinator import Coordinator
            # active_tasks = len(Coordinator.list_active_sessions()) if hasattr(Coordinator, "list_active_sessions") else 0
            pass
        except ImportError:
            active_tasks = 0

        # 每 5 个活跃任务增加 10% 溢价
        task_impact = (active_tasks // 5) * 0.1
        multiplier += task_impact

        _log.debug(
            "[Market] Current EU Multiplier calculated: %.2f (Load: %.2f, ActiveTasks: %d)",
            multiplier,
            load1,
            active_tasks,
        )
        return round(multiplier, 2)


# 全局单例
_market_analyzer: MarketAnalyzer | None = None


def get_market_analyzer() -> MarketAnalyzer:
    """Get or create the global MarketAnalyzer singleton."""
    global _market_analyzer
    if _market_analyzer is None:
        _market_analyzer = MarketAnalyzer()
    return _market_analyzer

[tool filesystem_read_text_file] """Energy Optimizer — optimize EU consumption across operations."""

from collections import deque
from dataclasses import dataclass, field
from enum import StrEnum


class Strategy(StrEnum):
    MINIMIZE_COST = "minimize_cost"
    MAXIMIZE_SPEED = "maximize_speed"
    BALANCED = "balanced"


@dataclass
class CostEstimate:
    operation: str
    estimated_eu: float
    confidence: float = 0.8
    factors: dict = field(default_factory=dict)


@dataclass
class Budget:
    agent_id: str = ""
    limit: float = 1000.0
    spent: float = 0.0
    reserved: float = 0.0
    alerts: list[str] = field(default_factory=list)

    @property
    def available(self) -> float:
        return max(0.0, self.limit - self.spent - self.reserved)

    @property
    def usage_pct(self) -> float:
        return (self.spent + self.reserved) / max(self.limit, 0.01) * 100


class EnergyOptimizer:
    """Optimize EU consumption with cost prediction and budget management."""

    def __init__(self):
        self._budgets: dict[str, Budget] = {}
        self._usage_history: dict[str, deque] = {}
        self._cost_model: dict[str, float] = {
            "kos_search": 3.0, "minerva_research": 10.0, "code_analysis": 5.0,
            "llm_query": 2.0, "llm_generation": 8.0, "graph_query": 1.0,
            "embedding": 4.0, "index_build": 15.0,
        }

    def set_budget(self, agent_id: str, limit: float):
        if agent_id not in self._budgets:
            self._budgets[agent_id] = Budget(agent_id=agent_id, limit=limit)
        else:
            self._budgets[agent_id].limit = limit

    def get_budget(self, agent_id: str) -> Budget:
        if agent_id not in self._budgets:
            self._budgets[agent_id] = Budget(agent_id=agent_id)
        return self._budgets[agent_id]

    def estimate_cost(self, operation: str, complexity: float = 1.0, size: int = 1, urgency: float = 0.0) -> CostEstimate:
        base = self._cost_model.get(operation, 5.0)
        urgency_factor = 1.0 + urgency * 0.5
        estimated = base * complexity * size * urgency_factor
        return CostEstimate(operation=operation, estimated_eu=round(estimated, 2),
                           factors={"base": base, "complexity": complexity, "size": size, "urgency": urgency_factor})

    def can_afford(self, agent_id: str, operation: str, complexity: float = 1.0, size: int = 1) -> tuple[bool, CostEstimate]:
        budget = self.get_budget(agent_id)
        estimate = self.estimate_cost(operation, complexity, size)
        return estimate.estimated_eu <= budget.available, estimate

    def reserve(self, agent_id: str, amount: float) -> bool:
        budget = self.get_budget(agent_id)
        if budget.available >= amount:
            budget.reserved += amount
            return True
        return False

    def commit(self, agent_id: str, amount: float):
        budget = self.get_budget(agent_id)
        budget.reserved = max(0, budget.reserved - amount)
        budget.spent += amount
        self._usage_history.setdefault(agent_id, deque(maxlen=100)).append(amount)
        if budget.usage_pct > 80:
            budget.alerts.append(f"Budget at {budget.usage_pct:.0f}% for {agent_id}")

    def get_usage_trend(self, agent_id: str) -> str:
        history = list(self._usage_history.get(agent_id, deque()))
        if len(history) < 5:
            return "insufficient_data"
        mid = len(history) // 2
        first_half = sum(history[:mid]) / max(mid, 1)
        second_half = sum(history[mid:]) / max(len(history) - mid, 1)
        if second_half > first_half * 1.2:
            return "increasing"
        elif second_half < first_half * 0.8:
            return "decreasing"
        return "stable"

[tool filesystem_read_text_file] """Reputation Ledger — decentralized reputation tracking for federation nodes.

Extracted from SharedBrain D_Economy reputation_ledger.py.
Independent of BaseMembrane infrastructure.

Key concepts:
- Reputation scoring: 70% success rate + 30% average quality, SMA-based
- Sigmoid feedback: smooth reputation adjustment via positive/negative feedback
- Circuit breaker: automatic isolation when reputation drops below threshold
- IQR anomaly detection: statistical outlier identification
- Time decay: reputation decays slowly over inactivity periods
"""

from __future__ import annotations

import logging
import math
import os
import sqlite3
import time

logger = logging.getLogger(__name__)

# Circuit breaker constants
REPUTATION_CIRCUIT_THRESHOLD = 0.3
CIRCUIT_BREAK_DURATION = 3600  # 1 hour in seconds
TIME_DECAY_LAMBDA = 1e-6  # Approximately 0.1% decay per day


class ReputationLedger:
    """
    [RFC-014] 联邦节点声誉账本。
    负责记录和计算每个节点的信用等级。
    """

    def __init__(self, db_path: str = "data/db/core/reputation.db") -> None:
        self.status = "active"
        self.db_path = db_path
        # Don't create directory for in-memory databases
        if db_path != ":memory:":
            os.makedirs(os.path.dirname(db_path), exist_ok=True)
        # For in-memory databases, keep a persistent connection
        self._persistent_conn = None
        if db_path == ":memory:":
            self._persistent_conn = sqlite3.connect(":memory:")
            self._ensure_schema_on_conn(self._persistent_conn)
        else:
            self._ensure_schema()

    def _ensure_schema_on_conn(self, conn: sqlite3.Connection) -> None:
        """Ensure schema exists on the given connection."""
        conn.execute("""
            CREATE TABLE IF NOT EXISTS reputation_nodes (
                node_id         TEXT PRIMARY KEY,
                tasks_attempted INTEGER DEFAULT 0,
                tasks_completed INTEGER DEFAULT 0,
                total_quality   REAL DEFAULT 0.0,
                reputation      REAL DEFAULT 0.5,
                last_updated    REAL NOT NULL,
                circuit_open    INTEGER DEFAULT 0,
                circuit_opened_at REAL DEFAULT NULL
            )
        """)
        # Add new columns if table exists (migration)
        cursor = conn.execute("PRAGMA table_info(reputation_nodes)")
        columns = [row[1] for row in cursor.fetchall()]
        if "circuit_open" not in columns:
            conn.execute("ALTER TABLE reputation_nodes ADD COLUMN circuit_open INTEGER DEFAULT 0")
        if "circuit_opened_at" not in columns:
            conn.execute(
                "ALTER TABLE reputation_nodes ADD COLUMN circuit_opened_at REAL DEFAULT NULL"
            )
        conn.commit()

    def _ensure_schema(self) -> None:
        """Ensure schema exists for file-based databases."""
        with sqlite3.connect(self.db_path) as conn:
            self._ensure_schema_on_conn(conn)

    def _get_connection(self) -> sqlite3.Connection:
        """Get a database connection, handling in-memory case."""
        if self._persistent_conn is not None:
            return self._persistent_conn
        return sqlite3.connect(self.db_path)

    def __del__(self) -> None:
        """Clean up in-memory connection on deletion."""
        if self._persistent_conn is not None:
            self._persistent_conn.close()
            self._persistent_conn = None

    def report_outcome(self, node_id: str, success: bool, quality: float = 0.5) -> float:
        """记录一次执行结果并更新声誉值。"""
        now = time.time()
        conn = self._get_connection()
        conn.row_factory = sqlite3.Row
        row = conn.execute(
            "SELECT * FROM reputation_nodes WHERE node_id = ?", (node_id,)
        ).fetchone()

        if not row:
            # 新节点初始状态
            attempted = 1
            completed = 1 if success else 0
            quality_sum = quality if success else 0.0
        else:
            attempted = row["tasks_attempted"] + 1
            completed = row["tasks_completed"] + (1 if success else 0)
            quality_sum = row["total_quality"] + (quality if success else 0.0)

        # 计算新声誉: 简单移动平均 (SMA) 思想，可后续引入贝叶斯平滑
        success_rate = completed / attempted
        avg_quality = quality_sum / completed if completed > 0 else 0.5

        # Reputation = (Success_Rate * 0.7) + (Avg_Quality * 0.3)
        new_reputation = (success_rate * 0.7) + (avg_quality * 0.3)
        # 限制在 [0.0, 1.0]
        new_reputation = max(0.0, min(1.0, new_reputation))

        # 先更新声誉（保留熔断器状态）
        conn.execute(
            """
            INSERT OR REPLACE INTO reputation_nodes
            (node_id, tasks_attempted, tasks_completed, total_quality, reputation, last_updated)
            VALUES (?, ?, ?, ?, ?, ?)
        """,
            (node_id, attempted, completed, quality_sum, new_reputation, now),
        )
        conn.commit()

        # 自动触发熔断器（独立的电路状态管理）
        if new_reputation < REPUTATION_CIRCUIT_THRESHOLD:
            self.trip_circuit(
                node_id,
                reason=f"Reputation {new_reputation:.3f} below threshold {REPUTATION_CIRCUIT_THRESHOLD}",
            )

        return new_reputation

    def apply_feedback(self, node_id: str, is_positive: bool) -> float:
        """
        [RFC-031] 处理来自真实世界（或关联联想）的用户反馈。
        使用 Sigmoid 函数平滑调整声誉值，代替硬编码常量演化。
        """
        conn = self._get_connection()
        conn.row_factory = sqlite3.Row
        row = conn.execute(
            "SELECT * FROM reputation_nodes WHERE node_id = ?", (node_id,)
        ).fetchone()

        if not row:
            # 如果节点不存在，初始化一个默认偏向的声誉
            current_rep = 0.55 if is_positive else 0.45
            attempted = 0
            completed = 0
            quality_sum = 0.0
        else:
            current_rep = row["reputation"]
            attempted = row["tasks_attempted"]
            completed = row["tasks_completed"]
            quality_sum = row["total_quality"]

        # Sigmoid 步长调整：反馈影响随极端值减弱 (防止被单次反馈刷爆或踩死)
        # delta = 0.1 * current_rep * (1 - current_rep)
        delta = 0.15 * current_rep * (1.0 - current_rep)

        if is_positive:
            new_reputation = current_rep + delta
        else:
            new_reputation = current_rep - delta

        new_reputation = max(0.01, min(0.99, new_reputation))  # 保留一点余地

        now = time.time()
        conn.execute(
            """
            INSERT OR REPLACE INTO reputation_nodes
            (node_id, tasks_attempted, tasks_completed, total_quality, reputation, last_updated)
            VALUES (?, ?, ?, ?, ?, ?)
        """,
            (node_id, attempted, completed, quality_sum, new_reputation, now),
        )
        conn.commit()

        logger.info(
            "[Reputation] Feedback applied to %s: %.3f -> %.3f (Positive: %s)",
            node_id,
            current_rep,
            new_reputation,
            is_positive,
        )
        return new_reputation

    def get_reputation(self, node_id: str) -> float:
        """获取特定节点的声誉值，应用时间衰减。"""
        conn = self._get_connection()
        conn.row_factory = sqlite3.Row
        row = conn.execute(
            "SELECT * FROM reputation_nodes WHERE node_id = ?", (node_id,)
        ).fetchone()
        if not row:
            return 0.5  # 默认中庸分

        base_reputation = row["reputation"]
        last_updated = row["last_updated"]

        # 应用时间衰减：score * exp(-lambda * age)
        age = time.time() - last_updated
        decayed_reputation = base_reputation * math.exp(-TIME_DECAY_LAMBDA * age)

        return max(0.0, min(1.0, decayed_reputation))

    def is_node_circuit_open(self, node_id: str) -> bool:
        """检查节点熔断器是否打开。

        如果熔断器打开且已超过恢复时间，则自动关闭。
        """
        conn = self._get_connection()
        conn.row_factory = sqlite3.Row
        row = conn.execute(
            "SELECT circuit_open, circuit_opened_at FROM reputation_nodes WHERE node_id = ?",
            (node_id,),
        ).fetchone()

        if not row:
            return False  # 新节点，熔断器关闭

        if not row["circuit_open"]:
            return False  # 熔断器关闭

        # 检查是否已超过恢复时间
        if row["circuit_opened_at"]:
            time_since_open = time.time() - row["circuit_opened_at"]
            if time_since_open >= CIRCUIT_BREAK_DURATION:
                # 自动关闭熔断器
                self.reset_circuit(node_id)
                logger.info(
                    "[CIRCUIT] Auto-reset circuit for node %s after %.0fs",
                    node_id,
                    time_since_open,
                )
                return False

        return True  # 熔断器仍然打开

    def trip_circuit(self, node_id: str, reason: str = "") -> None:
        """触发节点熔断器。

        当节点声誉低于阈值时调用，将节点从候选池中隔离。
        """
        now = time.time()
        conn = self._get_connection()
        conn.execute(
            """
            UPDATE reputation_nodes
            SET circuit_open = 1, circuit_opened_at = ?
            WHERE node_id = ?
        """,
            (now, node_id),
        )
        conn.commit()

        logger.warning("[CIRCUIT] Tripped circuit for node %s: %s", node_id, reason)

    def reset_circuit(self, node_id: str) -> None:
        """手动重置节点熔断器。

        允许节点重新参与任务分配。
        """
        conn = self._get_connection()
        conn.execute(
            """
            UPDATE reputation_nodes
            SET circuit_open = 0, circuit_opened_at = NULL
            WHERE node_id = ?
        """,
            (node_id,),
        )
        conn.commit()

        logger.info("[CIRCUIT] Manually reset circuit for node %s", node_id)

    def detect_anomalies(self) -> list[str]:
        """使用IQR方法检测声誉异常值。

        返回异常节点ID列表（声誉在 Q1 - 1.5*IQR 或 Q3 + 1.5*IQR 之外）。
        """
        conn = self._get_connection()
        conn.row_factory = sqlite3.Row
        rows = conn.execute("SELECT node_id, reputation FROM reputation_nodes").fetchall()

        if len(rows) < 4:  # IQR需要至少4个数据点
            return []

        reputations = [row["reputation"] for row in rows]
        node_ids = [row["node_id"] for row in rows]

        # 计算四分位数
        sorted_reps = sorted(reputations)
        n = len(sorted_reps)

        q1_idx = n // 4
        q3_idx = (3 * n) // 4

        q1 = sorted_reps[q1_idx]
        q3 = sorted_reps[q3_idx]
        iqr = q3 - q1

        # 异常值边界
        lower_bound = q1 - 1.5 * iqr
        upper_bound = q3 + 1.5 * iqr

        # 识别异常节点
        anomalies = []
        for i, rep in enumerate(reputations):
            if rep < lower_bound or rep > upper_bound:
                anomalies.append(node_ids[i])

        return anomalies

    def list_top_nodes(self, limit: int = 10) -> list[dict]:
        """返回声誉最高的 N 个节点。"""
        conn = self._get_connection()
        conn.row_factory = sqlite3.Row
        cursor = conn.execute(
            "SELECT * FROM reputation_nodes ORDER BY reputation DESC LIMIT ?", (limit,)
        )
        return [dict(row) for row in cursor.fetchall()]

[tool filesystem_read_text_file] """Reward Engine — calculate and distribute rewards based on task completion quality."""

import time
import uuid
from dataclasses import dataclass, field
from enum import StrEnum


class RewardType(StrEnum):
    BASE = "base"
    QUALITY = "quality"
    SPEED = "speed"
    BONUS = "bonus"


@dataclass
class Reward:
    reward_id: str = field(default_factory=lambda: uuid.uuid4().hex[:12])
    agent_id: str = ""
    task_id: str = ""
    reward_type: RewardType = RewardType.BASE
    amount: float = 0.0
    reason: str = ""
    timestamp: float = field(default_factory=time.time)


@dataclass
class RewardConfig:
    base_reward: float = 10.0
    quality_multiplier: float = 1.5
    speed_multiplier: float = 1.2
    max_bonus: float = 100.0


class RewardEngine:
    """Calculate and distribute rewards based on task completion."""

    def __init__(self, config: RewardConfig | None = None):
        self.config = config or RewardConfig()
        self._history: dict[str, list[Reward]] = {}
        self._pending: dict[str, float] = {}

    def calculate(self, agent_id: str, task_id: str, quality_score: float,
                  completion_time_sec: float, expected_time_sec: float) -> Reward:
        base = self.config.base_reward
        quality_bonus = base * (quality_score - 0.5) * self.config.quality_multiplier
        speed_ratio = expected_time_sec / max(completion_time_sec, 0.1)
        speed_bonus = base * min(speed_ratio - 1.0, 1.0) * self.config.speed_multiplier
        total = max(0.0, min(base + quality_bonus + speed_bonus, self.config.max_bonus))
        reward = Reward(agent_id=agent_id, task_id=task_id,
                        reward_type=RewardType.BASE if abs(total - base) < 1 else RewardType.QUALITY,
                        amount=round(total, 2))
        self._history.setdefault(agent_id, []).append(reward)
        self._pending[agent_id] = self._pending.get(agent_id, 0) + total
        return reward

    def get_pending(self, agent_id: str) -> float:
        return self._pending.get(agent_id, 0.0)

    def payout(self, agent_id: str) -> float:
        return self._pending.pop(agent_id, 0.0)

    def get_history(self, agent_id: str, limit: int = 50) -> list[Reward]:
        return self._history.get(agent_id, [])[-limit:]

    def get_stats(self, agent_id: str) -> dict:
        rewards = self._history.get(agent_id, [])
        if not rewards:
            return {"total": 0, "count": 0, "avg": 0.0, "max": 0.0}
        amounts = [r.amount for r in rewards]
        return {"total": sum(amounts), "count": len(amounts), "avg": sum(amounts) / len(amounts), "max": max(amounts)}

