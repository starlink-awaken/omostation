class TestEnergyLedgerRecordDebit:
    """Tests for EnergyLedger idempotent debit recording."""

    def setup_method(self):
        self.ledger = EnergyLedger(db_path=":memory:")

    def teardown_method(self):
        self.ledger.close()

    def test_record_debit_from_coordinator_new(self):
        """A new debit from coordinator should be processed."""
        result = self.ledger.record_debit_from_coordinator(
            amount=50.0, source="coordinator", trace_id="trace-debit-1"
        )
        assert result["success"] is True

    def test_record_debit_from_coordinator_duplicate(self):
        """A duplicate debit should be idempotently skipped."""
        self.ledger.record_debit_from_coordinator(
            amount=50.0, source="coordinator", trace_id="trace-debit-2"
        )
        result = self.ledger.record_debit_from_coordinator(
            amount=50.0, source="eventbus", trace_id="trace-debit-2"
        )
        assert result.get("duplicate") is True
        assert result["status"] == "success"

    def test_get_idempotency_stats(self):
        """get_idempotency_stats should return non-empty stats."""
        self.ledger.record_debit_from_coordinator(
            amount=10.0, source="coordinator", trace_id="trace-stats"
        )
        stats = self.ledger.get_idempotency_stats()
        assert stats["cache_size"] >= 1


