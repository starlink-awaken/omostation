class TestEnergyLedgerLLMCost:
    """Tests for LLM cost tracking."""

    def setup_method(self):
        self.ledger = EnergyLedger(db_path=":memory:")

    def teardown_method(self):
        self.ledger.close()

    def test_record_llm_cost(self):
        """record_llm_cost should create a debit entry."""
        result = self.ledger.record_llm_cost(
            provider="anthropic", model="claude-3-sonnet", tokens_used=500, cost_eu=2.5
        )
        assert result["success"] is True

    def test_get_llm_cost_summary(self):
        """get_llm_cost_summary should return aggregated costs."""
        self.ledger.record_llm_cost(
            provider="anthropic", model="claude-3-sonnet", tokens_used=500, cost_eu=2.5
        )
        self.ledger.record_llm_cost(
            provider="openai", model="gpt-4", tokens_used=300, cost_eu=1.5
        )
        summary = self.ledger.get_llm_cost_summary(since_hours=24)
