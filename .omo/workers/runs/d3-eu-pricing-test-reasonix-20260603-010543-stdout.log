class TestLedgerSingleton:
    """Tests for get_ledger/reset_ledger singleton."""

    def setup_method(self):
        reset_ledger()

    def teardown_method(self):
        reset_ledger()

    def test_get_ledger_returns_instance(self):
        """get_ledger should return an EnergyLedger instance."""
        ledger = get_ledger()
        assert isinstance(ledger, EnergyLedger)

    def test_get_ledger_singleton(self):
        """get_ledger should return the same instance."""
        a = get_ledger()
        b = get_ledger()
        assert a is b

    def test_reset_ledger_creates_new_instance(self):
        """After reset, get_ledger should return a new instance."""
        a = get_ledger()
        reset_ledger()
        b = get_ledger()
        assert a is not b

