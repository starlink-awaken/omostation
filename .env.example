# .env.example — omostation environment variables
#
# Copy to .env and fill in values. Most variables have defaults;
# only API keys and non-standard ports need to be set explicitly.
#
# SSOT: protocols/vault-paths.yaml (paths), protocols/port-registry.yaml (ports)
# Project-level .env.example files exist in projects/cockpit, projects/observability,
# projects/runtime, projects/family-hub, projects/gbrain

# ── LLM / AI ──────────────────────────────────
# At least one API key is required for LLM-dependent services
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Azure OpenAI (optional, used by aetherforge)
AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=
# DeepSeek / Google (optional, used by aetherforge gateway)
# DEEPSEEK_API_KEY=
# GOOGLE_API_KEY=

# ── LLM Gateway ───────────────────────────────
# Port for the LLM gateway proxy (default: 9290)
LLM_GATEWAY_PORT=9290
# LLM_GATEWAY_API_KEY=
# LLM_PROVIDER=

# ── Ollama (local LLM, optional) ─────────────
# OLLAMA_ENDPOINT=
# WKS_OLLAMA_MODEL=

# ── Vault Paths (override for CI/containers) ─
# When set, overrides protocols/vault-paths.yaml defaults
# See protocols/vault-paths.yaml for all available keys
# VAULT_PATHS_COCKPIT_ROOT=
# VAULT_PATHS_VAULT_ROOT=
# VAULT_PATHS_RUNTIME_ROOT=

# ── OPC Mode ──────────────────────────────────
# Operational mode: weekly | monthly | pre-release
# L0 constraint: must be env-transmitted, never hardcoded
OPC_MODE=weekly

# ── OMO Webhook ───────────────────────────────
# Webhook endpoint for observability alerts (default: local)
OMO_WEBHOOK_URL=http://localhost:9100/webhook

# ── Observability (Langfuse) ─────────────────
# LANGFUSE_API_KEY=
# LANGFUSE_URL=

# ── Cockpit ──────────────────────────────────
# Port for cockpit dashboard (default: 8090, see protocols/port-registry.yaml)
# GBRAIN_PORT=
# OMO_DIR=

# ── C2G ─────────────────────────────────────
# C2G_LLM_URL=

# ── Governance ──────────────────────────────
# Enable tuned weights in governance-readiness (default: off)
# USE_TUNED_WEIGHTS=0

# ── OpenTelemetry (agora) ───────────────────
# OTEL_SERVICE_NAME=

# ── Workspace Root ────────────────────────────
# Used by audit/health tools (default: auto-detected)
# WORKSPACE_ROOT=

# ── OMO Root ─────────────────────────────────
# Used by ssot-writeback (default: projects/omo)
# OMO_ROOT=

# ── MCP Registration ──────────────────────────
# Python binary for MCP server registration (default: auto-detected)
# HERMES_PYTHON=
