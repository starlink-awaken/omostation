#!/bin/bash
# pre-commit — arcnode 约束变更验证
# 当 arcnode 验证脚本可用时，在提交前运行变更验证。
# 如果 arcnode 未安装，发出警告但不阻止提交。

set -euo pipefail

SCRIPTS_DIR="${ARCNODE_SCRIPTS_DIR:-$HOME/.hermes/scripts}"
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BIN_SCRIPT="$PROJECT_ROOT/bin/arcnode-validate"

# ── 检查 arcnode 可用性 ───────────────────────────────────────────────────

if [ -d "$SCRIPTS_DIR" ] && ls "$SCRIPTS_DIR"/validate-* 1>/dev/null 2>&1; then
    echo "🔍 arcnode: 发现验证脚本 ($SCRIPTS_DIR)"

    if [ -x "$BIN_SCRIPT" ]; then
        echo "🔍 arcnode: 运行变更验证..."
        if python3 "$BIN_SCRIPT" --changed; then
            echo "✅ arcnode: 约束验证全部通过"
        else
            echo "❌ arcnode: 约束验证失败，提交已阻止"
            echo "   运行 \`python3 bin/arcnode-validate --all\` 查看完整结果"
            exit 1
        fi
    else
        echo "⚠ arcnode: bin/arcnode-validate 不存在或不可执行"
        # 降级：直接运行所有 EG 验证脚本
        for script in "$SCRIPTS_DIR"/validate-EG*; do
            [ -x "$script" ] || continue
            echo "  → $(basename "$script")"
            if python3 "$script" "$PROJECT_ROOT"; then
                echo "    ✅ 通过"
            else
                echo "    ❌ 失败"
                exit 1
            fi
        done
        echo "✅ arcnode: 约束验证全部通过"
    fi

elif command -v arcnode &>/dev/null; then
    echo "🔍 arcnode: 发现 CLI 工具"
    if arcnode validate --changed; then
        echo "✅ arcnode: 约束验证全部通过"
    else
        echo "❌ arcnode: 约束验证失败，提交已阻止"
        exit 1
    fi

else
    echo "⚠ arcnode: 未安装 (未在 PATH 或 $SCRIPTS_DIR 找到)"
    echo "  提交继续，但约束未验证。"
    echo "  安装: pip install hermes-agent"
fi
